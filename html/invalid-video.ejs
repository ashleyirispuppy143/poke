<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Video Unavailable <%= (locals.v) ? '- ' + v : '' %></title>
    <style>
        @import url('https://p.poketube.fun/https://fonts.bunny.net/css?family=roboto:400,500&display=swap');

        body {
            margin: 0;
            padding: 0;
            font-family: 'Roboto', Arial, sans-serif;
            background-color: #000000;
            color: #f1f1f1;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        #error-container {
            max-width: 500px;
            width: 90%;
            text-align: center;
        }

        .error-icon {
            width: 64px;
            height: 64px;
            fill: #ffffff;
            margin-bottom: 24px;
        }

        h1 {
            font-size: 24px;
            font-weight: 400;
            margin: 0 0 12px 0;
            color: #ffffff;
        }

        .subtitle {
            font-size: 15px;
            color: #aaaaaa;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .might-be {
            font-size: 15px;
            color: #f1f1f1;
            margin-bottom: 16px;
        }

        .reasons-list {
            text-align: left;
            display: inline-block;
            padding: 0;
            margin: 0 auto 36px auto;
            font-size: 14px;
            color: #aaaaaa;
            line-height: 1.6;
            list-style-type: none;
        }

        .reasons-list li {
            margin-bottom: 10px;
            position: relative;
            padding-left: 18px;
        }

        .reasons-list li.active-reason {
            color: #ff4e4e;
            font-weight: 500;
        }

        .reasons-list li::before {
            content: "•";
            position: absolute;
            left: 0;
            color: #717171;
        }

        .actions {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }

        .btn-home,
        .btn-youtube {
            border: none;
            min-height: 36px;
            padding: 0 16px;
            font-size: 14px;
            font-weight: 500;
            border-radius: 18px;
            cursor: pointer;
            transition: background-color 0.2s, opacity 0.2s;
            font-family: 'Roboto', Arial, sans-serif;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-sizing: border-box;
            white-space: nowrap;
        }

        .btn-home {
            background-color: #f1f1f1;
            color: #0f0f0f;
        }

        .btn-home:hover {
            background-color: #d9d9d9;
        }

        .btn-youtube {
            background-color: #272727;
            color: #f1f1f1;
        }

        .btn-youtube:hover {
            background-color: #3f3f3f;
        }

        .report-issue {
            font-size: 13px;
            color: #717171;
            line-height: 1.6;
        }

        .report-issue a {
            font-weight: 500;
            color: #aaaaaa;
            text-decoration: none;
        }

        .report-issue a:hover {
            color: #f1f1f1;
            text-decoration: underline;
        }

        .debug-info {
            margin-top: 15px;
            font-family: monospace;
            font-size: 11px;
            opacity: 0.4;
            border-top: 1px solid #333;
            padding-top: 10px;
        }
    </style>
</head>
<body>

    <%
        const getSafeErrorMessage = value => {
            const message = String(value || "").trim();

            if (!message) {
                return "No error message provided";
            }

            if (/^fetch failed for\s+.+/i.test(message)) {
                return "fetch timeouted";
            }

            return message;
        };

        const issueNow = new Date();
        const issueMonths = [
            "january",
            "february",
            "march",
            "april",
            "may",
            "june",
            "july",
            "august",
            "september",
            "october",
            "november",
            "december"
        ];

        const padIssueNumber = value => String(value).padStart(2, "0");

        const issueDateFormatted = `${issueNow.getUTCDate()} ${issueMonths[issueNow.getUTCMonth()]} ${issueNow.getUTCFullYear()}, ${padIssueNumber(issueNow.getUTCHours())}:${padIssueNumber(issueNow.getUTCMinutes())} UTC`;
        const issueVideoId = locals.v || "Unknown";
        const issueErrorMessage = getSafeErrorMessage(locals.error_message);
        const issueReason = locals.err_reason || "Unknown";
        const issuePageUrl = locals.url || locals.page_url || "Please paste the Poke page URL here";
        const issueLabel = "bug";

        const issueTitle = `[Video Error] ${issueVideoId} | ${issueErrorMessage}`;

        const issueBody = [
            "Haiiii random Poke user that ran into this silly little video problem D:",
            "",
            "We are so so sorry this happened. Poke tried its best to load the video, but something went bonk, like a cat knocking a glass off a table or a dog stepping on the Wi-Fi cable.",
            "",
            "Good news though: this report already has the boring techy bits filled in for you. You can leave them here, then add anything you noticed below so the Poke contributors can figure out what happened faster.",
            "",
            "Auto-filled bug details:",
            `Video ID: ${issueVideoId}`,
            `Error message: ${issueErrorMessage}`,
            `Error reason: ${issueReason}`,
            `Reported at: ${issueDateFormatted}`,
            `Page URL: ${issuePageUrl}`,
            "",
            "What happened?",
            "- The video opened the unavailable page instead of playing.",
            "",
            "What were you trying to do?",
            "- I was trying to watch this video on Poke.",
            "",
            "What did you expect to happen?",
            "- The video should have loaded normally, or Poke should have explained the problem more clearly.",
            "",
            "Tiny helpful questions for you, dear bug reporter:",
            "- Does the video work when you press Try on YouTube?",
            "- Did the page break right away, or did it load for a bit first?",
            "- Did refreshing the page help at all?",
            "- Does this happen every time you open this same video?",
            "- Are other videos working fine on Poke?",
            "- What browser are you using?",
            "- What device or operating system are you using?",
            "",
            "Extra clue corner:",
            "- You can paste screenshots, weird behavior, console messages, or anything else that feels useful here.",
            "- No pressure to fill out everything. Even a tiny clue can help the Poke contributors a lot.",
            "- Thank you for helping make Poke better. Very cool of you, honestly."
        ].join("\n");

        const issueUrl = `https://codeberg.org/ashleyirispuppy/poke/issues/new?title=${encodeURIComponent(issueTitle)}&body=${encodeURIComponent(issueBody)}&labels=${encodeURIComponent(issueLabel)}`;
    %>

    <div id="error-container">

        <svg class="error-icon" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
        </svg>

        <h1>Video unavailable</h1>

        <p class="subtitle">
            <% if (locals.error_message) { %>
                <% if (error_message === "Video unavailable.") { %>
                    This video isn't available any more (╥﹏╥)
                <% } else { %>
                    <%= issueErrorMessage %>
                <% } %>
            <% } else { %>
                This video isn't available right now. (╥﹏╥)
            <% } %>
        </p>

        <% if (locals.knownErrors && locals.err_reason && knownErrors[err_reason]) { %>
        <% } else { %>
            <div class="might-be">This usually happens because...</div>
            <ul class="reasons-list">
                <li>The video was removed by the uploader.</li>
                <li>The uploader closed their account.</li>
                <li>The video was taken down for Terms of Service violations.</li>
                <li>The video ID provided is invalid.</li>
            </ul>
        <% } %>

        <div class="actions">
            <a class="btn-home" href="/home">Go Home</a>

            <% if (locals.v) { %>
                <a class="btn-youtube" href="https://www.youtube.com/watch?v=<%= encodeURIComponent(v) %>" target="_blank" rel="noopener noreferrer">Try on YouTube</a>
            <% } else { %>
                <a class="btn-youtube" href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer">Try on YouTube</a>
            <% } %>
        </div>

        <div class="report-issue">
            Think this is a Poke mistake?<br>
            <a href="<%= issueUrl %>" target="_blank" rel="noopener noreferrer">Report an issue here</a>.
        </div>

    </div>

</body>
</html>