<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Poke | Download Video</title>
  <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no,viewport-fit=cover" />
  <meta name="theme-color" content="<%= color %>"/>
  <meta property="og:type" content="website" />
  <meta property="og:title" content="PokeTube - Video Downloader" />
  <meta property="og:image" content="https://i.ytimg.com/vi/<%= v %>/maxresdefault.jpg" />
  
  <link rel="icon" href="/css/yt-ukraine.svg?v=7" />
  <link rel="manifest" href="/manifest.json" />
  <link href="https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css" rel="stylesheet" />
  
  <style>
    :root {
      /* Palette */
      --brand: <%= color %>;
      --bg-main: #0f0f0f;
      --bg-card: #272727;
      --bg-hover: #3f3f3f;
      --bg-active: #ffffff;
      
      --text-primary: #f1f1f1;
      --text-secondary: #aaaaaa;
      --text-link: #3ea6ff;
      --text-inverse: #0f0f0f;
      
      /* Layout */
      --radius-lg: 12px;
      --radius-md: 8px;
      --radius-pill: 18px;
      --pad-main: clamp(16px, 4vw, 24px);
    }

    @font-face {
      src: url("/static/robotoflex.ttf");
      font-family: "PokeTube Flex";
      font-style: normal;
      font-stretch: 1% 800%;
      font-display: swap;
    }

    /* --- Base --- */
    *, *::before, *::after { box-sizing: border-box; }
    
    body {
      margin: 0;
      color: var(--text-primary);
      background-color: var(--bg-main);
      font-family: "PokeTube Flex", Roboto, Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 10px; }
    ::-webkit-scrollbar-track { background: var(--bg-main); }
    ::-webkit-scrollbar-thumb { background: #717171; border-radius: 8px; border: 2px solid var(--bg-main); }
    ::-webkit-scrollbar-thumb:hover { background: #a0a0a0; }

    a { color: inherit; text-decoration: none; transition: 0.2s; }
    
    /* --- Topbar --- */
    .topbar {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 16px;
      background: rgba(15, 15, 15, 0.95);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    }
    
    .brand img { height: 24px; display: block; margin-left: 12px; }
    
    .actions { display: flex; gap: 8px; }
    .icon-btn {
      width: 40px; height: 40px;
      display: grid; place-items: center;
      border-radius: 50%;
      background: transparent;
      color: var(--text-primary);
      font-size: 18px;
      transition: background 0.2s;
    }
    .icon-btn:hover { background: var(--bg-card); }

    /* --- Main Layout --- */
    .container {
      max-width: 1600px;
      margin: 0 auto;
      padding: 24px var(--pad-main);
      display: flex;
      flex-direction: row;
      gap: 24px;
      align-items: flex-start;
      animation: fadeIn 0.4s ease-out;
    }

    @media (max-width: 1024px) {
      .container { flex-direction: column; }
      .yt-secondary { width: 100% !important; }
    }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .yt-primary { flex: 1; min-width: 0; }
    .yt-secondary { width: 400px; flex-shrink: 0; }

    /* --- Player / Thumbnail Area --- */
    .player-wrap {
      position: relative;
      display: block;
      width: 100%;
      aspect-ratio: 16/9;
      background: transparent;
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 16px;
      cursor: pointer;
    }
    .player-thumb { 
      width: 100%; 
      height: 100%; 
      object-fit: cover; 
      display: block; 
      transition: opacity 0.2s ease, transform 0.3s ease;
    }
    .player-wrap:hover .player-thumb {
      opacity: 0.8;
      transform: scale(1.02);
    }

    /* Hover Play Button Overlay - Blurred Circle */
    .play-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0.9);
      width: 72px;
      height: 72px;
      background-color: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 26px;
      opacity: 0;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      /* Nudge the play icon slightly right to look centered visually */
      padding-left: 4px; 
    }
    .player-wrap:hover .play-overlay {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
      background-color: rgba(0, 0, 0, 0.6);
      border-color: rgba(255, 255, 255, 0.4);
    }

    /* --- Video Info --- */
    .video-title {
      font-size: 20px;
      font-weight: 700;
      margin: 0 0 8px;
      line-height: 1.4;
      color: var(--text-primary);
    }

    .video-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
    .subtitle { font-size: 14px; color: var(--text-secondary); font-weight: 500; }
    .subtitle a { color: var(--text-primary); font-weight: 600; }
    .subtitle a:hover { text-decoration: underline; }
    .subtitle code { background: var(--bg-card); padding: 2px 6px; border-radius: 4px; font-family: monospace; }

    .description-box {
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      padding: 12px 16px;
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 24px;
    }
    .description-box p { margin: 0 0 8px; }
    .description-box p:last-child { margin: 0; }

    /* --- Formats Section (Sidebar) --- */
    .section { margin-bottom: 24px; }
    .section h2 {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0 0 12px;
      display: flex; align-items: center; gap: 8px;
    }
    .helper { color: var(--text-secondary); font-size: 13px; margin: 0 0 12px 0; }
    .helper a { color: var(--text-link); }
    .helper a:hover { text-decoration: underline; }

    .grid {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .grid-2col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    /* --- Format Chips --- */
    .chip {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 12px;
      border-radius: var(--radius-md);
      transition: background 0.2s;
    }
    .chip:hover { background: var(--bg-card); }
    .chip:focus-within { background: var(--bg-card); outline: 2px solid var(--text-primary); }

    .chip .meta { display: flex; flex-direction: column; gap: 2px; }
    .chip .label { font-weight: 500; font-size: 14px; color: var(--text-primary); }
    .chip .hint { font-size: 12px; color: var(--text-secondary); }

    /* Download Button (Primary Pill) */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      height: 32px; padding: 0 16px;
      border-radius: var(--radius-pill);
      background: var(--bg-active);
      color: var(--text-inverse);
      font-weight: 600;
      font-size: 13px;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
    }
    .btn:hover { background: #d9d9d9; }
    .btn:active { transform: scale(0.97); }
    .btn i { font-size: 14px; }
    
    .btn-secondary {
      background: var(--bg-card);
      color: var(--text-primary);
    }
    .btn-secondary:hover {
      background: var(--bg-hover);
    }

    /* Alert Box */
    .alert {
      display: flex; align-items: center; gap: 12px;
      margin: 0 0 24px;
      padding: 12px 16px;
      background: rgba(62, 166, 255, 0.1);
      border: 1px solid rgba(62, 166, 255, 0.2);
      color: #3ea6ff;
      border-radius: var(--radius-md);
      font-size: 13px;
    }
    .alert::before { content: "\f05a"; font-family: "Font Awesome 6 Pro"; font-weight: 900; font-size: 16px; }

    /* --- Mux (How To) Section - Standard display (fallback when no JS) --- */
    .mux-section {
      margin-top: 16px;
      padding-top: 24px;
      border-top: 1px solid var(--bg-card);
    }
    
    .mux-intro {
      background: rgba(62, 166, 255, 0.05);
      border-left: 4px solid #3ea6ff;
      padding: 16px;
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
      margin-bottom: 20px;
    }
    
    .mux-intro h3 {
      margin: 0 0 8px 0;
      font-size: 16px;
      color: var(--text-primary);
    }
    
    .mux-intro p {
      margin: 0 0 8px 0;
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.5;
    }
    
    .mux-intro p:last-child {
      margin: 0;
    }
    
    .mux-rows {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 16px;
      margin-top: 16px;
    }

    .mux-item {
      display: flex; flex-direction: column;
      background: var(--bg-card);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .mux-header {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      display: flex; justify-content: space-between; align-items: center;
    }

    /* Terminal Look for Code */
    .terminal-window {
      padding: 16px;
      font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
      font-size: 12px;
      color: var(--text-secondary);
      background: #1a1a1a;
      flex-grow: 1;
      display: flex; flex-direction: column; gap: 12px;
    }
    
    .kbd {
      display: block;
      color: #3ea6ff;
      line-height: 1.5;
      word-break: break-all;
      background: transparent; border: none; padding: 0;
    }
    
    /* Copy Button Styled */
    .copy-action {
      align-self: flex-start;
      margin-top: auto;
      background: rgba(255,255,255,0.1);
      border: none;
      color: var(--text-primary);
      padding: 6px 12px;
      border-radius: var(--radius-pill);
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      transition: background 0.2s;
    }
    .copy-action:hover { background: rgba(255,255,255,0.2); }
    
    /* --- Mux Modal Overrides (Activated by JS) --- */
    .mux-modal-overlay {
      display: none; /* Controlled by JS active class */
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      z-index: 1000;
      align-items: center; 
      justify-content: center;
      padding: 16px;
    }
    .mux-modal-overlay.active {
      display: flex;
    }
    .mux-modal-content {
      background: var(--bg-main);
      border: 1px solid var(--bg-hover);
      border-radius: var(--radius-lg);
      max-width: 900px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
      box-shadow: 0 10px 40px rgba(0,0,0,0.6);
      animation: modalPop 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes modalPop {
      from { opacity: 0; transform: scale(0.95) translateY(10px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .mux-modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 24px;
      border-bottom: 1px solid var(--bg-card);
      position: sticky;
      top: 0;
      background: var(--bg-main);
      z-index: 10;
    }
    .mux-modal-header h2 {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
    }
    .mux-modal-close {
      background: transparent;
      border: none;
      color: var(--text-primary);
      font-size: 20px;
      cursor: pointer;
      width: 36px;
      height: 36px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      transition: background 0.2s;
    }
    .mux-modal-close:hover {
      background: var(--bg-card);
    }
    .mux-modal-body {
      padding: 24px;
    }

    /* Screen Reader Utilities */
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
  </style>
</head>
<body>
  <header class="topbar" role="banner">
    <a class="brand" href="/143" aria-label="Poke home">
      <img src="/css/logo-poke.svg?v=5" alt="Poke logo" />
    </a>
    <div class="actions" role="group" aria-label="Quick actions">
      <a class="icon-btn" href="/privacy" title="Privacy"><i class="fa-light fa-shield"></i></a>
      <a class="icon-btn" href="/video/upload?from=" title="Upload video"><i class="fa-light fa-video"></i></a>
      <a class="icon-btn" href="https://codeberg.org/ashleyirispuppy/poketube/" title="Source code"><i class="fab fa-git-alt"></i></a>
      <a class="icon-btn" href="https://codeberg.org/ashleyirispuppy/poketube/issues" title="Report a bug"><i class="fa-light fa-bug"></i></a>
    </div>
  </header>

  <main class="container">
    <div class="yt-primary">
      <a href="/watch?v=<%= v %>" class="player-wrap" aria-label="Play Video">
        <img class="player-thumb" src="/vi/<%= v %>/maxresdefault.jpg" alt="Video thumbnail" loading="eager" />
        <div class="play-overlay">
          <i class="fa-solid fa-play"></i>
        </div>
      </a>

      <h1 class="video-title">Download Media</h1>
      
      <div class="video-meta">
        <div class="subtitle">ID: <code><%= v %></code></div>
      </div>

      <div class="description-box">
        <p>Select a format to download :3 Muxed is audio+video and Video only needs a separate audio track if you plan to mux!</p>
      </div>

      <div class="alert" role="status">
        <span>if a download fails try another container (MP4 vs WEBM) or a different quality :D</span>
      </div>

      <!-- Button injected via JS to open modal. Hidden by default for noscript fallback -->
      <button id="open-mux-modal" class="btn btn-secondary" style="display: none; margin-bottom: 24px;">
        <i class="fa-light fa-layer-group"></i> How to Combine (Mux) Video & Audio
      </button>

      <!-- Standard Inline Display (Becomes modal body if JS is enabled) -->
      <section id="mux-content-section" class="mux-section" aria-labelledby="combine">
        <h2 id="combine" style="margin:0 0 12px; font-size: 20px; font-weight: 700;">Combining Video & Audio (Muxing)</h2>
        
        <div class="mux-intro">
          <h3><i class="fa-light fa-circle-info"></i> What is Muxing?</h3>
          <p>To provide you with the absolute highest qualities (like 1080p, 1440p, and 4K), YouTube separates the video track from the audio track. If you download a "Video Only" file, it won't have any sound.</p>
          <p><strong>Muxing</strong> (multiplexing) is simply stitching the separate video and audio files back together into a single playable file, <em>without</em> losing any quality or re-encoding. Download your Video, download your Audio, and use a tool like <strong>FFmpeg</strong> below!</p>
        </div>

        <div class="mux-rows">
          <div class="mux-item">
            <div class="mux-header">
              <span><i class="fab fa-linux"></i> FFmpeg — MP4 Output</span>
            </div>
            <div class="terminal-window">
              <span class="helper" style="font-size:11px; margin:0">Use this when your video is MP4 (H.264) and audio is M4A/AAC.</span>
              <code class="kbd" data-code="ffmpeg -i video.mp4 -i videoplayback.m4a -c copy -map 0:v:0 -map 1:a:0 output.mp4">
                ffmpeg -i video.mp4 -i videoplayback.m4a -c copy -map 0:v:0 -map 1:a:0 output.mp4
              </code>
              <button class="copy-action" data-target="prev"><i class="fa-light fa-copy"></i> Copy Command</button>
            </div>
          </div>

          <div class="mux-item">
            <div class="mux-header">
              <span><i class="fab fa-linux"></i> FFmpeg — WEBM Output</span>
            </div>
            <div class="terminal-window">
              <span class="helper" style="font-size:11px; margin:0">Use this when both tracks are WEBM (VP9/AV1 + Opus).</span>
              <code class="kbd" data-code="ffmpeg -i videoplayback.webm -i audio.webm -c copy -map 0:v:0 -map 1:a:0 output.webm">
                ffmpeg -i videoplayback.webm -i audio.webm -c copy -map 0:v:0 -map 1:a:0 output.webm
              </code>
              <button class="copy-action" data-target="prev"><i class="fa-light fa-copy"></i> Copy Command</button>
            </div>
          </div>

          <div class="mux-item">
            <div class="mux-header">
              <span><i class="fa-light fa-file-video"></i> FFmpeg — Mixed / MKV</span>
            </div>
            <div class="terminal-window">
              <span class="helper" style="font-size:11px; margin:0">Containers differ? (e.g., WEBM Video + M4A Audio). Mux to MKV for best compatibility!</span>
              <code class="kbd" data-code="ffmpeg -i videoplayback.webm -i videoplayback.m4a -c copy -map 0:v:0 -map 1:a:0 output.mkv">
                ffmpeg -i videoplayback.webm -i videoplayback.m4a -c copy -map 0:v:0 -map 1:a:0 output.mkv
              </code>
              <button class="copy-action" data-target="prev"><i class="fa-light fa-copy"></i> Copy Command</button>
            </div>
          </div>

          <div class="mux-item">
            <div class="mux-header"><span><i class="fab fa-windows"></i> Windows Setup</span></div>
            <div class="terminal-window">
              <pre class="kbd" style="white-space: pre-wrap;">1) Download FFmpeg and add it to your system PATH.
2) Place your video and audio files in the same folder.
3) Open Terminal/Command Prompt in that folder and run one of the commands above.</pre>
            </div>
          </div>

          <div class="mux-item">
            <div class="mux-header"><span><i class="fab fa-apple"></i> macOS / Linux Setup</span></div>
            <div class="terminal-window">
              <pre class="kbd" style="white-space: pre-wrap;"># Install ffmpeg via Homebrew (macOS) or APT (Linux)
brew install ffmpeg  # macOS
sudo apt install ffmpeg # Ubuntu/Debian

# Then run the command:
ffmpeg -i video.mp4 -i audio.m4a -c copy output.mp4</pre>
            </div>
          </div>

          <div class="mux-item">
            <div class="mux-header"><span><i class="fab fa-android"></i> Android (Termux)</span></div>
            <div class="terminal-window">
              <pre class="kbd" style="white-space: pre-wrap;">pkg install ffmpeg
cd /sdcard/Download
ffmpeg -i videoplayback.webm -i audio.webm -c copy -map 0:v:0 -map 1:a:0 output.webm</pre>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="yt-secondary">
      <section class="section">
        <h2 id="muxed"><span><i class="fa-light fa-film-canister"></i> Muxed Formats</span></h2>
        <p class="helper">youtube only gives one muxed format. <a href="https://github.com/iv-org/invidious/issues/4759">they removed HD muxed video.</a></p>
        <div class="grid">
          <article class="chip" tabindex="0">
            <div class="meta">
              <span class="label">MP4 — 480p</span>
              <span class="hint">Audio + Video • Ready to play</span>
            </div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=18"><i class="fa-light fa-download"></i> Get</a>
          </article>
        </div>
      </section>

      <section class="section">
        <h2 id="audio"><span><i class="fa-light fa-music"></i> Audio Only</span></h2>
        <div class="grid">
          <article class="chip" tabindex="0">
            <div class="meta"><span class="label">m4a — low</span><span class="hint">Small size</span></div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=139&f=webm"><i class="fa-light fa-download"></i> Get</a>
          </article>
          <article class="chip" tabindex="0">
            <div class="meta"><span class="label">m4a — high</span><span class="hint">Best Quality</span></div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=140&f=webm"><i class="fa-light fa-download"></i> Get</a>
          </article>
          <article class="chip" tabindex="0">
            <div class="meta"><span class="label">webm — low</span><span class="hint">Opus • Efficient</span></div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=249&f=webm"><i class="fa-light fa-download"></i> Get</a>
          </article>
          <article class="chip" tabindex="0">
            <div class="meta"><span class="label">webm — high</span><span class="hint">Opus • High Bitrate</span></div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=251&f=webm"><i class="fa-light fa-download"></i> Get</a>
          </article>
        </div>
      </section>

      <section class="section">
        <h2 id="videoonly"><span><i class="fa-light fa-video-slash"></i> Video Only</span></h2>
        <p class="helper" style="margin-bottom:12px">No audio!! You may need to mux with an audio track :c</p>
        <div class="grid-2col">
          <article class="chip" tabindex="0">
            <div class="meta"><span class="label">144p — MP4</span></div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=160&f=mp4"><i class="fa-light fa-download"></i></a>
          </article>
          <article class="chip" tabindex="0">
            <div class="meta"><span class="label">144p — WEBM</span></div>
            <a class="btn" href="/api/video/download?v=<%= v %>&q=278&f=webm"><i class="fa-light fa-download"></i></a>
          </article>
