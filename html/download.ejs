  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // --- Modal Setup Logic ---
      const muxSection = document.getElementById('mux-content-section');
      const openBtn = document.getElementById('open-mux-modal');
      
      // Upgrade layout if JS is enabled
      if (muxSection && openBtn) {
        // Swap default inline look to trigger button
        muxSection.style.display = 'none';
        openBtn.style.display = 'inline-flex';

        // Construct YouTube-style modal structure dynamically
        const overlay = document.createElement('div');
        overlay.className = 'mux-modal-overlay';
        
        const modal = document.createElement('div');
        modal.className = 'mux-modal-content';
        
        const modalHeader = document.createElement('div');
        modalHeader.className = 'mux-modal-header';
        modalHeader.innerHTML = `
          <h2><i class="fa-light fa-layer-group"></i> How to Mux Video & Audio</h2>
        `;
        
        const closeBtn = document.createElement('button');
        closeBtn.className = 'mux-modal-close';
        closeBtn.innerHTML = '<i class="fa-light fa-xmark"></i>';
        closeBtn.setAttribute('aria-label', 'Close dialog');
        modalHeader.appendChild(closeBtn);

        const modalBody = document.createElement('div');
        modalBody.className = 'mux-modal-body';

        // Migrate content into the modal body smoothly
        muxSection.style.display = 'block'; 
        muxSection.style.borderTop = 'none';
        muxSection.style.paddingTop = '0';
        muxSection.style.marginTop = '0';
        muxSection.querySelector('h2#combine').style.display = 'none'; // Hide redundant heading
        
        modalBody.appendChild(muxSection);
        modal.appendChild(modalHeader);
        modal.appendChild(modalBody);
        overlay.appendChild(modal);
        document.body.appendChild(overlay);

        // Open Modal Event
        openBtn.addEventListener('click', () => {
          overlay.classList.add('active');
          document.body.style.overflow = 'hidden'; // Stop background scrolling
        });

        // Close Modal Logic
        const closeModal = () => {
          overlay.classList.remove('active');
          document.body.style.overflow = '';
        };

        closeBtn.addEventListener('click', closeModal);
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) closeModal();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && overlay.classList.contains('active')) closeModal();
        });
      }

      // --- Accessible Click on Chips ---
      document.querySelectorAll('.chip').forEach(chip => {
        const btn = chip.querySelector('.btn');
        if(!btn) return;
        chip.style.cursor = 'pointer';
        chip.addEventListener('click', (e) => {
           if(e.target !== btn && !btn.contains(e.target)) btn.click();
        });
        chip.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') { 
            e.preventDefault(); 
            btn.click(); 
          }
        });
      });

      // --- Copy Functionality ---
      const toClipboard = async (text, el) => {
        try {
          await navigator.clipboard.writeText(text);
          const icon = el.querySelector('i');
          const originalClass = icon.className;
          
          el.innerHTML = '<i class="fa-light fa-check"></i> Copied!';
          el.style.color = '#3ea6ff';
          
          setTimeout(() => { 
            el.innerHTML = `<i class="${originalClass}"></i> Copy Command`;
            el.style.color = '';
          }, 1500);
        } catch (_) {
          console.error("Copy failed");
        }
      };

      // Attaches to all copy buttons (works whether inside the DOM or moved into modal)
      document.querySelectorAll('.copy-action').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const target = btn.dataset.target === 'prev' ? btn.previousElementSibling : document.querySelector(btn.dataset.target);
          const code = target?.dataset.code || target?.innerText || '';
          if (code.trim()) toClipboard(code.trim(), btn);
        });
      });
    });
  </script>
