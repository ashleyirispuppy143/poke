<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results</title>
    
    <style>
        @import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

        :root {
            --bg-color: #0f0f0f;
            --text-color: #ffffff;
            --secondary-text: #aaaaaa;
            --input-bg: #1f1f1f;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: Roboto, Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* Header / Search Bar */
        .app-header {
            padding: 10px;
            background: var(--bg-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .search-container {
            display: flex;
            align-items: center;
            background: var(--input-bg);
            border-radius: 999px;
            padding: 8px 16px;
            gap: 12px;
        }

        input[name="mobilesearch"] {
            background: transparent;
            border: none;
            color: white;
            flex: 1;
            font-size: 16px;
            outline: none;
        }

        .search-icon-inline, .search-btn {
            color: var(--secondary-text);
            font-size: 18px;
            cursor: pointer;
            border: none;
            background: none;
        }

        /* Results List */
        .video-grid {
            display: flex;
            flex-direction: column;
            padding: 10px;
            gap: 12px;
        }

        .video-card {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .thumbnail-link {
            flex-shrink: 0;
            width: 120px;
            height: 68px; /* Standard 16:9 ratio for the 120px width */
            border-radius: 8px;
            overflow: hidden;
            background: #222;
        }

        .thumbnail {
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            display: block;
        }

        .video-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: hidden;
        }

        .title {
            color: var(--text-color);
            font-size: 14px;
            text-decoration: none;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.4;
            font-weight: 400; /* Removed bold */
        }

        .author {
            color: var(--secondary-text);
            font-size: 12px;
            margin-top: 4px;
            text-decoration: none;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>
</head>
<body>

    <header class="app-header">
        <form action="/app" class="search-container">
            <i class="fa-light fa-search search-icon-inline"></i>
            <input type="text" name="mobilesearch" value="<%= typeof mobilesearch !== 'undefined' ? mobilesearch : '' %>" placeholder="Search">
            <button type="submit" class="search-btn">
                <i class="fa-light fa-arrow-right"></i>
            </button>
        </form>
    </header>

    <main class="video-grid">
        <% if (typeof j !== 'undefined' && j && Array.isArray(j.results)) { %>
            <% j.results.forEach(x => { %>
                <article class="video-card">
                    <a href="/watch?v=<%- x.videoId %>" class="thumbnail-link">
                        <span class="thumbnail" style="background-image: url('https://i.ytimg.com/vi/<%- x.videoId %>/mqdefault.jpg');"></span>
                    </a>
                    <div class="video-info">
                        <a href="/watch?v=<%- x.videoId %>" class="title"><%- x.title %></a>
                        <div class="author"><%- x.author %></div>
                    </div>
                </article>
            <% }) %>
        <% } %>
    </main>

</body>
</html>