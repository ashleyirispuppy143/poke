<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const results = typeof j !== "undefined" && j && Array.isArray(j.results) ? j.results : [];
        const videoResults = results.filter(item => item && (item.type === "video" || item.videoId));
        const searchValue = typeof mobilesearch !== "undefined" ? mobilesearch : "";
        const mediaProxyBase = typeof media_proxy_url !== "undefined" && media_proxy_url ? String(media_proxy_url).replace(/\/$/, "") : "";

        let currentPage = typeof continuation !== "undefined" && continuation ? Number(continuation) : 1;
        if (!Number.isFinite(currentPage) || currentPage < 1) currentPage = 1;

        const previousPage = currentPage > 1 ? currentPage - 1 : 1;
        const nextPage = currentPage + 1;

        function proxyMediaUrl(url) {
            if (!url) return "";
            if (!mediaProxyBase) return url;
            return mediaProxyBase + "/proxy?url=" + encodeURIComponent(url);
        }

        function pageUrl(page) {
            return "/app?mobilesearch=" + encodeURIComponent(searchValue) + "&continuation=" + encodeURIComponent(page);
        }

        function videoHref(item) {
            return item && item.videoId ? "/watch?v=" + encodeURIComponent(item.videoId) : "#";
        }

        function channelHref(item) {
            if (!item) return "#";
            if (item.authorUrl) return item.authorUrl;
            if (item.authorId) return "/channel?id=" + encodeURIComponent(item.authorId);
            return "#";
        }

        function rawVideoThumbnailUrl(videoId) {
            if (!videoId) return "";
            return "https://i.ytimg.com/vi/" + encodeURIComponent(videoId) + "/hqdefault.jpg";
        }

        function rawAvatarUrl(item) {
            if (!item || !Array.isArray(item.authorThumbnails)) return "";
            if (item.authorThumbnails[1] && item.authorThumbnails[1].url) return item.authorThumbnails[1].url;
            if (item.authorThumbnails[0] && item.authorThumbnails[0].url) return item.authorThumbnails[0].url;
            return "";
        }

        function authorInitial(author) {
            if (!author || typeof author !== "string") return "?";
            return author.trim().charAt(0).toUpperCase() || "?";
        }

        function formatDuration(seconds) {
            const value = Number(seconds);
            if (!Number.isFinite(value) || value <= 0) return "";

            const total = Math.floor(value);
            const hours = Math.floor(total / 3600);
            const minutes = Math.floor((total % 3600) / 60);
            const secs = total % 60;

            if (hours > 0) {
                return String(hours) + ":" + String(minutes).padStart(2, "0") + ":" + String(secs).padStart(2, "0");
            }

            return String(minutes) + ":" + String(secs).padStart(2, "0");
        }

        function formatCompactNumber(value) {
            const number = Number(value);
            if (!Number.isFinite(number) || number < 0) return "";

            if (number < 1000) return String(number);

            return new Intl.NumberFormat("en", {
                notation: "compact",
                maximumFractionDigits: number >= 1000000 ? 1 : 0
            }).format(number).replace("K", "k");
        }
    %>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Search</title>

    <% if (!searchValue && !(typeof tab !== "undefined" && tab)) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">

    <style>
        @import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

        @font-face {
            font-family: "PokeTube Flex";
            src: url("/static/robotoflex.ttf");
            font-style: normal;
            font-weight: 100 1000;
            font-stretch: 1% 800%;
            font-display: swap;
        }

        :root {
            --bg: #0f0f0f;
            --panel: #0f0f0f;
            --search-bg: #282828;
            --search-focus: #303030;
            --text: #f1f1f1;
            --text-soft: #aaaaaa;
            --text-muted: #8a8a8a;
            --line: #272727;
            --chip: #272727;
            --chip-hover: #343434;
            --danger: #cc0000;
        }

        * {
            box-sizing: border-box;
            font-family: inherit;
        }

        html {
            background: var(--bg);
            font-family: "PokeTube Flex", Roboto, Arial, Helvetica, sans-serif;
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: var(--bg);
            color: var(--text);
            font-family: "PokeTube Flex", Roboto, Arial, Helvetica, sans-serif;
            -webkit-tap-highlight-color: transparent;
            overscroll-behavior-y: contain;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button,
        input {
            font: inherit;
        }

        .app-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(15, 15, 15, 0.98);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
        }

        .nav-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            min-height: calc(60px + env(safe-area-inset-top));
            padding: calc(6px + env(safe-area-inset-top)) 15px 6px 12px;
        }

        .back-button {
            width: 48px;
            height: 48px;
            flex: 0 0 48px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            color: var(--text);
            font-size: 34px;
            line-height: 1;
        }

        .back-button:active {
            transform: scale(0.94);
            background: rgba(255, 255, 255, 0.06);
        }

        .search-container {
            flex: 1 1 auto;
            min-width: 0;
            height: 42px;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--search-bg);
            border: 0;
            border-radius: 999px;
            padding: 0 6px 0 18px;
            transition: background 140ms ease, box-shadow 140ms ease;
        }

        .search-container:focus-within {
            background: var(--search-focus);
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.04);
        }

        input[name="mobilesearch"] {
            appearance: none;
            width: 100%;
            min-width: 0;
            border: 0;
            outline: 0;
            background: transparent;
            color: var(--text);
            font-size: 23px;
            line-height: 1;
            padding: 0;
            font-weight: 430;
            font-stretch: 112%;
            font-variation-settings: "wdth" 112, "opsz" 20;
        }

        input[name="mobilesearch"]::placeholder {
            color: var(--text-muted);
            opacity: 1;
        }

        .clear-search-button {
            width: 42px;
            height: 42px;
            flex: 0 0 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            padding: 0;
            background: transparent;
            color: #ffffff;
            cursor: pointer;
            font-size: 31px;
            line-height: 1;
        }

        .clear-search-button:active {
            transform: scale(0.94);
            background: rgba(255, 255, 255, 0.06);
        }

        .hidden-submit {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }

        .feed {
            width: 100%;
            max-width: 520px;
            margin: 0 auto;
            padding: 13px 0 calc(96px + env(safe-area-inset-bottom));
            background: var(--bg);
        }

        .result-card {
            width: 100%;
            background: var(--panel);
            color: var(--text);
            overflow: hidden;
        }

        .result-card + .result-card {
            margin-top: 16px;
        }

        .video-card {
            padding: 0 0 11px;
        }

        .thumbnail-shell {
            width: 100%;
            padding: 0 10px;
        }

        .thumbnail-link {
            position: relative;
            display: block;
            width: 100%;
            aspect-ratio: 16 / 9;
            overflow: hidden;
            border-radius: 13px;
            background: #181818;
            box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05);
        }

        .thumbnail-img {
            display: block;
            width: 100%;
            height: 100%;
            border-radius: 13px;
            object-fit: cover;
            background: #181818;
        }

        .thumbnail-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 13px;
            background: #181818;
            color: var(--text-muted);
            font-size: 26px;
        }

        .duration-badge,
        .live-badge {
            position: absolute;
            right: 7px;
            bottom: 7px;
            min-height: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            color: #fff;
            font-size: 12px;
            line-height: 1;
            font-weight: 650;
            font-stretch: 115%;
            font-variation-settings: "wdth" 115, "opsz" 12;
        }

        .duration-badge {
            min-width: 34px;
            padding: 0 5px;
            background: rgba(0, 0, 0, 0.86);
        }

        .live-badge {
            padding: 0 7px;
            background: var(--danger);
            letter-spacing: 0.01em;
        }

        .details-row {
            display: grid;
            grid-template-columns: 38px minmax(0, 1fr);
            column-gap: 8px;
            align-items: start;
            padding: 11px 11px 0;
        }

        .avatar-link,
        .avatar-fallback {
            width: 38px;
            height: 38px;
            display: block;
            overflow: hidden;
            border-radius: 999px;
            background: #272727;
        }

        .avatar-img {
            display: block;
            width: 100%;
            height: 100%;
            border-radius: 999px;
            object-fit: cover;
            background: #272727;
        }

        .avatar-letter {
            width: 100%;
            height: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: linear-gradient(135deg, #7b1fa2, #e91e63);
            color: #fff;
            font-size: 16px;
            line-height: 1;
            font-weight: 750;
            font-stretch: 130%;
            font-variation-settings: "wdth" 130, "opsz" 14;
        }

        .text-block {
            min-width: 0;
            padding-right: 4px;
        }

        .title {
            color: var(--text);
            font-weight: 650;
            font-stretch: 200%;
            font-variation-settings: "wdth" 151, "opsz" 14;
            letter-spacing: 0.01em;
        }

        .title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            font-size: 15.5px;
            line-height: 1.24;
        }

        .meta {
            margin-top: 5px;
            color: var(--text-soft);
            font-size: 12.5px;
            font-weight: 450;
            line-height: 1.35;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-stretch: 112.5%;
            font-variation-settings: "wdth" 112.5, "opsz" 12;
        }

        .meta a {
            color: var(--text-soft);
        }

        .stats-line {
            display: flex;
            align-items: center;
            min-height: 21px;
            margin-top: 5px;
            overflow: hidden;
        }

        .view-count-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            max-width: 100%;
            min-height: 19px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
            line-height: 1;
            font-stretch: 130%;
            font-variation-settings: "wdth" 130, "opsz" 12;
        }

        .view-play-icon {
            display: inline-block;
            color: #ffffff;
            font-size: 11px;
            line-height: 1;
            transform: translateY(-0.5px);
        }

        .empty-state {
            min-height: calc(100vh - 190px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 42px 24px;
            color: var(--text-soft);
            text-align: center;
            font-size: 16px;
            line-height: 1.45;
            font-weight: 550;
            font-stretch: 140%;
            font-variation-settings: "wdth" 140, "opsz" 16;
        }

        .pagination {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 90;
            display: flex;
            justify-content: center;
            padding: 0 10px;
            pointer-events: none;
        }

        .pagination-inner {
            width: 100%;
            max-width: 520px;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            padding: 12px 10px calc(12px + env(safe-area-inset-bottom));
            background: rgba(15, 15, 15, 0.96);
            border-top: 1px solid rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            pointer-events: auto;
        }

        .page-button,
        .disabled-page-button,
        .page-count {
            min-height: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.09);
            user-select: none;
            white-space: nowrap;
            font-weight: 650;
            font-stretch: 125%;
            font-variation-settings: "wdth" 125, "opsz" 14;
        }

        .page-button,
        .disabled-page-button {
            min-width: 98px;
            gap: 8px;
            padding: 0 18px;
            background: var(--chip);
            color: var(--text);
            font-size: 14.5px;
        }

        .page-button:active {
            transform: scale(0.97);
            background: var(--chip-hover);
        }

        .disabled-page-button {
            opacity: 0.35;
            pointer-events: none;
        }

        .page-count {
            min-width: 90px;
            padding: 0 14px;
            background: #181818;
            color: var(--text-soft);
            font-size: 13.5px;
        }

        .loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 9999;
            height: 3px;
            overflow: hidden;
            pointer-events: none;
            background: rgba(255, 255, 255, 0.08);
        }

        .loading-bar::before {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            left: 0;
            width: 42%;
            border-radius: 999px;
            background: #ffffff;
            transform: translateX(-110%);
            animation: loadingBarMove 900ms ease-in-out infinite;
        }

        @keyframes loadingBarMove {
            0% {
                width: 34%;
                transform: translateX(-110%);
            }

            55% {
                width: 58%;
                transform: translateX(95%);
            }

            100% {
                width: 30%;
                transform: translateX(340%);
            }
        }

        @media (min-width: 521px) {
            .feed {
                border-left: 1px solid rgba(255, 255, 255, 0.06);
                border-right: 1px solid rgba(255, 255, 255, 0.06);
            }

            .pagination-inner {
                border-left: 1px solid rgba(255, 255, 255, 0.06);
                border-right: 1px solid rgba(255, 255, 255, 0.06);
            }
        }

        @media (max-width: 390px) {
            .nav-wrap {
                gap: 12px;
                min-height: calc(60px + env(safe-area-inset-top));
                padding: calc(6px + env(safe-area-inset-top)) 15px 6px 12px;
            }

            .back-button {
                width: 48px;
                height: 48px;
                flex-basis: 48px;
                font-size: 34px;
            }

            .search-container {
                height: 42px;
                padding: 0 6px 0 18px;
            }

            input[name="mobilesearch"] {
                font-size: 23px;
            }

            .clear-search-button {
                width: 42px;
                height: 42px;
                flex-basis: 42px;
                font-size: 31px;
            }
        }
    </style>
</head>
<body>
    <header class="app-header">
        <div class="nav-wrap">
            <a href="/home" class="back-button" aria-label="Back to home">
                <i class="fa-light fa-chevron-left"></i>
            </a>

            <form action="/app" class="search-container" role="search">
                <input type="text" name="mobilesearch" value="<%= searchValue %>" placeholder="Search" autocomplete="off">
                <button type="button" class="clear-search-button" aria-label="Clear search">
                    <i class="fa-light fa-xmark"></i>
                </button>
                <button type="submit" class="hidden-submit" aria-label="Search">Search</button>
            </form>
        </div>
    </header>

    <main class="feed">
        <% if (videoResults.length) { %>
            <% videoResults.forEach(item => { %>
                <%
                    const href = videoHref(item);
                    const authorHref = channelHref(item);
                    const thumb = proxyMediaUrl(rawVideoThumbnailUrl(item.videoId));
                    const avatar = proxyMediaUrl(rawAvatarUrl(item));
                    const duration = formatDuration(item.lengthSeconds);
                    const bareViews = formatCompactNumber(item.viewCount);
                %>

                <article class="result-card video-card">
                    <div class="thumbnail-shell">
                        <a href="<%= href %>" class="thumbnail-link" aria-label="<%= item.title || 'Video' %>">
                            <% if (thumb) { %>
                                <img class="thumbnail-img" src="<%= thumb %>" alt="" loading="lazy">
                            <% } else { %>
                                <div class="thumbnail-placeholder">
                                    <i class="fa-light fa-video"></i>
                                </div>
                            <% } %>

                            <% if (item.liveNow) { %>
                                <span class="live-badge">LIVE</span>
                            <% } else if (duration) { %>
                                <span class="duration-badge"><%= duration %></span>
                            <% } %>
                        </a>
                    </div>

                    <div class="details-row">
                        <% if (authorHref && authorHref !== "#") { %>
                            <a class="avatar-link" href="<%= authorHref %>" aria-label="<%= item.author || 'Channel' %>">
                                <% if (avatar) { %>
                                    <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                <% } else { %>
                                    <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                <% } %>
                            </a>
                        <% } else { %>
                            <div class="avatar-fallback" aria-hidden="true">
                                <% if (avatar) { %>
                                    <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                <% } else { %>
                                    <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                <% } %>
                            </div>
                        <% } %>

                        <div class="text-block">
                            <a href="<%= href %>" class="title"><%= item.title || "Untitled video" %></a>

                            <% if (item.author) { %>
                                <div class="meta">
                                    <% if (authorHref && authorHref !== "#") { %>
                                        <a href="<%= authorHref %>"><%= item.author %></a>
                                    <% } else { %>
                                        <%= item.author %>
                                    <% } %>
                                </div>
                            <% } %>

                            <% if (bareViews) { %>
                                <div class="stats-line" aria-label="<%= bareViews %> views">
                                    <span class="view-count-pill">
                                        <span class="view-play-icon" aria-hidden="true">▷</span>
                                        <span><%= bareViews %></span>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </article>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                you...somehow found something that doesnt exist on youtube...woaw...
            </div>
        <% } %>
    </main>

    <% if (results.length) { %>
        <nav class="pagination" aria-label="Search pages">
            <div class="pagination-inner">
                <% if (currentPage > 1) { %>
                    <a class="page-button" href="<%= pageUrl(previousPage) %>" rel="prev" aria-label="Previous page">
                        <i class="fa-light fa-arrow-left"></i>
                        Prev
                    </a>
                <% } else { %>
                    <span class="disabled-page-button" aria-disabled="true">
                        <i class="fa-light fa-arrow-left"></i>
                        Prev
                    </span>
                <% } %>

                <span class="page-count" aria-current="page">Page <%= currentPage %></span>

                <a class="page-button" href="<%= pageUrl(nextPage) %>" rel="next" aria-label="Next page">
                    Next
                    <i class="fa-light fa-arrow-right"></i>
                </a>
            </div>
        </nav>
    <% } %>

    <script>
        const searchInput = document.querySelector('input[name="mobilesearch"]');
        const clearSearchButton = document.querySelector(".clear-search-button");

        function removeLoadingBar() {
            document.querySelectorAll(".loading-bar").forEach(loadingBar => {
                loadingBar.remove();
            });
        }

        function showLoadingBar() {
            if (document.querySelector(".loading-bar")) return;

            const loadingBar = document.createElement("div");
            loadingBar.className = "loading-bar";
            loadingBar.setAttribute("aria-hidden", "true");

            document.body.appendChild(loadingBar);
        }

        if (clearSearchButton && searchInput) {
            clearSearchButton.addEventListener("click", () => {
                searchInput.value = "";
                searchInput.focus();
            });
        }

        document.addEventListener("click", event => {
            const link = event.target.closest("a");
            if (!link) return;

            const href = link.getAttribute("href");
            if (!href || href.startsWith("#") || href.startsWith("javascript:")) return;
            if (link.target && link.target !== "_self") return;
            if (link.hasAttribute("download")) return;
            if (event.defaultPrevented) return;
            if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

            showLoadingBar();
        });

        document.querySelectorAll("form").forEach(form => {
            form.addEventListener("submit", () => {
                showLoadingBar();
            });
        });

        window.addEventListener("pageshow", removeLoadingBar);
        window.addEventListener("pagehide", removeLoadingBar);
        window.addEventListener("popstate", removeLoadingBar);

        document.addEventListener("visibilitychange", () => {
            if (!document.hidden) removeLoadingBar();
        });

        if ("scrollRestoration" in history) {
            history.scrollRestoration = "auto";
        }

        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.getRegistrations().then(registrations => {
                registrations.forEach(registration => {
                    registration.unregister();
                });
            });
        }
    </script>
</body>
</html>