<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const results = typeof j !== "undefined" && j && Array.isArray(j.results) ? j.results : [];
        const videoResults = results.filter(item => item && (item.type === "video" || item.videoId));
        const searchValue = typeof mobilesearch !== "undefined" ? mobilesearch : "";
        const mediaProxyBase = typeof media_proxy_url !== "undefined" && media_proxy_url ? String(media_proxy_url).replace(/\/$/, "") : "";

        let currentPage = typeof continuation !== "undefined" && continuation ? Number(continuation) : 1;
        if (!Number.isFinite(currentPage) || currentPage < 1) currentPage = 1;

        const previousPage = currentPage > 1 ? currentPage - 1 : 1;
        const nextPage = currentPage + 1;

        function proxyMediaUrl(url) {
            if (!url) return "";
            if (!mediaProxyBase) return url;
            return mediaProxyBase + "/proxy?url=" + encodeURIComponent(url);
        }

        function pageUrl(page) {
            return "/app?mobilesearch=" + encodeURIComponent(searchValue) + "&continuation=" + encodeURIComponent(page);
        }

        function videoHref(item) {
            return item && item.videoId ? "/watch?v=" + encodeURIComponent(item.videoId) : "#";
        }

        function channelHref(item) {
            if (!item) return "#";
            if (item.authorUrl) return item.authorUrl;
            if (item.authorId) return "/channel?id=" + encodeURIComponent(item.authorId);
            return "#";
        }

        function rawVideoThumbnailUrl(videoId) {
            if (!videoId) return "";
            return "https://i.ytimg.com/vi/" + encodeURIComponent(videoId) + "/hqdefault.jpg";
        }

        function rawAvatarUrl(item) {
            if (!item || !Array.isArray(item.authorThumbnails)) return "";
            if (item.authorThumbnails[1] && item.authorThumbnails[1].url) return item.authorThumbnails[1].url;
            if (item.authorThumbnails[0] && item.authorThumbnails[0].url) return item.authorThumbnails[0].url;
            return "";
        }

        function authorInitial(author) {
            if (!author || typeof author !== "string") return "?";
            return author.trim().charAt(0).toUpperCase() || "?";
        }

        function formatDuration(seconds) {
            const value = Number(seconds);
            if (!Number.isFinite(value) || value <= 0) return "";

            const total = Math.floor(value);
            const hours = Math.floor(total / 3600);
            const minutes = Math.floor((total % 3600) / 60);
            const secs = total % 60;

            if (hours > 0) {
                return String(hours) + ":" + String(minutes).padStart(2, "0") + ":" + String(secs).padStart(2, "0");
            }

            return String(minutes) + ":" + String(secs).padStart(2, "0");
        }

        function formatCompactNumber(value) {
            const number = Number(value);
            if (!Number.isFinite(number) || number < 0) return "";

            if (number < 1000) return String(number);

            return new Intl.NumberFormat("en", {
                notation: "compact",
                maximumFractionDigits: number >= 1000000 ? 1 : 0
            }).format(number).replace("K", "k");
        }
    %>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Search</title>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">

    <style>
        @import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

        @font-face {
            font-family: "PokeTube Flex";
            src: url("/static/robotoflex.ttf");
            font-style: normal;
            font-weight: 100 1000;
            font-stretch: 1% 800%;
            font-display: swap;
        }

        :root {
            --bg: #0f0f0f;
            --search-bg: #282828;
            --text: #f1f1f1;
            --text-soft: #aaaaaa;
            --text-muted: #8a8a8a;
        }

        * { box-sizing: border-box; }

        html, body {
            background: var(--bg);
            color: var(--text);
            font-family: "PokeTube Flex", Roboto, Arial, Helvetica, sans-serif;
            margin: 0;
        }

        .app-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(15, 15, 15, 0.98);
        }

        .nav-wrap {
            display: flex;
            align-items: center;
            padding: 8px 12px;
            gap: 8px;
        }

        .back-button {
            width: 36px;
            height: 36px; /* Matches search container */
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 20px;
        }

        .search-container {
            flex: 1;
            height: 36px;
            display: flex;
            align-items: center;
            background: var(--search-bg);
            border-radius: 18px;
            padding: 0 12px;
        }

        input[name="mobilesearch"] {
            flex: 1;
            border: 0;
            outline: 0;
            background: transparent;
            color: var(--text);
            font-size: 16px;
            padding: 0 8px;
        }

        .clear-search-button {
            background: transparent;
            border: 0;
            color: var(--text);
            font-size: 18px;
        }

        .feed { padding: 12px 0; }

        .result-card { margin-bottom: 24px; }

        .thumbnail-link {
            position: relative;
            display: block;
            width: 100%;
            aspect-ratio: 16 / 9;
        }

        .thumbnail-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .duration-badge {
            position: absolute;
            right: 8px;
            bottom: 8px;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 2px 4px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
        }

        .details-row {
            display: flex;
            gap: 12px;
            padding: 12px;
        }

        .avatar-link {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            overflow: hidden;
            flex-shrink: 0;
        }

        .avatar-img { width: 100%; height: 100%; object-fit: cover; }

        .text-block { flex: 1; }

        .title {
            font-size: 16px;
            font-weight: 500;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.4;
        }

        .meta {
            font-size: 14px;
            color: var(--text-soft);
            margin-top: 4px;
        }

        .hidden-submit { display: none; }
    </style>
</head>
<body>
    <header class="app-header">
        <div class="nav-wrap">
            <a href="/home" class="back-button"><i class="fa-light fa-arrow-left"></i></a>
            <form action="/app" class="search-container">
                <input type="text" name="mobilesearch" value="<%= searchValue %>" placeholder="Search">
                <button type="button" class="clear-search-button"><i class="fa-light fa-xmark"></i></button>
            </form>
        </div>
    </header>

    <main class="feed">
        <% videoResults.forEach(item => { %>
            <%
                const href = videoHref(item);
                const thumb = proxyMediaUrl(rawVideoThumbnailUrl(item.videoId));
                const avatar = proxyMediaUrl(rawAvatarUrl(item));
                const duration = formatDuration(item.lengthSeconds);
            %>
            <article class="result-card">
                <a href="<%= href %>" class="thumbnail-link">
                    <img class="thumbnail-img" src="<%= thumb %>" loading="lazy">
                    <% if (duration) { %><span class="duration-badge"><%= duration %></span><% } %>
                </a>
                <div class="details-row">
                    <a href="<%= channelHref(item) %>" class="avatar-link">
                        <img class="avatar-img" src="<%= avatar %>">
                    </a>
                    <div class="text-block">
                        <div class="title"><%= item.title %></div>
                        <div class="meta"><%= item.author %> • <%= formatCompactNumber(item.viewCount) %> views</div>
                    </div>
                </div>
            </article>
        <% }) %>
    </main>
</body>
</html>