<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Poke | Discover</title>
    
    <!-- Redirect for homepage -->
    <% if (!mobilesearch && !tab) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">
    <link href="https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #0f0f0f;
            --text-color: #ffffff;
            --secondary-text: #aaaaaa;
            --input-bg: #222222;
            --accent-color: #ff0000;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: Roboto, Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* Header / Masthead */
        header {
            display: flex;
            align-items: center;
            padding: 10px 15px;
            background: var(--bg-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo { width: 30px; margin-right: 15px; }

        /* Modern Search Input */
        .search-container {
            flex-grow: 1;
            display: flex;
            background: var(--input-bg);
            border-radius: 20px;
            padding: 5px 15px;
            border: 1px solid #333;
        }

        input[name="mobilesearch"] {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            font-size: 16px;
        }

        button.search-btn {
            background: transparent;
            border: none;
            color: white;
            cursor: pointer;
        }

        /* Video Grid */
        .video-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            padding: 15px;
        }

        .video-card {
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: white;
        }

        .thumbnail {
            width: 100%;
            aspect-ratio: 16 / 9;
            background-size: cover;
            background-position: center;
            border-radius: 12px;
            margin-bottom: 8px;
        }

        .video-info .title {
            font-size: 14px;
            font-weight: 500;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .video-info .author {
            font-size: 12px;
            color: var(--secondary-text);
            margin-top: 4px;
        }

        /* Utilities */
        .loading {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 9999;
            display: flex; justify-content: center; align-items: center;
        }
        .spinner {
            border: 4px solid #333; border-top: 4px solid #fff;
            border-radius: 50%; width: 40px; height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <header>
        <a href="/"><img src="/css/logo-poke.svg" class="logo" alt="Logo"></a>
        <form action="/app" class="search-container">
            <input type="text" name="mobilesearch" value="<%= typeof mobilesearch !== 'undefined' ? mobilesearch : '' %>" placeholder="Search videos...">
            <button type="submit" class="search-btn"><i class="fa-light fa-search"></i></button>
        </form>
    </header>

    <main class="video-grid">
        <% if (typeof j !== 'undefined' && j && Array.isArray(j.results)) { %>
            <% j.results.forEach(x => { %>
                <a href="/watch?v=<%- x.videoId %>" class="video-card">
                    <div class="thumbnail" style="background-image: url('https://i.ytimg.com/vi/<%= x.videoId %>/hqdefault.jpg');"></div>
                    <div class="video-info">
                        <div class="title"><%- x.title %></div>
                        <div class="author"><%- x.author %></div>
                    </div>
                </a>
            <% }) %>

            <!-- Pagination -->
            <div style="display: flex; justify-content: space-between; margin-top: 20px;">
                <% if (typeof continuation !== 'undefined' && Number(continuation) > 1) { %>
                    <a href="/app?mobilesearch=<%=mobilesearch%>&continuation=<%- Number(continuation) - 1 %>">Previous</a>
                <% } %>
                
                <% if (typeof continuation !== 'undefined') { %>
                    <a href="/app?mobilesearch=<%=mobilesearch%>&continuation=<%- Number(continuation) + 1 %>">Next Page</a>
                <% } %>
            </div>
        <% } else { %>
            <div style="text-align: center; margin-top: 50px;">
                <h1>PokeTube</h1>
                <p>A private, ad-free YouTube front-end.</p>
                <p>Search to get started!</p>
            </div>
        <% } %>
    </main>

    <script>
        const links = document.querySelectorAll('a');
        links.forEach(link => {
            link.addEventListener('click', e => {
                const loading = document.createElement('div');
                loading.className = 'loading';
                loading.innerHTML = '<div class="spinner"></div>';
                document.body.appendChild(loading);
            });
        });

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(regs => {
                for (let reg of regs) reg.unregister();
            });
        }
    </script>
</body>
</html>