<!DOCTYPE html>
<html lang="en">
<head>
    <%
        function pickBestThumbnail(thumbnails, fallbackVideoId) {
            if (Array.isArray(thumbnails) && thumbnails.length) {
                const preferred = [
                    "maxresdefault",
                    "sddefault",
                    "high",
                    "medium",
                    "default",
                    "start",
                    "middle",
                    "end"
                ];

                for (const quality of preferred) {
                    const found = thumbnails.find(thumbnail => thumbnail && thumbnail.quality === quality && thumbnail.url);
                    if (found) return found.url;
                }

                const sorted = thumbnails
                    .filter(thumbnail => thumbnail && thumbnail.url)
                    .sort((a, b) => ((b.width || 0) * (b.height || 0)) - ((a.width || 0) * (a.height || 0)));

                if (sorted[0]) return sorted[0].url;
            }

            if (fallbackVideoId) return "https://i.ytimg.com/vi/" + encodeURIComponent(fallbackVideoId) + "/hqdefault.jpg";
            return "";
        }

        function pickBestAvatar(thumbnails) {
            if (Array.isArray(thumbnails) && thumbnails.length) {
                if (thumbnails[1] && thumbnails[1].url) return thumbnails[1].url;
                if (thumbnails[0] && thumbnails[0].url) return thumbnails[0].url;

                const sorted = thumbnails
                    .filter(thumbnail => thumbnail && thumbnail.url)
                    .sort((a, b) => ((b.width || 0) * (b.height || 0)) - ((a.width || 0) * (a.height || 0)));

                if (sorted[0]) return sorted[0].url;
            }

            return "";
        }

        function formatDuration(seconds) {
            const value = Number(seconds);

            if (!Number.isFinite(value) || value <= 0) return "";

            const total = Math.floor(value);
            const hours = Math.floor(total / 3600);
            const minutes = Math.floor((total % 3600) / 60);
            const secs = total % 60;

            if (hours > 0) {
                return String(hours) + ":" + String(minutes).padStart(2, "0") + ":" + String(secs).padStart(2, "0");
            }

            return String(minutes) + ":" + String(secs).padStart(2, "0");
        }

        function formatCompactNumber(value) {
            const number = Number(value);

            if (!Number.isFinite(number) || number < 0) return "";

            if (number < 1000) return String(number);

            return new Intl.NumberFormat("en", {
                notation: "compact",
                maximumFractionDigits: number >= 1000000 ? 1 : 0
            }).format(number).replace("K", "k");
        }

        function formatViews(value) {
            const text = formatCompactNumber(value);
            return text ? text + " views" : "";
        }

        function cleanChannelId(item) {
            const raw = item && (item.authorId || item.channelId || item.ucid || item.authorUrl || item.channelUrl)
                ? (item.authorId || item.channelId || item.ucid || item.authorUrl || item.channelUrl)
                : "";

            if (!raw || typeof raw !== "string") return "";

            return raw
                .replace("/channel/", "")
                .replace("/c/", "")
                .replace("/user/", "")
                .replace(/^@/, "")
                .trim();
        }

        function authorInitial(author) {
            if (!author || typeof author !== "string") return "?";
            return author.trim().charAt(0).toUpperCase() || "?";
        }

        function resultUrl(item) {
            if (!item || !item.type) return "#";

            if (item.type === "video" && item.videoId) return "/watch?v=" + encodeURIComponent(item.videoId);
            if (item.type === "playlist" && item.playlistId) return "/playlist?list=" + encodeURIComponent(item.playlistId);

            if (item.type === "channel") {
                const id = cleanChannelId(item);
                return id ? "/channel?id=" + encodeURIComponent(id) : "#";
            }

            if (item.type === "hashtag" && item.url) return item.url;

            return "#";
        }

        function channelUrl(item) {
            const id = cleanChannelId(item);
            return id ? "/channel?id=" + encodeURIComponent(id) : "";
        }

        function metaParts(parts) {
            return parts.filter(Boolean).join(" • ");
        }

        const results = typeof j !== "undefined" && j && Array.isArray(j.results) ? j.results : [];
        let currentPage = (typeof continuation !== "undefined" && continuation) ? Number(continuation) : 1;

        if (!Number.isFinite(currentPage) || currentPage < 1) currentPage = 1;

        const searchValue = typeof mobilesearch !== "undefined" ? mobilesearch : "";
        const previousPage = currentPage > 1 ? currentPage - 1 : 1;
        const nextPage = currentPage + 1;
        const previousPageUrl = "/app?mobilesearch=" + encodeURIComponent(searchValue) + "&continuation=" + previousPage;
        const nextPageUrl = "/app?mobilesearch=" + encodeURIComponent(searchValue) + "&continuation=" + nextPage;
    %>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Search</title>

    <% if (!mobilesearch && !tab) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">

    <style>
        @import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

        :root {
            --bg-color: #0f0f0f;
            --header-bg: rgba(15, 15, 15, 0.94);
            --text-color: #ffffff;
            --secondary-text: #aaaaaa;
            --muted-text: #777777;
            --input-bg: #1f1f1f;
            --input-border: #333333;
            --input-border-focus: #575757;
            --divider: #262626;
            --red: #ff0000;
            --shadow: rgba(0, 0, 0, 0.35);
        }

        * {
            box-sizing: border-box;
        }

        html {
            background: var(--bg-color);
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
            overscroll-behavior-y: none;
        }

        body.no-scroll {
            overflow: hidden;
        }

        .app-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--header-bg);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--divider);
            box-shadow: 0 8px 24px var(--shadow);
        }

        .nav-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            min-height: 60px;
            padding: 10px 10px;
            padding-top: max(10px, env(safe-area-inset-top));
        }

        .search-container {
            flex: 1 1 auto;
            min-width: 0;
            height: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            border-radius: 999px;
            padding: 0 8px 0 15px;
            transition: border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
        }

        .search-container:focus-within {
            border-color: var(--input-border-focus);
            background: #242424;
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.05);
        }

        .search-icon-inline {
            color: var(--secondary-text);
            font-size: 15px;
            flex: 0 0 auto;
        }

        input[name="mobilesearch"] {
            appearance: none;
            width: 100%;
            min-width: 0;
            border: 0;
            outline: 0;
            padding: 0;
            background: transparent;
            color: var(--text-color);
            font-size: 16px;
            line-height: 1;
            font-weight: 500;
        }

        input[name="mobilesearch"]::placeholder {
            color: var(--muted-text);
            opacity: 1;
        }

        button.search-btn {
            width: 32px;
            height: 32px;
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            padding: 0;
            background: transparent;
            color: var(--secondary-text);
            cursor: pointer;
            font-size: 17px;
            transition: transform 160ms ease, color 160ms ease;
        }

        button.search-btn:active {
            transform: scale(0.94);
            color: white;
        }

        .feed {
            width: 100%;
            max-width: 520px;
            margin: 0 auto;
            padding: 0 0 calc(22px + env(safe-area-inset-bottom));
            background: var(--bg-color);
        }

        .top-page-counter {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 36px;
            padding: 0 12px;
            border-bottom: 1px solid var(--divider);
            color: var(--secondary-text);
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.01em;
            background: #0f0f0f;
        }

        .result-card {
            position: relative;
            display: block;
            width: 100%;
            background: #0f0f0f;
            color: white;
            overflow: hidden;
        }

        .result-card + .result-card {
            margin-top: 14px;
        }

        .result-card.video-result {
            border-bottom: 3px solid #cc0000;
        }

        .thumbnail-link {
            position: relative;
            display: block;
            width: 100%;
            aspect-ratio: 16 / 9;
            background: #111111;
            color: inherit;
            text-decoration: none;
            overflow: hidden;
        }

        .thumbnail-img {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            background: #111111;
        }

        .duration-badge {
            position: absolute;
            right: 7px;
            bottom: 7px;
            min-width: 34px;
            height: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
            border-radius: 3px;
            background: rgba(0, 0, 0, 0.86);
            color: white;
            font-size: 12px;
            line-height: 1;
            font-weight: 500;
            letter-spacing: -0.01em;
        }

        .live-badge {
            position: absolute;
            right: 7px;
            bottom: 7px;
            min-width: 34px;
            height: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
            border-radius: 3px;
            background: #cc0000;
            color: white;
            font-size: 12px;
            line-height: 1;
            font-weight: 700;
            letter-spacing: 0.01em;
        }

        .playlist-badge {
            position: absolute;
            right: 7px;
            bottom: 7px;
            min-height: 22px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            padding: 0 7px;
            border-radius: 3px;
            background: rgba(0, 0, 0, 0.86);
            color: white;
            font-size: 12px;
            line-height: 1;
            font-weight: 600;
        }

        .details-row {
            display: grid;
            grid-template-columns: 48px minmax(0, 1fr) 32px;
            column-gap: 12px;
            align-items: start;
            min-height: 88px;
            padding: 12px 10px 12px 12px;
        }

        .avatar-link,
        .avatar-fallback {
            width: 40px;
            height: 40px;
            display: block;
            border-radius: 999px;
            overflow: hidden;
            background: #272727;
            text-decoration: none;
            color: white;
            flex: 0 0 auto;
        }

        .avatar-img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: cover;
            border-radius: 999px;
            background: #272727;
        }

        .avatar-letter {
            width: 100%;
            height: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: linear-gradient(135deg, #7b1fa2, #e91e63);
            color: white;
            font-size: 18px;
            font-weight: 700;
            line-height: 1;
        }

        .text-block {
            min-width: 0;
            padding-top: 0;
        }

        .title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            color: var(--text-color);
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            line-height: 1.25;
            letter-spacing: -0.01em;
        }

        .meta {
            margin-top: 5px;
            color: var(--secondary-text);
            font-size: 12px;
            font-weight: 400;
            line-height: 1.35;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .meta a {
            color: var(--secondary-text);
            text-decoration: none;
        }

        .menu-button {
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: flex-start;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            padding: 2px 0 0;
            background: transparent;
            color: #eeeeee;
            font-size: 19px;
            line-height: 1;
            cursor: pointer;
        }

        .menu-button:active {
            background: rgba(255, 255, 255, 0.08);
        }

        .channel-result {
            padding: 18px 14px;
            border-bottom: 1px solid var(--divider);
        }

        .channel-inner {
            display: grid;
            grid-template-columns: 76px minmax(0, 1fr) 32px;
            column-gap: 14px;
            align-items: center;
        }

        .channel-avatar-link,
        .channel-avatar-fallback {
            width: 76px;
            height: 76px;
            display: block;
            border-radius: 999px;
            overflow: hidden;
            background: #272727;
            color: white;
            text-decoration: none;
        }

        .channel-title {
            display: block;
            color: white;
            text-decoration: none;
            font-size: 16px;
            font-weight: 500;
            line-height: 1.25;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .channel-description {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-top: 5px;
            color: var(--secondary-text);
            font-size: 12px;
            line-height: 1.35;
        }

        .hashtag-result {
            display: grid;
            grid-template-columns: 48px minmax(0, 1fr) 32px;
            column-gap: 12px;
            align-items: center;
            padding: 14px 10px 14px 12px;
            border-bottom: 1px solid var(--divider);
            text-decoration: none;
            color: white;
        }

        .hashtag-icon {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #272727;
            color: white;
            font-size: 18px;
            font-weight: 700;
        }

        .hashtag-title {
            display: block;
            color: white;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            line-height: 1.25;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .empty-state {
            padding: 36px 18px;
            color: var(--secondary-text);
            text-align: center;
            font-size: 14px;
            line-height: 1.45;
        }

        .pagination {
            position: sticky;
            bottom: 0;
            z-index: 80;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            padding: 12px 12px calc(12px + env(safe-area-inset-bottom));
            margin-top: 8px;
            background: rgba(15, 15, 15, 0.94);
            border-top: 1px solid var(--divider);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
        }

        .pagination a,
        .pagination .disabled-page-button {
            min-width: 88px;
            min-height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 0 16px;
            border-radius: 999px;
            background: #222222;
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: white;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            user-select: none;
        }

        .pagination a:active {
            transform: scale(0.97);
            background: #2a2a2a;
        }

        .pagination .disabled-page-button {
            opacity: 0.35;
            pointer-events: none;
        }

        .page-count {
            min-width: 74px;
            min-height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 12px;
            border-radius: 999px;
            background: #181818;
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: var(--secondary-text);
            font-size: 13px;
            font-weight: 600;
            white-space: nowrap;
        }

        .loading {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.78);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .spinner {
            width: 42px;
            height: 42px;
            border: 4px solid #333333;
            border-top: 4px solid #ffffff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        @media (min-width: 521px) {
            .feed {
                border-left: 1px solid #202020;
                border-right: 1px solid #202020;
            }
        }
    </style>
</head>
<body>
    <header class="app-header">
        <div class="nav-wrap">
            <form action="/app" class="search-container" role="search">
                <i class="fa-light fa-search search-icon-inline" aria-hidden="true"></i>
                <input type="text" name="mobilesearch" value="<%= searchValue %>" placeholder="Search" autocomplete="off">
                <button type="submit" class="search-btn" aria-label="Search">
                    <i class="fa-light fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </header>

    <main class="feed">
        <% if (results.length) { %>
            <div class="top-page-counter">Page <%= currentPage %></div>

            <% results.forEach(item => { %>
                <% if (item && item.type === "video") { %>
                    <%
                        const videoId = item.videoId || "";
                        const href = resultUrl(item);
                        const thumbnail = pickBestThumbnail(item.videoThumbnails, videoId);
                        const avatar = pickBestAvatar(item.authorThumbnails);
                        const duration = formatDuration(item.lengthSeconds);
                        const authorHref = channelUrl(item);
                        const metaText = metaParts([
                            item.author || "",
                            formatViews(item.viewCount),
                            item.publishedText || ""
                        ]);
                    %>

                    <article class="result-card video-result">
                        <a href="<%= href %>" class="thumbnail-link" aria-label="<%= item.title || 'Video' %>">
                            <% if (thumbnail) { %>
                                <img class="thumbnail-img" src="<%= thumbnail %>" alt="" loading="lazy">
                            <% } %>

                            <% if (item.liveNow) { %>
                                <span class="live-badge">LIVE</span>
                            <% } else if (duration) { %>
                                <span class="duration-badge"><%= duration %></span>
                            <% } %>
                        </a>

                        <div class="details-row">
                            <% if (authorHref) { %>
                                <a class="avatar-link" href="<%= authorHref %>" aria-label="<%= item.author || 'Channel' %>">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </a>
                            <% } else { %>
                                <div class="avatar-fallback" aria-hidden="true">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="text-block">
                                <a href="<%= href %>" class="title"><%= item.title || "Untitled video" %></a>
                                <div class="meta">
                                    <% if (authorHref && item.author) { %>
                                        <a href="<%= authorHref %>"><%= item.author %></a><%= metaParts([formatViews(item.viewCount), item.publishedText || ""]) ? " • " + metaParts([formatViews(item.viewCount), item.publishedText || ""]) : "" %>
                                    <% } else { %>
                                        <%= metaText %>
                                    <% } %>
                                </div>
                            </div>

                            <button class="menu-button" type="button" aria-label="More options">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                    </article>
                <% } else if (item && item.type === "playlist") { %>
                    <%
                        const href = resultUrl(item);
                        const firstVideo = Array.isArray(item.videos) && item.videos[0] ? item.videos[0] : null;
                        const thumbnail = item.playlistThumbnail || (firstVideo ? pickBestThumbnail(firstVideo.videoThumbnails, firstVideo.videoId) : "");
                        const avatar = pickBestAvatar(item.authorThumbnails);
                        const authorHref = channelUrl(item);
                        const metaText = metaParts([
                            item.author || "",
                            Number.isFinite(Number(item.videoCount)) ? String(item.videoCount) + " videos" : ""
                        ]);
                    %>

                    <article class="result-card video-result">
                        <a href="<%= href %>" class="thumbnail-link" aria-label="<%= item.title || 'Playlist' %>">
                            <% if (thumbnail) { %>
                                <img class="thumbnail-img" src="<%= thumbnail %>" alt="" loading="lazy">
                            <% } %>

                            <span class="playlist-badge">
                                <i class="fa-light fa-list"></i>
                                <%= Number.isFinite(Number(item.videoCount)) ? item.videoCount : "Playlist" %>
                            </span>
                        </a>

                        <div class="details-row">
                            <% if (authorHref) { %>
                                <a class="avatar-link" href="<%= authorHref %>" aria-label="<%= item.author || 'Channel' %>">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </a>
                            <% } else { %>
                                <div class="avatar-fallback" aria-hidden="true">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="text-block">
                                <a href="<%= href %>" class="title"><%= item.title || "Untitled playlist" %></a>
                                <div class="meta">
                                    <% if (authorHref && item.author) { %>
                                        <a href="<%= authorHref %>"><%= item.author %></a><%= Number.isFinite(Number(item.videoCount)) ? " • " + item.videoCount + " videos" : "" %>
                                    <% } else { %>
                                        <%= metaText %>
                                    <% } %>
                                </div>
                            </div>

                            <button class="menu-button" type="button" aria-label="More options">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                    </article>
                <% } else if (item && item.type === "channel") { %>
                    <%
                        const href = resultUrl(item);
                        const avatar = pickBestAvatar(item.authorThumbnails);
                        const metaText = metaParts([
                            Number.isFinite(Number(item.subCount)) ? formatCompactNumber(item.subCount) + " subscribers" : "",
                            Number.isFinite(Number(item.videoCount)) ? formatCompactNumber(item.videoCount) + " videos" : ""
                        ]);
                    %>

                    <article class="result-card channel-result">
                        <div class="channel-inner">
                            <a class="channel-avatar-link" href="<%= href %>" aria-label="<%= item.author || 'Channel' %>">
                                <% if (avatar) { %>
                                    <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                <% } else { %>
                                    <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                <% } %>
                            </a>

                            <div class="text-block">
                                <a href="<%= href %>" class="channel-title"><%= item.author || "Channel" %></a>
                                <div class="meta"><%= metaText %></div>
                                <% if (item.description) { %>
                                    <div class="channel-description"><%= item.description %></div>
                                <% } %>
                            </div>

                            <button class="menu-button" type="button" aria-label="More options">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                    </article>
                <% } else if (item && item.type === "hashtag") { %>
                    <%
                        const href = resultUrl(item);
                        const metaText = metaParts([
                            Number.isFinite(Number(item.videoCount)) ? formatCompactNumber(item.videoCount) + " videos" : "",
                            Number.isFinite(Number(item.channelCount)) ? formatCompactNumber(item.channelCount) + " channels" : ""
                        ]);
                    %>

                    <article class="result-card">
                        <a class="hashtag-result" href="<%= href %>">
                            <span class="hashtag-icon">#</span>

                            <span class="text-block">
                                <span class="hashtag-title"><%= item.title || "Hashtag" %></span>
                                <span class="meta"><%= metaText %></span>
                            </span>

                            <span class="menu-button" aria-hidden="true">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </span>
                        </a>
                    </article>
                <% } %>
            <% }) %>

            <nav class="pagination" aria-label="Search pages">
                <% if (currentPage > 1) { %>
                    <a href="<%= previousPageUrl %>" rel="prev" aria-label="Previous page">
                        <i class="fa-light fa-arrow-left"></i>
                        Prev
                    </a>
                <% } else { %>
                    <span class="disabled-page-button" aria-disabled="true">
                        <i class="fa-light fa-arrow-left"></i>
                        Prev
                    </span>
                <% } %>

                <span class="page-count" aria-current="page">Page <%= currentPage %></span>

                <a href="<%= nextPageUrl %>" rel="next" aria-label="Next page">
                    Next
                    <i class="fa-light fa-arrow-right"></i>
                </a>
            </nav>
        <% } else { %>
            <div class="empty-state">
                No results found.
            </div>
        <% } %>
    </main>

    <script>
        function removeLoadingOverlay() {
            document.body.classList.remove("no-scroll");

            const loadingOverlays = document.querySelectorAll(".loading");
            loadingOverlays.forEach(loadingOverlay => loadingOverlay.remove());
        }

        function showLoadingOverlay() {
            removeLoadingOverlay();

            const loading = document.createElement("div");
            loading.className = "loading";
            loading.innerHTML = '<div class="spinner"></div>';

            document.body.classList.add("no-scroll");
            document.body.appendChild(loading);
        }

        const links = document.querySelectorAll("a");

        links.forEach(link => {
            link.addEventListener("click", () => {
                const href = link.getAttribute("href");

                if (!href || href.startsWith("#") || href.startsWith("javascript:")) return;
                if (link.target && link.target !== "_self") return;
                if (link.hasAttribute("download")) return;

                showLoadingOverlay();
            });
        });

        window.addEventListener("pageshow", removeLoadingOverlay);
        window.addEventListener("pagehide", removeLoadingOverlay);
        window.addEventListener("popstate", removeLoadingOverlay);

        document.addEventListener("visibilitychange", () => {
            if (!document.hidden) removeLoadingOverlay();
        });

        if ("scrollRestoration" in history) {
            history.scrollRestoration = "auto";
        }

        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.getRegistrations().then(regs => {
                for (const reg of regs) reg.unregister();
            });
        }
    </script>
</body>
</html>