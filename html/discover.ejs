<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Poke Mobile Search</title>
    
    <% if (!mobilesearch && !tab) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">
    <link href="https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #0f0f0f;
            --text-color: #ffffff;
            --secondary-text: #aaaaaa;
            --input-bg: #1c1c1c;  
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        header {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            background: #0f0f0f;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo-text { 
            font-weight: bold; 
            font-size: 18px; 
            margin-right: 15px; 
            text-decoration: none; 
            color: white;
            font-family: sans-serif;
        }

        .search-container {
            flex-grow: 1;
            display: flex;
            background: var(--input-bg);
            border-radius: 999px; /* Pill shape */
            padding: 8px 20px;
            height: 40px;
            align-items: center;
            border: 1px solid #333;
        }

        input[name="mobilesearch"] {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            font-size: 15px;
            padding: 0;
        }

        button.search-btn {
            background: transparent;
            border: none;
            color: #aaa;
            cursor: pointer;
            padding-left: 10px;
            font-size: 16px;
        }

        .video-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
            padding: 16px;
        }

        .video-card {
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: white;
        }

        .thumbnail {
            width: 100%;
            aspect-ratio: 16 / 9;
            background-size: cover;
            background-position: center;
            border-radius: 12px;
            margin-bottom: 8px;
        }

        .video-info { padding: 0 4px; }

        .video-info .title {
            font-size: 15px;
            font-weight: 500;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.4;
            margin-bottom: 4px;
        }

        .video-info .author a {
            font-size: 13px;
            color: var(--secondary-text);
            text-decoration: none;
        }

        .pagination {
            display: flex;
            justify-content: center;
            padding: 20px;
            gap: 15px;
            margin-bottom: 20px;
        }

        .pagination a {
            color: white;
            text-decoration: none;
            background: #222;
            padding: 10px 24px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 14px;
        }

        .loading {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 9999;
            display: flex; justify-content: center; align-items: center;
        }
        .spinner {
            border: 4px solid #333; border-top: 4px solid #fff;
            border-radius: 50%; width: 40px; height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo-text">Poke</a>
        <form action="/app" class="search-container">
            <input type="text" name="mobilesearch" value="<%= typeof mobilesearch !== 'undefined' ? mobilesearch : '' %>" placeholder="Search...">
            <button type="submit" class="search-btn"><i class="fa-light fa-search"></i></button>
        </form>
    </header>

    <main class="video-grid">
        <% if (typeof j !== 'undefined' && j && Array.isArray(j.results)) { %>
            <% j.results.forEach(x => { %>
                <a href="/watch?v=<%- x.videoId %>" class="video-card">
                    <div class="thumbnail" style="background-image: url('https://i.ytimg.com/vi/<%= x.videoId %>/hqdefault.jpg');"></div>
                    <div class="video-info">
                        <div class="title"><%- x.title %></div>
                        <div class="author">
                            <a href="/channel?id=<%- x.authorId %>"><%- x.author %></a>
                        </div>
                    </div>
                </a>
            <% }) %>

            <div class="pagination">
                <% 
                   let currentPage = (typeof continuation !== 'undefined' && continuation) ? Number(continuation) : 1; 
                %>
                
                <% if (currentPage > 1) { %>
                    <a href="/app?mobilesearch=<%= encodeURIComponent(typeof mobilesearch !== 'undefined' ? mobilesearch : '') %>&continuation=<%= currentPage - 1 %>">Prev</a>
                <% } %>
                
                <a href="/app?mobilesearch=<%= encodeURIComponent(typeof mobilesearch !== 'undefined' ? mobilesearch : '') %>&continuation=<%= currentPage + 1 %>">Next</a>
            </div>
        <% } else { %>
            <div style="text-align: center; margin-top: 50px; color: #888;">
                <p>Search for videos to get started.</p>
            </div>
        <% } %>
    </main>

    <script>
        const links = document.querySelectorAll('a');
        links.forEach(link => {
            link.addEventListener('click', e => {
                const loading = document.createElement('div');
                loading.className = 'loading';
                loading.innerHTML = '<div class="spinner"></div>';
                document.body.appendChild(loading);
            });
        });

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(regs => {
                for (let reg of regs) reg.unregister();
            });
        }
    </script>
</body>
</html>