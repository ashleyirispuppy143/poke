<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const results = typeof j !== "undefined" && j && Array.isArray(j.results) ? j.results : [];
        const searchValue = typeof mobilesearch !== "undefined" ? mobilesearch : "";
        const hasMobileSearch = typeof mobilesearch !== "undefined" && Boolean(mobilesearch);
        const hasTab = typeof tab !== "undefined" && Boolean(tab);

        let currentPage = typeof continuation !== "undefined" && continuation ? Number(continuation) : 1;
        if (!Number.isFinite(currentPage) || currentPage < 1) currentPage = 1;

        const previousPage = currentPage > 1 ? currentPage - 1 : 1;
        const nextPage = currentPage + 1;

        function pageUrl(page) {
            return "/app?mobilesearch=" + encodeURIComponent(searchValue) + "&continuation=" + encodeURIComponent(page);
        }

        function videoHref(item) {
            return item && item.videoId ? "/watch?v=" + encodeURIComponent(item.videoId) : "#";
        }

        function playlistHref(item) {
            return item && item.playlistId ? "/playlist?list=" + encodeURIComponent(item.playlistId) : "#";
        }

        function channelHref(item) {
            if (!item) return "#";
            if (item.authorUrl) return item.authorUrl;
            if (item.authorId) return "/channel?id=" + encodeURIComponent(item.authorId);
            return "#";
        }

        function hashtagHref(item) {
            return item && item.url ? item.url : "#";
        }

        function videoThumbnailUrl(videoId) {
            if (!videoId) return "";
            return "https://i.ytimg.com/vi/" + encodeURIComponent(videoId) + "/hqdefault.jpg";
        }

        function playlistThumbnailUrl(item) {
            if (item && Array.isArray(item.videos) && item.videos[0] && item.videos[0].videoId) {
                return videoThumbnailUrl(item.videos[0].videoId);
            }

            if (item && item.playlistThumbnail) return item.playlistThumbnail;
            return "";
        }

        function avatarUrl(item) {
            if (!item || !Array.isArray(item.authorThumbnails)) return "";
            if (item.authorThumbnails[1] && item.authorThumbnails[1].url) return item.authorThumbnails[1].url;
            if (item.authorThumbnails[0] && item.authorThumbnails[0].url) return item.authorThumbnails[0].url;
            return "";
        }

        function authorInitial(author) {
            if (!author || typeof author !== "string") return "?";
            return author.trim().charAt(0).toUpperCase() || "?";
        }

        function formatDuration(seconds) {
            const value = Number(seconds);
            if (!Number.isFinite(value) || value <= 0) return "";

            const total = Math.floor(value);
            const hours = Math.floor(total / 3600);
            const minutes = Math.floor((total % 3600) / 60);
            const secs = total % 60;

            if (hours > 0) {
                return String(hours) + ":" + String(minutes).padStart(2, "0") + ":" + String(secs).padStart(2, "0");
            }

            return String(minutes) + ":" + String(secs).padStart(2, "0");
        }

        function formatCompactNumber(value) {
            const number = Number(value);
            if (!Number.isFinite(number) || number < 0) return "";

            if (number < 1000) return String(number);

            return new Intl.NumberFormat("en", {
                notation: "compact",
                maximumFractionDigits: number >= 1000000 ? 1 : 0
            }).format(number).replace("K", "k");
        }

        function formatViews(value) {
            const formatted = formatCompactNumber(value);
            return formatted ? formatted + " views" : "";
        }

        function formatCount(value, label) {
            const formatted = formatCompactNumber(value);
            return formatted ? formatted + " " + label : "";
        }

        function joinMeta(parts) {
            return parts.filter(Boolean).join(" • ");
        }
    %>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Search</title>

    <% if (!hasMobileSearch && !hasTab) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">

    <style>
        @import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

        :root {
            --bg: #0f0f0f;
            --panel: #0f0f0f;
            --search-bg: #212121;
            --search-border: #303030;
            --search-focus: #3f3f3f;
            --text: #f1f1f1;
            --text-soft: #aaa;
            --text-muted: #717171;
            --line: #272727;
            --chip: #272727;
            --chip-hover: #343434;
            --danger: #ff0033;
            --shadow: rgba(0, 0, 0, 0.45);
        }

        * {
            box-sizing: border-box;
        }

        html {
            background: var(--bg);
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, "Roboto", "Segoe UI", Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
            overscroll-behavior-y: contain;
        }

        body.no-scroll {
            overflow: hidden;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button,
        input {
            font: inherit;
        }

        .app-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(15, 15, 15, 0.96);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
        }

        .nav-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            min-height: 58px;
            padding: 9px 10px;
            padding-top: max(9px, env(safe-area-inset-top));
        }

        .search-container {
            flex: 1 1 auto;
            min-width: 0;
            height: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--search-bg);
            border: 1px solid var(--search-border);
            border-radius: 999px;
            padding: 0 8px 0 14px;
            transition: background 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
        }

        .search-container:focus-within {
            background: #262626;
            border-color: var(--search-focus);
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.045);
        }

        .search-icon-inline {
            flex: 0 0 auto;
            color: var(--text-soft);
            font-size: 15px;
        }

        input[name="mobilesearch"] {
            appearance: none;
            width: 100%;
            min-width: 0;
            border: 0;
            outline: 0;
            background: transparent;
            color: var(--text);
            font-size: 16px;
            line-height: 1;
            padding: 0;
        }

        input[name="mobilesearch"]::placeholder {
            color: var(--text-muted);
            opacity: 1;
        }

        .search-btn {
            width: 32px;
            height: 32px;
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            padding: 0;
            background: transparent;
            color: var(--text-soft);
            cursor: pointer;
            font-size: 17px;
        }

        .search-btn:active {
            transform: scale(0.94);
            color: var(--text);
        }

        .feed {
            width: 100%;
            max-width: 520px;
            margin: 0 auto;
            padding: 8px 0 calc(82px + env(safe-area-inset-bottom));
            background: var(--bg);
        }

        .result-card {
            width: 100%;
            background: var(--panel);
            color: var(--text);
            overflow: hidden;
        }

        .result-card + .result-card {
            margin-top: 5px;
        }

        .video-card,
        .playlist-card {
            padding: 0 0 7px;
        }

        .thumbnail-shell {
            width: 100%;
            padding: 0 10px;
        }

        .thumbnail-link {
            position: relative;
            display: block;
            width: 100%;
            aspect-ratio: 16 / 9;
            overflow: hidden;
            border-radius: 12px;
            background: #181818;
        }

        .thumbnail-img {
            display: block;
            width: 100%;
            height: 100%;
            border-radius: 12px;
            object-fit: cover;
            background: #181818;
        }

        .thumbnail-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: #181818;
            color: var(--text-muted);
            font-size: 26px;
        }

        .duration-badge,
        .live-badge,
        .playlist-badge {
            position: absolute;
            right: 6px;
            bottom: 6px;
            min-height: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            color: #fff;
            font-size: 12px;
            line-height: 1;
            font-weight: 600;
        }

        .duration-badge {
            min-width: 34px;
            padding: 0 5px;
            background: rgba(0, 0, 0, 0.86);
        }

        .live-badge {
            padding: 0 7px;
            background: #cc0000;
            letter-spacing: 0.01em;
        }

        .playlist-badge {
            gap: 5px;
            padding: 0 7px;
            background: rgba(0, 0, 0, 0.86);
        }

        .details-row {
            display: grid;
            grid-template-columns: 40px minmax(0, 1fr) 32px;
            column-gap: 10px;
            align-items: start;
            padding: 9px 10px 0;
        }

        .avatar-link,
        .avatar-fallback {
            width: 36px;
            height: 36px;
            display: block;
            overflow: hidden;
            border-radius: 999px;
            background: #272727;
        }

        .avatar-img {
            display: block;
            width: 100%;
            height: 100%;
            border-radius: 999px;
            object-fit: cover;
            background: #272727;
        }

        .avatar-letter {
            width: 100%;
            height: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: linear-gradient(135deg, #7b1fa2, #e91e63);
            color: #fff;
            font-size: 16px;
            line-height: 1;
            font-weight: 700;
        }

        .text-block {
            min-width: 0;
        }

        .title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            color: var(--text);
            font-size: 15px;
            font-weight: 500;
            line-height: 1.26;
            letter-spacing: -0.01em;
        }

        .meta {
            margin-top: 4px;
            color: var(--text-soft);
            font-size: 12px;
            font-weight: 400;
            line-height: 1.35;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .meta a {
            color: var(--text-soft);
        }

        .menu-button {
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: flex-start;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            padding: 2px 0 0;
            background: transparent;
            color: #e6e6e6;
            cursor: pointer;
            font-size: 18px;
            line-height: 1;
        }

        .menu-button:active {
            background: rgba(255, 255, 255, 0.08);
        }

        .channel-card {
            padding: 11px 10px;
        }

        .channel-inner {
            display: grid;
            grid-template-columns: 72px minmax(0, 1fr) 32px;
            column-gap: 13px;
            align-items: center;
        }

        .channel-avatar-link,
        .channel-avatar-fallback {
            width: 72px;
            height: 72px;
            display: block;
            overflow: hidden;
            border-radius: 999px;
            background: #272727;
        }

        .channel-title {
            display: block;
            overflow: hidden;
            color: var(--text);
            font-size: 16px;
            font-weight: 500;
            line-height: 1.25;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .channel-description {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-top: 5px;
            color: var(--text-soft);
            font-size: 12px;
            line-height: 1.35;
        }

        .hashtag-card {
            padding: 8px 10px;
        }

        .hashtag-result {
            display: grid;
            grid-template-columns: 40px minmax(0, 1fr) 32px;
            column-gap: 10px;
            align-items: center;
            min-height: 54px;
        }

        .hashtag-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #272727;
            color: var(--text);
            font-size: 18px;
            font-weight: 700;
        }

        .hashtag-title {
            display: block;
            overflow: hidden;
            color: var(--text);
            font-size: 15px;
            font-weight: 500;
            line-height: 1.25;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .empty-state {
            padding: 42px 18px;
            color: var(--text-soft);
            text-align: center;
            font-size: 14px;
            line-height: 1.45;
        }

        .pagination {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 90;
            display: flex;
            justify-content: center;
            padding: 0 10px;
            pointer-events: none;
        }

        .pagination-inner {
            width: 100%;
            max-width: 520px;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 9px;
            padding: 10px 10px calc(10px + env(safe-area-inset-bottom));
            background: rgba(15, 15, 15, 0.96);
            border-top: 1px solid rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            pointer-events: auto;
        }

        .page-button,
        .disabled-page-button,
        .page-count {
            min-height: 39px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            user-select: none;
            white-space: nowrap;
        }

        .page-button,
        .disabled-page-button {
            gap: 7px;
            padding: 0 15px;
            background: var(--chip);
            color: var(--text);
            font-size: 14px;
            font-weight: 500;
        }

        .page-button:active {
            transform: scale(0.97);
            background: var(--chip-hover);
        }

        .disabled-page-button {
            opacity: 0.35;
            pointer-events: none;
        }

        .page-count {
            min-width: 74px;
            padding: 0 12px;
            background: #181818;
            color: var(--text-soft);
            font-size: 13px;
            font-weight: 600;
        }

        .loading {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.78);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .spinner {
            width: 42px;
            height: 42px;
            border: 4px solid #333;
            border-top-color: #fff;
            border-radius: 999px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        @media (min-width: 521px) {
            .feed {
                border-left: 1px solid rgba(255, 255, 255, 0.06);
                border-right: 1px solid rgba(255, 255, 255, 0.06);
            }

            .pagination-inner {
                border-left: 1px solid rgba(255, 255, 255, 0.06);
                border-right: 1px solid rgba(255, 255, 255, 0.06);
            }
        }
    </style>
</head>
<body>
    <header class="app-header">
        <div class="nav-wrap">
            <form action="/app" class="search-container" role="search">
                <i class="fa-light fa-search search-icon-inline" aria-hidden="true"></i>
                <input type="text" name="mobilesearch" value="<%= searchValue %>" placeholder="Search" autocomplete="off">
                <button type="submit" class="search-btn" aria-label="Search">
                    <i class="fa-light fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </header>

    <main class="feed">
        <% if (results.length) { %>
            <% results.forEach(item => { %>
                <% if (item && item.type === "video") { %>
                    <%
                        const href = videoHref(item);
                        const authorHref = channelHref(item);
                        const thumb = videoThumbnailUrl(item.videoId);
                        const avatar = avatarUrl(item);
                        const duration = formatDuration(item.lengthSeconds);
                        const meta = joinMeta([
                            item.author || "",
                            formatViews(item.viewCount)
                        ]);
                    %>

                    <article class="result-card video-card">
                        <div class="thumbnail-shell">
                            <a href="<%= href %>" class="thumbnail-link" aria-label="<%= item.title || 'Video' %>">
                                <% if (thumb) { %>
                                    <img class="thumbnail-img" src="<%= thumb %>" alt="" loading="lazy">
                                <% } else { %>
                                    <div class="thumbnail-placeholder">
                                        <i class="fa-light fa-video"></i>
                                    </div>
                                <% } %>

                                <% if (item.liveNow) { %>
                                    <span class="live-badge">LIVE</span>
                                <% } else if (duration) { %>
                                    <span class="duration-badge"><%= duration %></span>
                                <% } %>
                            </a>
                        </div>

                        <div class="details-row">
                            <% if (authorHref && authorHref !== "#") { %>
                                <a class="avatar-link" href="<%= authorHref %>" aria-label="<%= item.author || 'Channel' %>">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </a>
                            <% } else { %>
                                <div class="avatar-fallback" aria-hidden="true">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="text-block">
                                <a href="<%= href %>" class="title"><%= item.title || "Untitled video" %></a>
                                <%# Upload date hidden for now: item.publishedText %>

                                <% if (meta) { %>
                                    <div class="meta">
                                        <% if (authorHref && authorHref !== "#" && item.author) { %>
                                            <a href="<%= authorHref %>"><%= item.author %></a><%= formatViews(item.viewCount) ? " • " + formatViews(item.viewCount) : "" %>
                                        <% } else { %>
                                            <%= meta %>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>

                            <button class="menu-button" type="button" aria-label="More options">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                    </article>
                <% } else if (item && item.type === "playlist") { %>
                    <%
                        const href = playlistHref(item);
                        const authorHref = channelHref(item);
                        const thumb = playlistThumbnailUrl(item);
                        const avatar = avatarUrl(item);
                        const meta = joinMeta([
                            item.author || "",
                            Number.isFinite(Number(item.videoCount)) ? item.videoCount + " videos" : ""
                        ]);
                    %>

                    <article class="result-card playlist-card">
                        <div class="thumbnail-shell">
                            <a href="<%= href %>" class="thumbnail-link" aria-label="<%= item.title || 'Playlist' %>">
                                <% if (thumb) { %>
                                    <img class="thumbnail-img" src="<%= thumb %>" alt="" loading="lazy">
                                <% } else { %>
                                    <div class="thumbnail-placeholder">
                                        <i class="fa-light fa-list"></i>
                                    </div>
                                <% } %>

                                <span class="playlist-badge">
                                    <i class="fa-light fa-list"></i>
                                    <%= Number.isFinite(Number(item.videoCount)) ? item.videoCount : "Playlist" %>
                                </span>
                            </a>
                        </div>

                        <div class="details-row">
                            <% if (authorHref && authorHref !== "#") { %>
                                <a class="avatar-link" href="<%= authorHref %>" aria-label="<%= item.author || 'Channel' %>">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </a>
                            <% } else { %>
                                <div class="avatar-fallback" aria-hidden="true">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="text-block">
                                <a href="<%= href %>" class="title"><%= item.title || "Untitled playlist" %></a>

                                <% if (meta) { %>
                                    <div class="meta">
                                        <% if (authorHref && authorHref !== "#" && item.author) { %>
                                            <a href="<%= authorHref %>"><%= item.author %></a><%= Number.isFinite(Number(item.videoCount)) ? " • " + item.videoCount + " videos" : "" %>
                                        <% } else { %>
                                            <%= meta %>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>

                            <button class="menu-button" type="button" aria-label="More options">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                    </article>
                <% } else if (item && item.type === "channel") { %>
                    <%
                        const href = channelHref(item);
                        const avatar = avatarUrl(item);
                        const meta = joinMeta([
                            formatCount(item.subCount, "subscribers"),
                            formatCount(item.videoCount, "videos")
                        ]);
                    %>

                    <article class="result-card channel-card">
                        <div class="channel-inner">
                            <% if (href && href !== "#") { %>
                                <a class="channel-avatar-link" href="<%= href %>" aria-label="<%= item.author || 'Channel' %>">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </a>
                            <% } else { %>
                                <div class="channel-avatar-fallback" aria-hidden="true">
                                    <% if (avatar) { %>
                                        <img class="avatar-img" src="<%= avatar %>" alt="" loading="lazy">
                                    <% } else { %>
                                        <span class="avatar-letter"><%= authorInitial(item.author) %></span>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="text-block">
                                <a href="<%= href %>" class="channel-title"><%= item.author || "Channel" %></a>

                                <% if (meta) { %>
                                    <div class="meta"><%= meta %></div>
                                <% } %>

                                <% if (item.description) { %>
                                    <div class="channel-description"><%= item.description %></div>
                                <% } %>
                            </div>

                            <button class="menu-button" type="button" aria-label="More options">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                    </article>
                <% } else if (item && item.type === "hashtag") { %>
                    <%
                        const href = hashtagHref(item);
                        const meta = joinMeta([
                            formatCount(item.videoCount, "videos"),
                            formatCount(item.channelCount, "channels")
                        ]);
                    %>

                    <article class="result-card hashtag-card">
                        <a class="hashtag-result" href="<%= href %>">
                            <span class="hashtag-icon">#</span>

                            <span class="text-block">
                                <span class="hashtag-title"><%= item.title || "Hashtag" %></span>

                                <% if (meta) { %>
                                    <span class="meta"><%= meta %></span>
                                <% } %>
                            </span>

                            <span class="menu-button" aria-hidden="true">
                                <i class="fa-regular fa-ellipsis-vertical"></i>
                            </span>
                        </a>
                    </article>
                <% } %>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                No results found.
            </div>
        <% } %>
    </main>

    <% if (results.length) { %>
        <nav class="pagination" aria-label="Search pages">
            <div class="pagination-inner">
                <% if (currentPage > 1) { %>
                    <a class="page-button" href="<%= pageUrl(previousPage) %>" rel="prev" aria-label="Previous page">
                        <i class="fa-light fa-arrow-left"></i>
                        Prev
                    </a>
                <% } else { %>
                    <span class="disabled-page-button" aria-disabled="true">
                        <i class="fa-light fa-arrow-left"></i>
                        Prev
                    </span>
                <% } %>

                <span class="page-count" aria-current="page">Page <%= currentPage %></span>

                <a class="page-button" href="<%= pageUrl(nextPage) %>" rel="next" aria-label="Next page">
                    Next
                    <i class="fa-light fa-arrow-right"></i>
                </a>
            </div>
        </nav>
    <% } %>

    <script>
        function removeLoadingOverlay() {
            document.body.classList.remove("no-scroll");

            document.querySelectorAll(".loading").forEach(loadingOverlay => {
                loadingOverlay.remove();
            });
        }

        function showLoadingOverlay() {
            removeLoadingOverlay();

            const loading = document.createElement("div");
            loading.className = "loading";
            loading.innerHTML = '<div class="spinner"></div>';

            document.body.classList.add("no-scroll");
            document.body.appendChild(loading);
        }

        document.addEventListener("click", event => {
            const link = event.target.closest("a");
            if (!link) return;

            const href = link.getAttribute("href");
            if (!href || href.startsWith("#") || href.startsWith("javascript:")) return;
            if (link.target && link.target !== "_self") return;
            if (link.hasAttribute("download")) return;
            if (event.defaultPrevented) return;
            if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

            showLoadingOverlay();
        });

        document.querySelectorAll("form").forEach(form => {
            form.addEventListener("submit", () => {
                showLoadingOverlay();
            });
        });

        window.addEventListener("pageshow", removeLoadingOverlay);
        window.addEventListener("pagehide", removeLoadingOverlay);
        window.addEventListener("popstate", removeLoadingOverlay);

        document.addEventListener("visibilitychange", () => {
            if (!document.hidden) removeLoadingOverlay();
        });

        if ("scrollRestoration" in history) {
            history.scrollRestoration = "auto";
        }

        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.getRegistrations().then(registrations => {
                registrations.forEach(registration => {
                    registration.unregister();
                });
            });
        }
    </script>
</body>
</html>