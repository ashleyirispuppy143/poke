<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Poke Mobile Search</title>

    <% if (!mobilesearch && !tab) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">

    <style>
        @import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

        :root {
            --bg-color: #0f0f0f;
            --header-bg: rgba(15, 15, 15, 0.96);
            --text-color: #ffffff;
            --secondary-text: #aaaaaa;
            --muted-text: #777777;
            --input-bg: #202020;
            --input-border: #343434;
            --input-focus: #4a4a4a;
            --card-bg: #101010;
            --card-border: #202020;
            --divider: #242424;
            --button-bg: #222222;
            --button-bg-active: #303030;
            --shadow: rgba(0, 0, 0, 0.38);
        }

        * {
            box-sizing: border-box;
        }

        html {
            background: var(--bg-color);
            color-scheme: dark;
        }

        body {
            background: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            -webkit-tap-highlight-color: transparent;
        }

        body.no-scroll {
            overflow: hidden;
        }

        a {
            color: inherit;
        }

        .app-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--header-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--divider);
            box-shadow: 0 6px 18px var(--shadow);
        }

        .nav-wrap {
            display: flex;
            align-items: center;
            min-height: 76px;
            padding: 12px 14px;
            padding-top: max(12px, env(safe-area-inset-top));
            max-width: 720px;
            margin: 0 auto;
        }

        .search-container {
            width: 100%;
            min-width: 0;
            height: 52px;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            border-radius: 999px;
            padding: 0 8px 0 18px;
            transition: border-color 150ms ease, background 150ms ease, box-shadow 150ms ease;
        }

        .search-container:focus-within {
            background: #242424;
            border-color: var(--input-focus);
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.045);
        }

        .search-icon-inline {
            flex: 0 0 auto;
            color: var(--secondary-text);
            font-size: 16px;
        }

        input[name="mobilesearch"] {
            appearance: none;
            background: transparent;
            border: none;
            color: var(--text-color);
            width: 100%;
            min-width: 0;
            outline: none;
            font-size: 18px;
            line-height: 1;
            padding: 0;
            font-weight: 400;
        }

        input[name="mobilesearch"]::placeholder {
            color: var(--muted-text);
            opacity: 1;
        }

        button.search-btn {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            cursor: pointer;
            border-radius: 999px;
            padding: 0;
            font-size: 15px;
            transition: background 150ms ease, transform 150ms ease;
        }

        button.search-btn:active {
            transform: scale(0.94);
            background: rgba(255, 255, 255, 0.14);
        }

        .content-wrap {
            max-width: 720px;
            margin: 0 auto;
            padding: 18px 14px 104px;
        }

        .results-list {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .result-card {
            display: block;
            text-decoration: none;
            color: var(--text-color);
            background: transparent;
            border-radius: 12px;
            overflow: hidden;
        }

        .thumb-link {
            display: block;
            text-decoration: none;
            color: inherit;
            border-radius: 12px;
            overflow: hidden;
            background: #181818;
        }

        .thumb {
            width: 100%;
            aspect-ratio: 16 / 9;
            display: block;
            background-color: #181818;
            background-size: cover;
            background-position: center;
            border-radius: 12px;
            transition: transform 150ms ease, filter 150ms ease;
        }

        .thumb-link:active .thumb {
            transform: scale(0.985);
            filter: brightness(0.82);
        }

        .result-body {
            display: grid;
            grid-template-columns: 44px minmax(0, 1fr) 32px;
            gap: 12px;
            padding: 10px 2px 0;
            align-items: start;
        }

        .avatar-link,
        .avatar-fallback {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            overflow: hidden;
            text-decoration: none;
            background: radial-gradient(circle at 30% 30%, #ff4fd8, #7b2cff 58%, #161616 100%);
            color: #ffffff;
            font-size: 16px;
            font-weight: 400;
            text-transform: uppercase;
        }

        .avatar-link img,
        .avatar-fallback img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .result-text {
            min-width: 0;
        }

        .result-title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            color: var(--text-color);
            text-decoration: none;
            font-size: 16px;
            line-height: 1.28;
            font-weight: 400;
            letter-spacing: -0.01em;
        }

        .result-title:active {
            color: #d6d6d6;
        }

        .meta {
            display: flex;
            align-items: center;
            gap: 5px;
            min-width: 0;
            margin-top: 5px;
            color: var(--secondary-text);
            font-size: 13px;
            line-height: 1.35;
            font-weight: 400;
        }

        .meta a {
            color: var(--secondary-text);
            text-decoration: none;
            min-width: 0;
        }

        .meta a:active {
            color: var(--text-color);
        }

        .meta .author-name,
        .meta .meta-text {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .meta-dot {
            flex: 0 0 auto;
            color: var(--muted-text);
        }

        .menu-btn {
            width: 30px;
            height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            justify-self: end;
            border: none;
            border-radius: 999px;
            background: transparent;
            color: #d8d8d8;
            padding: 0;
            font-size: 20px;
        }

        .menu-btn:active {
            background: rgba(255, 255, 255, 0.08);
        }

        .playlist-card,
        .channel-card,
        .hashtag-card {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 12px;
            text-decoration: none;
            color: var(--text-color);
            padding: 4px 0;
        }

        .playlist-thumb,
        .channel-thumb,
        .hashtag-thumb {
            width: 112px;
            aspect-ratio: 16 / 9;
            border-radius: 10px;
            background-color: #181818;
            background-size: cover;
            background-position: center;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
        }

        .channel-thumb {
            aspect-ratio: 1 / 1;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 30%, #ff4fd8, #7b2cff 58%, #161616 100%);
            font-size: 34px;
            text-transform: uppercase;
        }

        .channel-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .hashtag-thumb {
            aspect-ratio: 1 / 1;
            border-radius: 18px;
            font-size: 38px;
            background: linear-gradient(135deg, #292929, #171717);
            border: 1px solid var(--card-border);
        }

        .compact-title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            color: var(--text-color);
            font-size: 15px;
            line-height: 1.32;
            font-weight: 400;
            text-decoration: none;
        }

        .compact-meta {
            color: var(--secondary-text);
            font-size: 13px;
            line-height: 1.35;
            margin-top: 5px;
            font-weight: 400;
        }

        .compact-description {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            color: var(--muted-text);
            font-size: 12px;
            line-height: 1.35;
            margin-top: 6px;
            font-weight: 400;
        }

        .page-controls {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 95;
            pointer-events: none;
            padding: 12px 14px;
            padding-bottom: max(12px, env(safe-area-inset-bottom));
            background: linear-gradient(to top, rgba(15, 15, 15, 0.98), rgba(15, 15, 15, 0.78), rgba(15, 15, 15, 0));
        }

        .page-controls-inner {
            max-width: 720px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            pointer-events: auto;
        }

        .page-btn {
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: white;
            text-decoration: none;
            background: var(--button-bg);
            border: 1px solid rgba(255, 255, 255, 0.09);
            border-radius: 999px;
            padding: 0 16px;
            font-size: 14px;
            font-weight: 400;
            transition: background 150ms ease, transform 150ms ease, opacity 150ms ease;
        }

        .page-btn:active {
            transform: scale(0.96);
            background: var(--button-bg-active);
        }

        .page-btn.disabled {
            opacity: 0.34;
            pointer-events: none;
        }

        .page-count {
            min-height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--secondary-text);
            background: rgba(255, 255, 255, 0.055);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 999px;
            padding: 0 13px;
            font-size: 13px;
            font-weight: 400;
            white-space: nowrap;
        }

        .empty-state {
            text-align: center;
            margin: 58px auto 0;
            color: var(--secondary-text);
            padding: 0 22px;
            max-width: 360px;
        }

        .empty-state h1 {
            color: var(--text-color);
            font-size: 22px;
            line-height: 1.2;
            margin: 0 0 10px;
            letter-spacing: -0.03em;
            font-weight: 400;
        }

        .empty-state p {
            margin: 0;
            font-size: 14px;
            line-height: 1.5;
            font-weight: 400;
        }

        .loading {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.78);
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .spinner {
            border: 4px solid #333333;
            border-top: 4px solid #ffffff;
            border-radius: 50%;
            width: 42px;
            height: 42px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        @media (max-width: 380px) {
            .nav-wrap {
                min-height: 70px;
                padding-left: 10px;
                padding-right: 10px;
            }

            .search-container {
                height: 48px;
                padding-left: 16px;
            }

            input[name="mobilesearch"] {
                font-size: 16px;
            }

            button.search-btn {
                width: 36px;
                height: 36px;
            }

            .content-wrap {
                padding-left: 10px;
                padding-right: 10px;
            }

            .result-body {
                grid-template-columns: 40px minmax(0, 1fr) 28px;
                gap: 10px;
            }

            .avatar-link,
            .avatar-fallback {
                width: 36px;
                height: 36px;
            }

            .result-title {
                font-size: 15px;
            }

            .playlist-card,
            .channel-card,
            .hashtag-card {
                grid-template-columns: 96px minmax(0, 1fr);
                gap: 10px;
            }

            .playlist-thumb,
            .channel-thumb,
            .hashtag-thumb {
                width: 96px;
            }

            .page-controls {
                padding-left: 10px;
                padding-right: 10px;
            }

            .page-btn {
                padding: 0 12px;
                font-size: 13px;
            }

            .page-count {
                padding: 0 10px;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
    <%
        let currentPage = (typeof continuation !== 'undefined' && continuation) ? Number(continuation) : 1;

        if (!Number.isFinite(currentPage) || currentPage < 1) {
            currentPage = 1;
        }

        const searchQuery = typeof mobilesearch !== 'undefined' ? mobilesearch : '';
        const encodedSearchQuery = encodeURIComponent(searchQuery);
        const prevPage = currentPage > 1 ? currentPage - 1 : 1;
        const nextPage = currentPage + 1;
        const prevUrl = `/app?mobilesearch=${encodedSearchQuery}&continuation=${prevPage}`;
        const nextUrl = `/app?mobilesearch=${encodedSearchQuery}&continuation=${nextPage}`;

        function formatViews(count) {
            const n = Number(count);

            if (!Number.isFinite(n) || n <= 0) {
                return '';
            }

            if (n >= 1000000000) {
                return `${(n / 1000000000).toFixed(n >= 10000000000 ? 0 : 1).replace(/\.0$/, '')}B views`;
            }

            if (n >= 1000000) {
                return `${(n / 1000000).toFixed(n >= 10000000 ? 0 : 1).replace(/\.0$/, '')}M views`;
            }

            if (n >= 1000) {
                return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, '')}K views`;
            }

            return `${n} views`;
        }

        function formatCount(count, word) {
            const n = Number(count);

            if (!Number.isFinite(n) || n <= 0) {
                return '';
            }

            if (n >= 1000000000) {
                return `${(n / 1000000000).toFixed(n >= 10000000000 ? 0 : 1).replace(/\.0$/, '')}B ${word}`;
            }

            if (n >= 1000000) {
                return `${(n / 1000000).toFixed(n >= 10000000 ? 0 : 1).replace(/\.0$/, '')}M ${word}`;
            }

            if (n >= 1000) {
                return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, '')}K ${word}`;
            }

            return `${n} ${word}`;
        }

        function getInitial(name) {
            if (!name || typeof name !== 'string') {
                return 'P';
            }

            const clean = name.trim();

            if (!clean) {
                return 'P';
            }

            return clean.charAt(0);
        }

        function cleanChannelId(item) {
            if (!item) {
                return '';
            }

            let raw = item.authorId || item.channelId || item.ucid || item.authorUrl || item.channelUrl || '';

            if (!raw || typeof raw !== 'string') {
                return '';
            }

            raw = raw.trim();

            if (!raw) {
                return '';
            }

            raw = raw
                .replace(/^https?:\/\/www\.youtube\.com\/channel\//, '')
                .replace(/^https?:\/\/youtube\.com\/channel\//, '')
                .replace(/^https?:\/\/m\.youtube\.com\/channel\//, '')
                .replace(/^https?:\/\/www\.youtube\.com\/c\//, '')
                .replace(/^https?:\/\/youtube\.com\/c\//, '')
                .replace(/^https?:\/\/m\.youtube\.com\/c\//, '')
                .replace(/^https?:\/\/www\.youtube\.com\/user\//, '')
                .replace(/^https?:\/\/youtube\.com\/user\//, '')
                .replace(/^https?:\/\/m\.youtube\.com\/user\//, '')
                .replace(/^https?:\/\/www\.youtube\.com\//, '')
                .replace(/^https?:\/\/youtube\.com\//, '')
                .replace(/^https?:\/\/m\.youtube\.com\//, '')
                .replace(/^\/channel\//, '')
                .replace(/^\/c\//, '')
                .replace(/^\/user\//, '')
                .replace(/^@/, '');

            return raw;
        }

        function getThumb(item) {
            if (!item) {
                return '';
            }

            if (item.type === 'playlist' && item.playlistThumbnail) {
                return item.playlistThumbnail;
            }

            if (Array.isArray(item.videoThumbnails) && item.videoThumbnails.length) {
                const preferred =
                    item.videoThumbnails.find(t => t.quality === 'maxres') ||
                    item.videoThumbnails.find(t => t.quality === 'maxresdefault') ||
                    item.videoThumbnails.find(t => t.quality === 'sddefault') ||
                    item.videoThumbnails.find(t => t.quality === 'high') ||
                    item.videoThumbnails.find(t => t.quality === 'medium') ||
                    item.videoThumbnails.find(t => t.quality === 'default') ||
                    item.videoThumbnails[item.videoThumbnails.length - 1];

                if (preferred && preferred.url) {
                    return preferred.url;
                }
            }

            if (item.videoId) {
                return `https://i.ytimg.com/vi/${item.videoId}/hqdefault.jpg`;
            }

            return '';
        }

        function getPlaylistThumb(item) {
            if (!item) {
                return '';
            }

            if (item.playlistThumbnail) {
                return item.playlistThumbnail;
            }

            if (Array.isArray(item.videos) && item.videos.length) {
                return getThumb(item.videos[0]);
            }

            return '';
        }

        function getAuthorThumb(item) {
            if (!item || !Array.isArray(item.authorThumbnails) || !item.authorThumbnails.length) {
                return '';
            }

            const preferred =
                item.authorThumbnails.find(t => Number(t.width) >= 176) ||
                item.authorThumbnails.find(t => Number(t.width) >= 88) ||
                item.authorThumbnails[item.authorThumbnails.length - 1];

            return preferred && preferred.url ? preferred.url : '';
        }

        function stripHtml(value) {
            if (!value || typeof value !== 'string') {
                return '';
            }

            return value.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
        }

        const rawResults = typeof j !== 'undefined' && j && Array.isArray(j.results) ? j.results : [];
        const pageResults = currentPage > 1 ? rawResults.slice(1) : rawResults;

        const seenResultKeys = new Set();

        const visibleResults = pageResults.filter(item => {
            if (!item) {
                return false;
            }

            const key = [
                item.type || 'unknown',
                item.videoId || '',
                item.playlistId || '',
                item.authorId || '',
                item.url || '',
                item.title || '',
                item.author || ''
            ].join(':');

            if (seenResultKeys.has(key)) {
                return false;
            }

            seenResultKeys.add(key);
            return true;
        });
    %>

    <header class="app-header">
        <div class="nav-wrap">
            <form action="/app" method="get" class="search-container" role="search">
                <i class="fa-light fa-search search-icon-inline" aria-hidden="true"></i>
                <input type="text" name="mobilesearch" value="<%= searchQuery %>" placeholder="Search Poke" autocomplete="off">
                <button type="submit" class="search-btn" aria-label="Search">
                    <i class="fa-light fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </header>

    <main class="content-wrap">
        <% if (visibleResults.length) { %>
            <section class="results-list" aria-label="Search results">
                <% visibleResults.forEach(x => { %>
                    <% if (x && x.type === 'video') { %>
                        <%
                            const videoId = x.videoId || '';
                            const authorId = cleanChannelId(x);
                            const thumb = getThumb(x);
                            const views = formatViews(x.viewCount);
                            const publishedText = x.publishedText || '';
                            const videoHref = `/watch?v=${encodeURIComponent(videoId)}`;
                            const channelHref = authorId ? `/channel?id=${encodeURIComponent(authorId)}` : '';
                        %>

                        <article class="result-card">
                            <a href="<%= videoHref %>" class="thumb-link" aria-label="<%- x.title || 'Video' %>">
                                <span class="thumb" style="background-image: url('<%= thumb %>');"></span>
                            </a>

                            <div class="result-body">
                                <% if (channelHref) { %>
                                    <a href="<%= channelHref %>" class="avatar-link" aria-label="<%- x.author || 'Channel' %>">
                                        <span><%- getInitial(x.author) %></span>
                                    </a>
                                <% } else { %>
                                    <div class="avatar-fallback" aria-hidden="true">
                                        <span><%- getInitial(x.author) %></span>
                                    </div>
                                <% } %>

                                <div class="result-text">
                                    <a href="<%= videoHref %>" class="result-title"><%- x.title || 'Untitled video' %></a>

                                    <div class="meta">
                                        <% if (channelHref) { %>
                                            <a href="<%= channelHref %>" class="author-name"><%- x.author || 'Unknown channel' %></a>
                                        <% } else { %>
                                            <span class="author-name"><%- x.author || 'Unknown channel' %></span>
                                        <% } %>

                                        <% if (views) { %>
                                            <span class="meta-dot">•</span>
                                            <span class="meta-text"><%- views %></span>
                                        <% } %>

                                        <% if (publishedText) { %>
                                            <span class="meta-dot">•</span>
                                            <span class="meta-text"><%- publishedText %></span>
                                        <% } %>
                                    </div>
                                </div>

                                <button type="button" class="menu-btn" aria-label="More options">
                                    <i class="fa-light fa-ellipsis-vertical"></i>
                                </button>
                            </div>
                        </article>
                    <% } else if (x && x.type === 'playlist') { %>
                        <%
                            const playlistId = x.playlistId || '';
                            const playlistThumb = getPlaylistThumb(x);
                            const authorId = cleanChannelId(x);
                            const playlistHref = `/playlist?list=${encodeURIComponent(playlistId)}`;
                            const playlistMeta = [
                                x.author || '',
                                formatCount(x.videoCount, 'videos')
                            ].filter(Boolean).join(' • ');
                        %>

                        <a href="<%= playlistHref %>" class="playlist-card">
                            <span class="playlist-thumb" style="background-image: url('<%= playlistThumb %>');"></span>

                            <span>
                                <span class="compact-title"><%- x.title || 'Untitled playlist' %></span>
                                <span class="compact-meta"><%- playlistMeta || 'Playlist' %></span>

                                <% if (authorId) { %>
                                    <span class="compact-description">Channel: <%- x.author || authorId %></span>
                                <% } %>
                            </span>
                        </a>
                    <% } else if (x && x.type === 'channel') { %>
                        <%
                            const authorId = cleanChannelId(x);
                            const channelHref = authorId ? `/channel?id=${encodeURIComponent(authorId)}` : '#';
                            const authorThumb = getAuthorThumb(x);
                            const channelMeta = [
                                formatCount(x.subCount, 'subscribers'),
                                formatCount(x.videoCount, 'videos')
                            ].filter(Boolean).join(' • ');
                            const description = stripHtml(x.descriptionHtml || x.description || '');
                        %>

                        <a href="<%= channelHref %>" class="channel-card">
                            <span class="channel-thumb">
                                <% if (authorThumb) { %>
                                    <img src="<%= authorThumb %>" alt="">
                                <% } else { %>
                                    <span><%- getInitial(x.author) %></span>
                                <% } %>
                            </span>

                            <span>
                                <span class="compact-title"><%- x.author || 'Unknown channel' %></span>
                                <span class="compact-meta"><%- channelMeta || 'Channel' %></span>

                                <% if (description) { %>
                                    <span class="compact-description"><%- description %></span>
                                <% } %>
                            </span>
                        </a>
                    <% } else if (x && x.type === 'hashtag') { %>
                        <%
                            const hashtagHref = x.url || `/hashtag/${encodeURIComponent((x.title || '').replace(/^#/, ''))}`;
                            const hashtagMeta = [
                                formatCount(x.channelCount, 'channels'),
                                formatCount(x.videoCount, 'videos')
                            ].filter(Boolean).join(' • ');
                        %>

                        <a href="<%= hashtagHref %>" class="hashtag-card">
                            <span class="hashtag-thumb">
                                <i class="fa-light fa-hashtag"></i>
                            </span>

                            <span>
                                <span class="compact-title"><%- x.title || 'Hashtag' %></span>
                                <span class="compact-meta"><%- hashtagMeta || 'Hashtag' %></span>
                            </span>
                        </a>
                    <% } %>
                <% }) %>
            </section>
        <% } else { %>
            <div class="empty-state">
                <h1>Poke Mobile Search</h1>
                <p>Search for videos to get started.</p>
            </div>
        <% } %>
    </main>

    <nav class="page-controls" aria-label="Search page navigation">
        <div class="page-controls-inner">
            <% if (currentPage > 1) { %>
                <a href="<%= prevUrl %>" class="page-btn" data-page-nav="prev">
                    <i class="fa-light fa-arrow-left"></i>
                    <span>Prev</span>
                </a>
            <% } else { %>
                <span class="page-btn disabled">
                    <i class="fa-light fa-arrow-left"></i>
                    <span>Prev</span>
                </span>
            <% } %>

            <span class="page-count">Page <%= currentPage %></span>

            <a href="<%= nextUrl %>" class="page-btn" data-page-nav="next">
                <span>Next</span>
                <i class="fa-light fa-arrow-right"></i>
            </a>
        </div>
    </nav>

    <script>
        const links = document.querySelectorAll('a');

        function showLoading() {
            if (document.querySelector('.loading')) {
                return;
            }

            const loading = document.createElement('div');
            loading.className = 'loading';
            loading.innerHTML = '<div class="spinner"></div>';
            document.body.classList.add('no-scroll');
            document.body.appendChild(loading);
        }

        links.forEach(link => {
            link.addEventListener('click', e => {
                const href = link.getAttribute('href');

                if (!href || href === '#' || href.startsWith('#') || href.startsWith('javascript:')) {
                    return;
                }

                if (link.target && link.target !== '_self') {
                    return;
                }

                showLoading();
            });
        });

        window.addEventListener('pageshow', () => {
            const loading = document.querySelector('.loading');

            if (loading) {
                loading.remove();
            }

            document.body.classList.remove('no-scroll');
        });

        window.addEventListener('keydown', e => {
            const active = document.activeElement;
            const typing = active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable);

            if (typing) {
                return;
            }

            if (e.key === 'ArrowLeft') {
                const prev = document.querySelector('[data-page-nav="prev"]');

                if (prev) {
                    prev.click();
                }
            }

            if (e.key === 'ArrowRight') {
                const next = document.querySelector('[data-page-nav="next"]');

                if (next) {
                    next.click();
                }
            }
        });

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(regs => {
                for (let reg of regs) {
                    reg.unregister();
                }
            });
        }
    </script>
</body>
</html>