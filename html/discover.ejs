<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Poke | Discover</title>
    
    <% if (!mobilesearch && !tab) { %>
        <meta http-equiv="refresh" content="0; url=/search">
    <% } %>

    <link href="/css/yt-ukraine.svg?v=6" rel="icon">
    <link href="/css/app-cdn.min.css" rel="stylesheet">
    <link href="https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #0f0f0f;
            --surface-color: #1e1e1e;
            --text-color: #ffffff;
            --text-secondary: #aaaaaa;
            --accent-color: #ff0000;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        /* Fixed Header */
        header {
            display: flex;
            align-items: center;
            padding: 10px;
            background: #0f0f0f;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid #333;
        }

        .logo { width: 32px; margin-right: 12px; }

        .search-container {
            flex-grow: 1;
            display: flex;
            background: var(--surface-color);
            border-radius: 25px;
            padding: 8px 16px;
            border: 1px solid #444;
        }

        input[name="mobilesearch"] {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            font-size: 16px;
        }

        .search-btn {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            padding: 0 5px;
        }

        /* Video Grid - Optimized for Phone screens */
        .video-grid {
            display: flex;
            flex-direction: column;
            gap: 20px;
            padding: 15px;
            margin-bottom: 80px; /* Space for footer/pagination */
        }

        .video-card {
            display: block;
            text-decoration: none;
            color: white;
        }

        .thumbnail {
            width: 100%;
            aspect-ratio: 16 / 9;
            background-size: cover;
            background-position: center;
            border-radius: 8px;
            background-color: #222;
        }

        .video-info { padding-top: 10px; }
        .title {
            font-size: 16px;
            font-weight: 500;
            line-height: 1.4;
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .author { font-size: 14px; color: var(--text-secondary); }

        /* Mobile Pagination Buttons */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 15px;
            padding: 20px 10px;
        }

        .nav-btn {
            background: var(--surface-color);
            color: white;
            padding: 12px 24px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border: 1px solid #444;
        }

        .nav-btn:active { background: #333; }

        /* Loading Spinner */
        .loading {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85); z-index: 9999;
            display: flex; justify-content: center; align-items: center;
        }
        .spinner {
            border: 3px solid #333; border-top: 3px solid var(--accent-color);
            border-radius: 50%; width: 40px; height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <header>
        <a href="/"><img src="/css/logo-poke.svg" class="logo" alt="Logo"></a>
        <form action="/app" class="search-container">
            <input type="text" name="mobilesearch" value="<%= typeof mobilesearch !== 'undefined' ? mobilesearch : '' %>" placeholder="Search...">
            <button type="submit" class="search-btn"><i class="fa-light fa-search"></i></button>
        </form>
    </header>

    <main class="video-grid">
        <% if (typeof j !== 'undefined' && j && Array.isArray(j.results)) { %>
            <% j.results.forEach(x => { %>
                <a href="/watch?v=<%- x.videoId %>" class="video-card">
                    <div class="thumbnail" style="background-image: url('https://i.ytimg.com/vi/<%= x.videoId %>/hqdefault.jpg');"></div>
                    <div class="video-info">
                        <div class="title"><%- x.title %></div>
                        <div class="author"><%- x.author %></div>
                    </div>
                </a>
            <% }) %>

            <!-- Large Mobile Pagination Buttons -->
            <div class="pagination">
                <% if (typeof continuation !== 'undefined' && Number(continuation) > 1) { %>
                    <a href="/app?mobilesearch=<%=mobilesearch%>&continuation=<%- Number(continuation) - 1 %>" class="nav-btn">Previous</a>
                <% } %>
                
                <% if (typeof continuation !== 'undefined') { %>
                    <a href="/app?mobilesearch=<%=mobilesearch%>&continuation=<%- Number(continuation) + 1 %>" class="nav-btn">Next Page</a>
                <% } %>
            </div>
        <% } else { %>
            <div style="text-align: center; margin-top: 60px; color: var(--text-secondary);">
                <p>Use the search bar above to find videos.</p>
            </div>
        <% } %>
    </main>

    <script>
        document.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', e => {
                // Ensure it's not a hash link
                if(link.getAttribute('href') && !link.getAttribute('href').startsWith('#')) {
                    const loading = document.createElement('div');
                    loading.className = 'loading';
                    loading.innerHTML = '<div class="spinner"></div>';
                    document.body.appendChild(loading);
                }
            });
        });

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(regs => {
                for (let reg of regs) reg.unregister();
            });
        }
    </script>
</body>
</html>