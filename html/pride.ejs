        <script>
document.addEventListener('DOMContentLoaded', () => {
  const storageKey = 'remove_old_contents_landing_page';
  const now = Date.now();
  const expiry = localStorage.getItem(storageKey);

  if (!expiry || now > parseInt(expiry)) {
    
    setTimeout(() => {
      const elementsToHide = document.querySelectorAll('.hideonload');
      
      elementsToHide.forEach(el => {
        el.style.display = 'none';
      });

      const newExpiry = Date.now() + (30 * 60 * 1000);
      localStorage.setItem(storageKey, newExpiry.toString());
      
    }, 300);

  } else {
    document.querySelectorAll('.hideonload').forEach(el => {
      el.style.display = 'none';
    });
  }

  const searchInput = document.getElementById('termSearch');
  const termCards = document.querySelectorAll('.term-card');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      termCards.forEach(card => {
        const text = card.textContent.toLowerCase();
        if (text.includes(query)) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  }
});

          (function () {
            var marquee = document.querySelector('.pk-marquee');
            if (!marquee) return;
            var tracks = marquee.querySelectorAll('.pk-marquee__track');
            if (tracks.length < 2) return;

            function tuneSpeed() {
              var contentWidth = tracks[0].scrollWidth;
              var viewport    = marquee.clientWidth || 1;
              var ratio       = contentWidth / viewport;
              var baseSeconds = 18;
              var clamped     = Math.max(baseSeconds, Math.min(60, baseSeconds * ratio));
              marquee.style.setProperty('--speed', clamped.toFixed(2) + 's');
            }

            tuneSpeed();
            window.addEventListener('resize', tuneSpeed);
          })();
        </script>

