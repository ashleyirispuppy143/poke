<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Poke is where pride happens</title>
  <style>
    @font-face {
      font-family: "PokeTube Flex";
      src: url("/static/robotoflex.ttf");
      font-style: normal;
      font-stretch: 1% 800%;
      font-display: swap;
    }

    :root {
      --accent: #ffabcc;
      --bg-dark: #0f0f0f;
      --bg-card: #1a1a1a;
      --bg-hover: #2a2a2a;
      --text-main: #ffffff;
      --text-muted: #aaaaaa;
      --border-color: #333333;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "PokeTube Flex", sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-main);
      line-height: 1.6;
      overflow-x: hidden;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 32px;
      background-color: rgba(15, 15, 15, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .navbar-logo {
      height: 40px;
    }

    .navbar-links {
      display: flex;
      gap: 24px;
    }

    .navbar-links a {
      color: var(--text-main);
      text-decoration: none;
      font-weight: 600;
      font-stretch: 110%;
      transition: color 0.2s;
    }

    .navbar-links a:hover {
      color: var(--accent);
    }

    .hero {
      position: relative;
      padding: 240px 20px;
      text-align: center;
      background-color: var(--bg-dark);
      border-bottom: 1px solid var(--border-color);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 1;
    }

    .hero::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 6px;
      background: linear-gradient(90deg, #ea392f, #f28917, #eecb12, #78b82a, #4375ca, #c346e3, #7bcce5, #eaeaea, #f4aec8, #000, #945516);
      z-index: 10;
    }

    /* Highly optimized fluid background without filter: blur() to prevent lag */
    .fluid-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
      background-color: var(--bg-dark);
      overflow: hidden;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      opacity: 0.6;
      will-change: transform;
      transform: translate3d(0, 0, 0);
    }

    /* Soft radial gradients emulate blur with practically zero performance cost */
    .blob-trans {
      background: radial-gradient(circle, rgba(91, 206, 250, 0.7) 0%, rgba(245, 169, 184, 0.4) 40%, transparent 70%);
      width: 120vw;
      height: 120vw;
      top: -40%;
      left: -30%;
    }

    .blob-rainbow {
      background: radial-gradient(circle, rgba(228, 3, 3, 0.5) 0%, rgba(255, 140, 0, 0.4) 20%, rgba(255, 237, 0, 0.3) 40%, rgba(0, 128, 38, 0.2) 60%, transparent 80%);
      width: 140vw;
      height: 140vw;
      bottom: -50%;
      right: -30%;
    }

    .blob-lesbian {
      background: radial-gradient(circle, rgba(213, 45, 0, 0.6) 0%, rgba(211, 98, 164, 0.4) 40%, transparent 70%);
      width: 100vw;
      height: 100vw;
      top: 10%;
      right: -20%;
    }

    .blob-bi {
      background: radial-gradient(circle, rgba(214, 2, 112, 0.6) 0%, rgba(155, 79, 150, 0.5) 40%, rgba(0, 56, 168, 0.3) 70%, transparent 85%);
      width: 110vw;
      height: 110vw;
      bottom: -20%;
      left: -20%;
    }

    @media (prefers-reduced-motion: no-preference) {
      .blob-trans { animation: floatOrbs 20s infinite alternate ease-in-out; }
      .blob-rainbow { animation: floatOrbs 25s infinite alternate-reverse ease-in-out; }
      .blob-lesbian { animation: floatOrbs 22s infinite alternate ease-in-out; animation-delay: -5s; }
      .blob-bi { animation: floatOrbs 28s infinite alternate-reverse ease-in-out; animation-delay: -10s; }
      
      .hero h1 {
        animation: shineText 8s linear infinite;
      }
    }

    @keyframes floatOrbs {
      0% { transform: translate3d(0, 0, 0) scale(1); }
      33% { transform: translate3d(10vw, 5vh, 0) scale(1.05); }
      66% { transform: translate3d(-5vw, 12vh, 0) scale(0.95); }
      100% { transform: translate3d(-15vw, -5vh, 0) scale(1.1); }
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 900px;
      padding: 0 20px;
    }

    .hero h1 {
      font-size: 5.5rem;
      font-weight: 800;
      font-stretch: 150%;
      margin-bottom: 24px;
      text-transform: uppercase;
      letter-spacing: 2px;
      background: linear-gradient(90deg, #5BCEFA, #F5A9B8, #FFFFFF, #F5A9B8, #5BCEFA);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.1;
      filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.9));
    }

    @keyframes shineText {
      to { background-position: 200% center; }
    }

    .hero p {
      font-size: 1.5rem;
      color: #ffffff;
      margin: 0 auto 40px auto;
      font-stretch: 100%;
      font-weight: 600;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.9);
    }

    .hero-btn {
      display: inline-block;
      background: #ffffff;
      color: #000000;
      padding: 18px 45px;
      border-radius: 50px;
      font-weight: 800;
      font-size: 1.2rem;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
    }

    .hero-btn:hover {
      transform: translateY(-4px) scale(1.05);
      background: var(--accent);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 100px 20px;
    }

    .section-title {
      font-size: 3.2rem;
      font-weight: 800;
      font-stretch: 120%;
      margin-bottom: 60px;
      text-align: center;
      color: var(--accent);
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
      margin-bottom: 120px;
    }

    .feature-card {
      background-color: var(--bg-card);
      padding: 40px;
      border-radius: 20px;
      border: 1px solid var(--border-color);
      transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
    }

    .feature-card:hover {
      border-color: var(--accent);
      transform: translateY(-8px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    .feature-card h3 {
      font-size: 1.6rem;
      margin-bottom: 16px;
      color: #fff;
    }

    .feature-card p {
      color: var(--text-muted);
      font-size: 1.05rem;
    }

    .creators-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
      margin-bottom: 120px;
    }

    .channel-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 20px;
      background-color: var(--bg-card);
      border-radius: 20px;
      text-align: center;
      transition: transform 0.3s, background-color 0.3s;
      border: 1px solid var(--border-color);
    }

    .channel-card:hover {
      background-color: var(--bg-hover);
      transform: translateY(-5px);
      border-color: var(--accent);
    }

    .channel-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background-color: var(--bg-dark);
      margin-bottom: 20px;
      border: 3px solid transparent;
      transition: border-color 0.3s, transform 0.3s;
    }

    .channel-card:hover .channel-avatar {
      border-color: var(--accent);
      transform: scale(1.08);
    }

    .channel-name {
      font-size: 1.3rem;
      color: var(--text-main);
      font-weight: 700;
      margin-bottom: 4px;
    }
    
    .channel-pronouns {
      font-size: 0.85rem;
      color: var(--accent);
      background: rgba(255, 171, 204, 0.1);
      padding: 4px 10px;
      border-radius: 12px;
      margin-bottom: 6px;
      font-weight: 600;
    }

    .channel-handle {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-bottom: 24px;
    }

    .btn-view-channel {
      background-color: #ffffff;
      color: #0f0f0f;
      border-radius: 25px;
      padding: 12px 28px;
      font-weight: 800;
      font-size: 0.95rem;
      text-decoration: none;
      transition: all 0.3s;
    }

    .btn-view-channel:hover {
      background-color: var(--accent);
      color: #000000;
      box-shadow: 0 4px 15px rgba(255, 171, 204, 0.4);
    }

    /* Better 30-item History Timeline */
    .history-timeline {
      position: relative;
      margin: 0 auto 120px auto;
      max-width: 1000px;
    }

    .history-timeline::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 4px;
      background: linear-gradient(to bottom, var(--accent), #7bcce5, #c346e3);
      border-radius: 2px;
      transform: translateX(-50%);
    }

    .history-item {
      position: relative;
      width: 50%;
      padding: 20px 40px;
      margin-bottom: 0;
    }

    .history-item:nth-child(odd) {
      left: 0;
      text-align: right;
    }

    .history-item:nth-child(even) {
      left: 50%;
      text-align: left;
    }

    .history-item::before {
      content: "";
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--bg-dark);
      border: 4px solid var(--accent);
      z-index: 2;
      transition: transform 0.3s, background 0.3s;
    }

    .history-item:nth-child(odd)::before {
      right: -12px;
    }

    .history-item:nth-child(even)::before {
      left: -12px;
    }

    .history-item:hover::before {
      transform: translateY(-50%) scale(1.3);
      background: var(--accent);
    }

    .history-card {
      background-color: var(--bg-card);
      padding: 24px 32px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      transition: transform 0.3s, border-color 0.3s;
      display: inline-block;
      width: 100%;
    }

    .history-item:nth-child(odd) .history-card:hover {
      transform: translateX(-8px);
      border-color: var(--accent);
    }
    
    .history-item:nth-child(even) .history-card:hover {
      transform: translateX(8px);
      border-color: var(--accent);
    }

    .history-header {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
    }

    .history-item:nth-child(even) .history-header {
      align-items: flex-start;
    }

    .history-item:nth-child(odd) .history-header {
      align-items: flex-end;
    }

    .history-date {
      color: var(--accent);
      font-size: 1.1rem;
      font-weight: 800;
      background: rgba(255, 171, 204, 0.1);
      padding: 4px 12px;
      border-radius: 20px;
      display: inline-block;
    }

    .history-title {
      font-size: 1.4rem;
      color: #ffffff;
      font-weight: 700;
    }

    .history-card p {
      font-size: 1.05rem;
      color: #cccccc;
      line-height: 1.6;
    }

    @media (max-width: 768px) {
      .history-timeline::before {
        left: 20px;
        transform: none;
      }
      .history-item {
        width: 100%;
        padding-left: 60px;
        padding-right: 20px;
        left: 0 !important;
        text-align: left !important;
      }
      .history-item::before {
        left: 10px !important;
        right: auto !important;
      }
      .history-item:nth-child(odd) .history-header,
      .history-item:nth-child(even) .history-header {
        align-items: flex-start;
      }
      .history-item:nth-child(odd) .history-card:hover,
      .history-item:nth-child(even) .history-card:hover {
        transform: translateX(8px);
      }
    }

    /* Myths Section */
    .misconceptions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 32px;
      margin-bottom: 120px;
    }

    .myth-card {
      background-color: var(--bg-card);
      padding: 32px;
      border-radius: 20px;
      border: 1px solid var(--border-color);
      transition: border-color 0.3s, transform 0.3s;
    }

    .myth-card:hover {
      border-color: #ff5e5e;
      transform: translateY(-5px);
    }

    .myth-title {
      font-size: 1.2rem;
      color: #ff5e5e;
      font-weight: 800;
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .myth-title::before {
      content: "✕";
      font-size: 1.4rem;
    }

    .myth-fact {
      font-size: 1.05rem;
      color: #dddddd;
      line-height: 1.6;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .myth-fact strong {
      color: #78b82a;
      font-size: 1.2rem;
      display: block;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .myth-fact strong::before {
      content: "✓ ";
    }

    /* Dictionary */
    .search-container {
      margin-bottom: 40px;
      text-align: center;
    }

    .term-search-input {
      width: 100%;
      max-width: 600px;
      padding: 18px 24px;
      border-radius: 30px;
      border: 2px solid var(--border-color);
      background-color: var(--bg-card);
      color: #ffffff;
      font-size: 1.1rem;
      font-family: inherit;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .term-search-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 15px rgba(255, 171, 204, 0.2);
    }

    .dictionary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-bottom: 120px;
    }

    .term-card {
      background-color: var(--bg-card);
      padding: 30px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .term-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--border-color);
      transition: background 0.3s;
    }

    .term-card:hover {
      background-color: var(--bg-hover);
      transform: translateY(-6px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.3);
      border-color: var(--accent);
    }

    .term-card:hover::before {
      background: var(--accent);
    }

    .term-name {
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--accent);
      margin-bottom: 12px;
    }

    .term-def {
      color: #cccccc;
      font-size: 1.05rem;
      line-height: 1.6;
    }

  </style>
</head>
