      { myth: "Queer people want special privileges", fact: "The community is seeking equal rights, fundamental dignity, and protection from discrimination. These are exactly the same baseline rights that heterosexual and cisgender people experience safely every single day." },
      { myth: "Being trans is a mental illness", fact: "Being transgender is a natural variation of human gender identity. Every major medical and psychological association affirms this. Gender dysphoria is the distress caused by societal friction and physical mismatch, which transition care alleviates." },
      { myth: "Pride events are dangerous for children", fact: "Pride is about celebrating diversity, love, and community. Teaching children about inclusion, empathy, and existence prevents bullying and helps them grow into compassionate adults." },
      { myth: "It's a threat to family values", fact: "Queer people build loving families, adopt children in need, and expand the definition of family to include chosen families. Love and support are what make a family, regardless of gender." },
      { myth: "Bisexuality is just a 'phase'", fact: "Bisexuality is a valid, distinct sexual orientation. Bisexual people are not 'confused' or in transition to being gay or straight. Their identity is whole and complete." },
      { myth: "Transgender people regret transitioning", fact: "Studies consistently show that the regret rate for gender-affirming care is less than 1% — vastly lower than the regret rates for almost any standard medical or surgical procedure." },
      { myth: "Asexual people just haven't found the right person", fact: "Asexuality is a complete sexual orientation characterized by a lack of sexual attraction. It is not celibacy, abstinence, or a temporary state of mind." },
      { myth: "Non-binary identities are a modern internet invention", fact: "Cultures across the globe, from Native American Two-Spirit identities to the Hijra in India, have recognized and revered genders outside the binary for centuries." },
      { myth: "Gender-affirming care for youth is experimental", fact: "Gender-affirming care is a well-established, evidence-based medical practice endorsed by the AAP, AMA, and APA, significantly improving mental health outcomes." },
      { myth: "You can tell someone's identity by looking at them", fact: "Gender expression (how someone presents themselves) does not automatically equal gender identity or sexual orientation. You can never truly know until someone tells you." }
    ];

    const historyEvents = [
      { year: "1924", title: "Society for Human Rights", desc: "The first recognized gay rights organization in the United States is founded in Chicago by Henry Gerber." },
      { year: "1950", title: "Mattachine Society", desc: "Harry Hay founds one of the first sustained gay rights groups in the U.S., focusing on assimilation and advocacy." },
      { year: "1955", title: "Daughters of Bilitis", desc: "The first lesbian civil and political rights organization in the U.S. is formed in San Francisco." },
      { year: "1966", title: "Compton's Cafeteria Riot", desc: "Transgender women and drag queens fight back against police harassment in San Francisco, preceding Stonewall." },
      { year: "1969", title: "The Stonewall Uprising", desc: "Patrons of the Stonewall Inn in NYC resist a police raid, sparking the modern LGBTQ+ rights movement. Marsha P. Johnson and Sylvia Rivera are prominent figures." },
      { year: "1970", title: "First Pride Marches", desc: "The first Christopher Street Liberation Day marches are held in NY, LA, and Chicago to commemorate Stonewall." },
      { year: "1973", title: "APA Declassifies Homosexuality", desc: "The American Psychiatric Association removes homosexuality from its list of mental disorders." },
      { year: "1974", title: "Kathy Kozachenko Elected", desc: "Becomes the first openly LGBTQ+ American elected to public office (Ann Arbor City Council)." },
      { year: "1977", title: "Harvey Milk Elected", desc: "Harvey Milk becomes the first openly gay man elected to public office in California." },
      { year: "1978", title: "The Rainbow Flag", desc: "Gilbert Baker designs the iconic Rainbow Flag, which debuts at the San Francisco Gay Freedom Day Parade." },
      { year: "1979", title: "March on Washington", desc: "The first National March on Washington for Lesbian and Gay Rights draws an estimated 75,000 to 125,000 people." },
      { year: "1981", title: "Lambda Legal Defense", desc: "Founding of the first legal organization to fight for the rights of LGBTQ+ people." },
      { year: "1987", title: "ACT UP Formed", desc: "The AIDS Coalition to Unleash Power is formed to demand political action to combat the AIDS crisis." },
      { year: "1988", title: "World AIDS Day", desc: "The first World AIDS Day is observed to raise awareness and mourn those lost to the epidemic." },
      { year: "1993", title: "Don't Ask, Don't Tell", desc: "The U.S. policy prohibiting military personnel from discriminating against closeted queer people, while barring openly queer people from service." },
      { year: "1996", title: "DOMA Passed", desc: "The Defense of Marriage Act defines marriage as between a man and a woman, later overturned." },
      { year: "1999", title: "Transgender Day of Remembrance", desc: "Founded by Gwendolyn Ann Smith to memorialize those murdered due to anti-transgender violence." },
      { year: "2001", title: "First Same-Sex Marriage", desc: "The Netherlands becomes the first country in the world to legalize same-sex marriage." },
      { year: "2003", title: "Lawrence v. Texas", desc: "The U.S. Supreme Court strikes down sodomy laws across the country, decriminalizing same-sex relationships." },
      { year: "2004", title: "Massachusetts Legalizes Marriage", desc: "Becomes the first U.S. state to legally recognize same-sex marriages." },
      { year: "2010", title: "DADT Repealed", desc: "The U.S. Senate repeals 'Don't Ask, Don't Tell', allowing gay, lesbian, and bisexual people to serve openly." },
      { year: "2013", title: "DOMA Ruled Unconstitutional", desc: "The U.S. Supreme Court rules that legally married same-sex couples are entitled to federal benefits." },
      { year: "2015", title: "Obergefell v. Hodges", desc: "The U.S. Supreme Court guarantees the right to same-sex marriage nationwide." },
      { year: "2016", title: "Stonewall National Monument", desc: "President Obama designates the Stonewall Inn as the first national monument honoring LGBTQ+ rights." },
      { year: "2019", title: "WHO Declassifies Transgender Identity", desc: "The World Health Organization removes 'gender incongruence' from its list of mental disorders." },
      { year: "2020", title: "Bostock v. Clayton County", desc: "The U.S. Supreme Court rules the Civil Rights Act protects LGBTQ+ employees from workplace discrimination." },
      { year: "2021", title: "Record Global Visibility", desc: "A record number of openly LGBTQ+ athletes compete in the Tokyo Olympics, reflecting growing global acceptance." },
      { year: "2022", title: "Respect for Marriage Act", desc: "The U.S. passes federal protection for same-sex and interracial marriages." },
      { year: "Present", title: "The Ongoing Fight", desc: "The movement continues globally, fighting against anti-trans legislation and advocating for true intersectional liberation." }
    ];
  %>


  <header class="hero">
    <div class="fluid-bg">
      <div class="blob blob-trans"></div>
      <div class="blob blob-rainbow"></div>
      <div class="blob blob-lesbian"></div>
      <div class="blob blob-bi"></div>
    </div>
    <div class="hero-content">
      <h1>Poke is where pride happens</h1>
      <p>A free and private platform built for everyone. Celebrate your identity, discover diverse creators, and experience software made with love.</p>
      <a href="/search" class="hero-btn">Start Exploring</a>
    </div>
  </header>

  <main class="container">
    
    <div class="features-grid">
      <div class="feature-card">
        <h3>Built by a Queer Developer</h3>
        <p>Poke was created by Ashley Íris Celeste. We understand the importance of building safe, welcoming spaces online because this project was built from the ground up by a queer person.</p>
      </div>
      <div class="feature-card">
        <h3>Pronoun Support</h3>
        <p>Identity matters. We have integrated dedicated pronoun support directly into your channel so you can show the world exactly how to refer to you.</p>
      </div>
      <div class="feature-card">
        <h3>Code of Conduct</h3>
        <p>We built a specific code of conduct heavily focused on radical inclusion and zero tolerance for bigotry to keep our spaces completely safe. Community spaces must be actively protected.</p>
      </div>
    </div>

    <h2 class="section-title">Spotlight: Queer Creators</h2>
    <div class="creators-grid">
      <% queerCreators.forEach(creator => { %>
        <div class="channel-card">
          <div class="channel-avatar">
            <% if (creator.avatar) { %>
              <img src="<%= creator.avatar %>" alt="<%= creator.name %>" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
            <% } %>
          </div>
          <div class="channel-name"><%= creator.name %></div>
          <% if (creator.pronouns) { %>
            <div class="channel-pronouns"><%= creator.pronouns %></div>
          <% } %>
          <div class="channel-handle"><%= creator.handle %></div>
          <a href="/channel?id=<%= creator.id %>" class="btn-view-channel">View Channel</a>
        </div>
      <% }) %>
    </div>

    <h2 class="section-title">Clearing the Air</h2>
    <div class="misconceptions-grid">
      <% myths.forEach(myth => { %>
        <div class="myth-card">
          <div class="myth-title"><%= myth.myth %></div>
          <div class="myth-fact">
            <strong>Fact</strong>
            <%= myth.fact %>
          </div>
        </div>
      <% }) %>
    </div>

    <h2 class="section-title">The Journey of Pride</h2>
    <div class="history-timeline">
      <% historyEvents.forEach(event => { %>
        <div class="history-item">
          <div class="history-card">
            <div class="history-header">
              <span class="history-date"><%= event.year %></span>
              <span class="history-title"><%= event.title %></span>
            </div>
            <p><%= event.desc %></p>
          </div>
        </div>
      <% }) %>
    </div>

    <h2 class="section-title">Understanding Queerness</h2>
    <div class="search-container">
      <input type="text" id="termSearch" class="term-search-input" placeholder="Search identities and terms...">
    </div>
    
    <div class="dictionary-grid" id="dictionaryGrid">
      <% queerTerms.forEach(item => { %>
        <div class="term-card">
          <div class="term-name"><%= item.term %></div>
          <div class="term-def"><%= item.def %></div>
        </div>
      <% }) %>
    </div>

  </main>

