<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Poke — Apps</title>
  <meta name="description" content="Poke is free software: a privacy-first suite with a player, translator, maps, notes, calendar, and more." />
  <meta name="theme-color" content="#1e1e2e" />
  
  <link href="https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css" rel="stylesheet" />
  
  <style>
    :root {
      --ctp-base: #1e1e2e;
      --ctp-mantle: #181825;
      --ctp-crust: #11111b;
      --ctp-surface0: #313244;
      --ctp-surface1: #45475a;
      --ctp-surface2: #585b70;
      --ctp-text: #cdd6f4;
      --ctp-subtext0: #a6adc8;
      --ctp-subtext1: #bac2de;
      --ctp-pink: #f5c2e7;
      --ctp-mauve: #cba6f7;
      --ctp-green: #a6e3a1;

      --md-radius-l: 28px;
      --md-radius-m: 16px;
      --md-radius-s: 12px;
      --md-elevation: 0 4px 8px 3px rgba(17, 17, 27, 0.15), 0 1px 3px rgba(17, 17, 27, 0.3);
      --transition: 0.25s cubic-bezier(0.2, 0, 0, 1);
    }

    * { box-sizing: border-box; }
    
    html, body { height: 100%; }
    
    body {
      margin: 0;
      color: var(--ctp-text);
      font-family: "Google Sans", ui-sans-serif, system-ui, -apple-system, sans-serif;
      background-color: var(--ctp-base);
      background-image: 
        radial-gradient(circle at 15% 50%, rgba(245, 194, 231, 0.08) 0%, transparent 50%),
        radial-gradient(circle at 85% 30%, rgba(203, 166, 247, 0.08) 0%, transparent 50%);
      background-attachment: fixed;
      overflow-x: hidden;
      line-height: 1.5;
    }

    .dashboard {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 32px;
      max-width: 1400px;
      margin: 0 auto;
      padding: 40px;
      min-height: 100dvh;
      align-items: start;
    }

    .hero-pane {
      position: sticky;
      top: 40px;
      display: flex;
      flex-direction: column;
      background: var(--ctp-mantle);
      padding: 40px;
      border-radius: var(--md-radius-l);
      box-shadow: var(--md-elevation);
    }

    h1.title {
      margin: 0 0 12px 0;
      font-weight: 700;
      font-size: clamp(32px, 4vw, 48px);
      color: var(--ctp-pink);
      letter-spacing: -0.5px;
    }

    .subtitle {
      margin: 0 0 32px 0;
      color: var(--ctp-subtext1);
      font-size: 1.1rem;
    }

    .cta-column {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: auto;
    }

    .cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      text-decoration: none;
      padding: 0 24px;
      height: 48px;
      border-radius: 9999px;
      font-weight: 600;
      font-size: 15px;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
    }

    .cta::after {
      content: "";
      position: absolute;
      inset: 0;
      background: currentColor;
      opacity: 0;
      transition: var(--transition);
    }

    .cta:hover::after {
      opacity: 0.08;
    }

    .cta.primary {
      background: var(--ctp-pink);
      color: var(--ctp-crust);
    }

    .cta.ghost {
      background: transparent;
      color: var(--ctp-pink);
      border: 1px solid var(--ctp-surface2);
    }

    .apps {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }

    .card {
      position: relative;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: var(--ctp-text);
      background: var(--ctp-surface0);
      border-radius: var(--md-radius-m);
      padding: 24px;
      transition: var(--transition);
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      background-color: var(--ctp-pink);
      opacity: 0;
      transition: var(--transition);
      z-index: 1;
    }

    .card:hover {
      background: var(--ctp-surface1);
      transform: translateY(-2px);
      box-shadow: var(--md-elevation);
    }

    .card:hover::before {
      opacity: 0.04;
    }

    .card:focus-visible {
      outline: 2px solid var(--ctp-pink);
      outline-offset: 2px;
    }

    .card > * {
      position: relative;
      z-index: 2;
    }

    .row {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 12px;
    }
    
    .badge {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border-radius: var(--md-radius-s);
      background: var(--ctp-mantle);
      color: var(--ctp-pink);
      font-size: 20px;
      transition: var(--transition);
    }

    .card:hover .badge {
      background: var(--ctp-pink);
      color: var(--ctp-crust);
    }

    .name {
      font-weight: 600;
      font-size: 1.15rem;
      letter-spacing: 0.1px;
    }

    .hint {
      color: var(--ctp-subtext0);
      font-size: 0.95rem;
    }

    .ext {
      position: absolute;
      top: 24px;
      right: 24px;
      color: var(--ctp-surface2);
      transition: var(--transition);
      z-index: 2;
    }

    .card:hover .ext {
      color: var(--ctp-pink);
    }

    .e2e-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      background: rgba(166, 227, 161, 0.15);
      color: var(--ctp-green);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 9999px;
      text-transform: uppercase;
      z-index: 2;
    }

    @media (prefers-reduced-motion: reduce) {
      *, ::after, ::before { transition: none !important; animation: none !important; }
    }
    
    @media (max-width: 900px) {
      .dashboard { grid-template-columns: 1fr; padding: 20px; gap: 24px; }
      .hero-pane { position: relative; top: 0; padding: 32px 24px; }
      .cta-column { flex-direction: row; flex-wrap: wrap; margin-top: 24px; }
      .cta { flex: 1; min-width: max-content; }
    }
  </style>
</head>
<body>

  <div class="dashboard">
    
    <aside class="hero-pane" aria-labelledby="title">
      <h1 id="title" class="title">Poke Apps</h1>
      <p class="subtitle">YouTube front-end, translator, maps, notes, calendar, and more! Designed with privacy in mind.</p>
      
      <div class="cta-column">
        <a class="cta primary" href="/app">
          <i class="fa-solid fa-compass"></i> Discover!
        </a>
        <a class="cta ghost" href="#apps">
          <i class="fa-solid fa-grid-2"></i> Browse Apps
        </a>
      </div>
    </aside>

    <main id="apps" class="apps" aria-label="Apps">
      
      <a class="card" href="/game-hub" aria-label="Games">
        <div class="row">
          <span class="badge"><i class="fa-solid fa-gamepad"></i></span>
          <span class="name">Games</span>
        </div>
        <span class="hint">Amazing games :3</span>
      </a>

      <a class="card" href="/translate" aria-label="Translate">
        <div class="row">
          <span class="badge"><i class="fa-solid fa-language"></i></span>
          <span class="name">Translate</span>
        </div>
        <span class="hint">Fast & accurate free software translation!!</span>
      </a>

      <a class="card" href="/map" aria-label="Maps">
        <div class="row">
          <span class="badge"><i class="fa-solid fa-map-location-dot"></i></span>
          <span class="name">Maps</span>
        </div>
        <span class="hint">A good map-view for the web!</span>
      </a>

      <a class="card" href="https://social.poketube.fun" target="_blank" rel="noopener" aria-label="Fediverse">
        <span class="ext"><i class="fa-solid fa-arrow-up-right-from-square"></i></span>
        <div class="row">
          <span class="badge"><i class="fa-brands fa-mastodon"></i></span>
          <span class="name">Fediverse</span>
        </div>
        <span class="hint">Poke Social community</span>
      </a>

      <a class="card" href="/calendar" aria-label="Calendar">
        <div class="row">
          <span class="badge"><i class="fa-solid fa-calendar"></i></span>
          <span class="name">Calendar</span>
        </div>
        <span class="hint">NO javascript!!! calendar :3</span>
      </a>

      <a class="card" href="/notepad" aria-label="Pokepad">
        <span class="e2e-badge">E2E</span>
        <div class="row">
          <span class="badge"><i class="fa-solid fa-memo-pad"></i></span>
          <span class="name">Pokepad!</span>
        </div>
        <span class="hint">End-to-End Encrypted Feature rich web Notepad!</span>
      </a>

      <a class="card" href="/app" aria-label="Watch">
        <div class="row">
          <span class="badge"><i class="fa-solid fa-play"></i></span>
          <span class="name">Watch</span>
        </div>
        <span class="hint">The biggest part of Poke - the best-looking YouTube front end ever!</span>
      </a>

      <a class="card" href="/settings" aria-label="Settings">
        <div class="row">
          <span class="badge"><i class="fa-solid fa-gear"></i></span>
          <span class="name">Settings</span>
        </div>
        <span class="hint">Settings lol idk wha to tell ya mate</span>
      </a>

    </main>
  </div>

  <script>
    (function(){
      const cards = Array.from(document.querySelectorAll('.card'));
      cards.forEach(c => c.tabIndex = 0);
      
      const getGridCols = () => {
        const grid = document.querySelector('.apps');
        if (!grid) return 1;
        const colWidth = 280;
        const gap = 16;
        const available = grid.clientWidth;
        return Math.floor((available + gap) / (colWidth + gap)) || 1;
      };

      cards.forEach((el, idx) => {
        el.addEventListener('keydown', e => {
          const cols = getGridCols();
          let t = null;
          
          if(e.key === 'ArrowRight') t = (idx + 1) % cards.length;
          else if(e.key === 'ArrowLeft') t = (idx - 1 + cards.length) % cards.length;
          else if(e.key === 'ArrowDown') t = Math.min(cards.length - 1, idx + cols);
          else if(e.key === 'ArrowUp') t = Math.max(0, idx - cols);
          else if(e.key === 'Home') t = 0;
          else if(e.key === 'End') t = cards.length - 1;
          else if(e.key === 'Enter' || e.key === ' ') { 
            e.preventDefault(); 
            el.click(); 
            return; 
          }
          
          if(t !== null){ 
            e.preventDefault(); 
            cards[t].focus(); 
          }
        });
      });
    })();
  </script>
</body>
</html>