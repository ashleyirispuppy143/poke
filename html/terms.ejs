  <div id="policy-modal" class="modal-overlay" aria-hidden="true">
    <div class="modal-window" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <button class="modal-close" aria-label="Close modal">&times;</button>
      <h3 id="modal-title" class="modal-title"></h3>
      <div id="modal-body" class="modal-body"></div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const modal = document.getElementById('policy-modal');
      const modalTitle = document.getElementById('modal-title');
      const modalBody = document.getElementById('modal-body');
      const closeBtn = modal.querySelector('.modal-close');
      const summaries = document.querySelectorAll('.policy-card summary');

      // Function to open the modal and lock background scrolling
      function openModal(title, contentHTML) {
        modalTitle.textContent = title;
        modalBody.innerHTML = contentHTML;
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden'; 
      }

      // Function to close the modal and restore background
      function closeModal() {
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        
        // Wait for animation to finish before clearing content
        setTimeout(() => { 
          if(!modal.classList.contains('active')) {
            modalBody.innerHTML = ''; 
          }
        }, 300);
      }

      // Intercept clicks on our policy cards
      summaries.forEach(summary => {
        summary.addEventListener('click', (e) => {
          // Prevent the default `<details>` dropdown action since JS is available
          e.preventDefault(); 
          
          const details = summary.parentElement;
          const title = summary.textContent.trim();
          const contentNode = details.querySelector('.content-inner');
          
          if (contentNode) {
            openModal(title, contentNode.innerHTML);
          }
        });
      });

      // Handle URL Query Parameters (e.g. ?policy=Warranty)
      const urlParams = new URLSearchParams(window.location.search);
      const targetPolicy = urlParams.get('policy');
      
      if (targetPolicy) {
        // Normalize the search string to lower case and handle spaces/hyphens
        const normalizedTarget = targetPolicy.toLowerCase().replace(/-/g, ' ');
        
        // Find matching policy card by data attribute or summary text
        const matchedDetails = Array.from(document.querySelectorAll('.policy-card')).find(card => {
          const dataPolicy = card.getAttribute('data-policy');
          const titleText = card.querySelector('summary').textContent.toLowerCase();
          
          return (dataPolicy && dataPolicy.includes(normalizedTarget)) || titleText.includes(normalizedTarget);
        });

        if (matchedDetails) {
          // Programmatically click the summary to trigger the modal logic above
          matchedDetails.querySelector('summary').click();
          
          // Optionally smooth scroll to the section so users see where it came from under the modal overlay
          matchedDetails.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      // Close events
      closeBtn.addEventListener('click', closeModal);
      
      modal.addEventListener('click', (e) => {
        // Only close if clicking the dark overlay area, not the white box
        if (e.target === modal) {
          closeModal();
        }
      });
      
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          closeModal();
        }
      });
    });
  </script>
