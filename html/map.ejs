<script>
;(() => {
  const mapState = { lat: 30.41, lon: 72.44, delta: 0.25, layer: 'mapnik', following: false };
  let savedPins = [];
  try { savedPins = JSON.parse(localStorage.getItem('pm_pins') || '[]'); } catch(e){}

  const select = (s) => document.querySelector(s);

  const ui = {
    mapFrame: select('#map'),
    centerMarker: select('#center-marker'),
    desktopSearch: select('#d-search'),
    desktopSuggestions: select('#d-suggestions'),
    desktopLocate: select('#d-locate'),
    desktopSavePin: select('#d-save-pin'),
    desktopPinList: select('#d-pin-list'),
    desktopLayer: select('#d-layer'),
    desktopFollow: select('#d-follow'),
    desktopTheme: select('#d-theme'),
    desktopShare: select('#d-share'),
    desktopMarkerSize: select('#d-m-size'),
    desktopMarkerColor: select('#d-m-color'),
    desktopPinsButton: select('#d-btn-pins'),
    desktopSettingsButton: select('#d-btn-settings'),
    pinsPopover: select('#pop-pins'),
    settingsPopover: select('#pop-settings'),
    mobileSearchButton: select('#m-btn-search'),
    mobileSearch: select('#m-search'),
    mobileSuggestions: select('#m-suggestions'),
    mobileLocate: select('#m-btn-locate'),
    mobilePinsButton: select('#m-btn-pins'),
    mobileMenuButton: select('#m-btn-menu'),
    mobileSave: select('#m-save-curr'),
    mobilePinList: select('#m-pin-list'),
    mobileLayer: select('#m-layer'),
    mobileFollow: select('#m-follow'),
    mobileTheme: select('#m-theme'),
    searchSheet: select('#sheet-search'),
    pinsSheet: select('#sheet-pins'),
    menuSheet: select('#sheet-menu')
  };

  const refreshMap = (pushHistory = false) => {
    mapState.delta = Math.max(0.0005, Math.min(45, mapState.delta));
    const bbox = {
      l: (mapState.lon - mapState.delta).toFixed(6),
      b: (mapState.lat - mapState.delta).toFixed(6),
      r: (mapState.lon + mapState.delta).toFixed(6),
      t: (mapState.lat + mapState.delta).toFixed(6)
    };

    const src = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox.l}%2C${bbox.b}%2C${bbox.r}%2C${bbox.t}&layer=${mapState.layer}`;
    if (ui.mapFrame.src !== src) ui.mapFrame.src = src;

    if (pushHistory) {
      const url = new URL(location);
      url.searchParams.set('lat', mapState.lat.toFixed(5));
      url.searchParams.set('lon', mapState.lon.toFixed(5));
      url.searchParams.set('d', mapState.delta.toFixed(4));
      url.searchParams.set('l', mapState.layer);
      history.pushState(mapState, '', url);
    }

    if(ui.desktopLayer.value !== mapState.layer) ui.desktopLayer.value = mapState.layer;
    if(ui.mobileLayer.value !== mapState.layer) ui.mobileLayer.value = mapState.layer;

    ui.desktopFollow.checked = mapState.following;
    ui.mobileFollow.checked = mapState.following;
  };

  let searchTimer;

  const performSearch = (value, list) => {
    if (!value || value.length < 3) {
      list.style.display = 'none';
      return;
    }

    const coords = value.match(/([+-]?\d+\.?\d*)\s*,\s*([+-]?\d+\.?\d*)/);
    if(coords) {
      const lat = parseFloat(coords[1]);
      const lon = parseFloat(coords[2]);

      list.innerHTML = `
        <li onclick="goTo(${lat},${lon})">
          <div class="sug-icon"><svg class="icon"><use href="#icon-loc"/></svg></div>
          <div class="sug-text">
            <span class="sug-title">${lat.toFixed(4)}, ${lon.toFixed(4)}</span>
            <span class="sug-sub">Coordinates</span>
          </div>
        </li>`;
      list.style.display = 'block';
      return;
    }

    clearTimeout(searchTimer);

    searchTimer = setTimeout(async () => {
      try {
        const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(value)}`);
        const data = await res.json();

        list.innerHTML = '';
        if(!data.length) {
          list.style.display = 'none';
          return;
        }

        data.slice(0,5).forEach(item => {
          const parts = item.display_name.split(',');
          const title = parts[0];
          const subtitle = parts.slice(1).join(',').trim();

          const li = document.createElement('li');
          li.innerHTML = `
            <div class="sug-icon"><svg class="icon"><use href="#icon-loc"/></svg></div>
            <div class="sug-text">
              <span class="sug-title">${title}</span>
              <span class="sug-sub">${subtitle}</span>
            </div>
          `;

          li.onclick = () => {
            goTo(parseFloat(item.lat), parseFloat(item.lon));
            list.style.display = 'none';
            ui.desktopSearch.value = title;
            ui.mobileSearch.value = title;
            closeAllPanels();
          };

          list.appendChild(li);
        });

        list.style.display = 'block';
      } catch(e){}
    }, 400);
  };

  window.goTo = (lat, lon) => {
    mapState.lat = lat;
    mapState.lon = lon;
    mapState.following = false;
    refreshMap(true);
  };

  let geoWatchId = null;

  const toggleFollowLocation = () => {
    if (mapState.following) {
      mapState.following = false;
      if (geoWatchId) navigator.geolocation.clearWatch(geoWatchId);
      refreshMap();
    } else {
      if (!navigator.geolocation) return alert("Geolocation not supported");

      mapState.following = true;

      geoWatchId = navigator.geolocation.watchPosition(
        p => {
          mapState.lat = p.coords.latitude;
          mapState.lon = p.coords.longitude;
          refreshMap();
        },
        () => {
          mapState.following = false;
          refreshMap();
          alert("Location access denied");
        },
        { enableHighAccuracy: true }
      );

      refreshMap();
    }
  };

  const locateOnce = () => {
    navigator.geolocation.getCurrentPosition(
      p => {
        mapState.lat = p.coords.latitude;
        mapState.lon = p.coords.longitude;
        mapState.delta = 0.01;
        refreshMap(true);
      },
      () => alert("Could not locate")
    );
  };

  const renderPinList = () => {
    const html = savedPins.length
      ? savedPins.map((p, i) => `
        <div class="pin-item">
          <div class="pin-info">
            <strong>${p.name}</strong>
            <span>${p.lat.toFixed(4)}, ${p.lon.toFixed(4)}</span>
          </div>
          <div class="pin-actions">
            <button class="pin-btn" onclick="loadPin(${i})">Go</button>
            <button class="pin-btn del" onclick="delPin(${i})">✕</button>
          </div>
        </div>
      `).join('')
      : '<div style="text-align:center; opacity:0.6; padding:20px; font-size:14px">No saved pins</div>';

    ui.desktopPinList.innerHTML = html;
    ui.mobilePinList.innerHTML = html;
  };

  window.loadPin = (i) => {
    mapState.lat = savedPins[i].lat;
    mapState.lon = savedPins[i].lon;
    mapState.layer = savedPins[i].layer || 'mapnik';
    refreshMap(true);
    closeAllPanels();
  };

  window.delPin = (i) => {
    if(confirm("Remove pin?")){
      savedPins.splice(i,1);
      localStorage.setItem('pm_pins', JSON.stringify(savedPins));
      renderPinList();
    }
  };

  const saveCurrentPin = () => {
    const name = prompt("Name this location:", "New Place");
    if(name) {
      savedPins.unshift({
        name,
        lat: mapState.lat,
        lon: mapState.lon,
        layer: mapState.layer
      });

      localStorage.setItem('pm_pins', JSON.stringify(savedPins));
      renderPinList();
    }
  };

  const updateMarkerStyle = () => {
    document.documentElement.style.setProperty('--marker-size', ui.desktopMarkerSize.value + 'px');
    document.documentElement.style.setProperty('--marker-color', ui.desktopMarkerColor.value);
  };

  ui.desktopMarkerSize.oninput = updateMarkerStyle;
  ui.desktopMarkerColor.oninput = updateMarkerStyle;

  const setTheme = (theme) => {
    document.body.classList.toggle('light-mode', theme === 'light');
    ui.desktopTheme.value = theme;
    ui.mobileTheme.value = theme;
  };

  const closeAllPanels = () => {
    document.querySelectorAll('.bottom-sheet').forEach(s => s.classList.remove('open'));
    document.querySelectorAll('.popover').forEach(p => p.classList.remove('open'));

    ui.desktopPinsButton.classList.remove('active');
    ui.desktopSettingsButton.classList.remove('active');
  };

  const toggleSheet = (sheet) => {
    const open = sheet.classList.contains('open');
    closeAllPanels();
    if(!open) sheet.classList.add('open');
  };

  const togglePopover = (popover, button) => {
    const open = popover.classList.contains('open');
    closeAllPanels();

    if(!open) {
      popover.classList.add('open');
      button.classList.add('active');
    }
  };

  ui.desktopSearch.oninput = e => performSearch(e.target.value, ui.desktopSuggestions);
  ui.mobileSearch.oninput = e => performSearch(e.target.value, ui.mobileSuggestions);

  ui.desktopLocate.onclick = locateOnce;
  ui.mobileLocate.onclick = locateOnce;

  ui.desktopSavePin.onclick = saveCurrentPin;
  ui.mobileSave.onclick = saveCurrentPin;

  ui.desktopShare.onclick = () => {
    navigator.clipboard.writeText(location.href);
    alert("Link copied!");
  };

  ui.desktopLayer.onchange = e => {
    mapState.layer = e.target.value;
    refreshMap(true);
  };

  ui.mobileLayer.onchange = e => {
    mapState.layer = e.target.value;
    refreshMap(true);
  };

  ui.desktopFollow.onchange = toggleFollowLocation;
  ui.mobileFollow.onchange = toggleFollowLocation;

  ui.desktopTheme.onchange = e => setTheme(e.target.value);
  ui.mobileTheme.onchange = e => setTheme(e.target.value);

  ui.desktopPinsButton.onclick = e => {
    e.stopPropagation();
    togglePopover(ui.pinsPopover, ui.desktopPinsButton);
  };

  ui.desktopSettingsButton.onclick = e => {
    e.stopPropagation();
    togglePopover(ui.settingsPopover, ui.desktopSettingsButton);
  };

  ui.pinsPopover.onclick = e => e.stopPropagation();
  ui.settingsPopover.onclick = e => e.stopPropagation();

  ui.mobileSearchButton.onclick = () => {
    toggleSheet(ui.searchSheet);
    setTimeout(() => ui.mobileSearch.focus(), 100);
  };

  ui.mobilePinsButton.onclick = () => toggleSheet(ui.pinsSheet);
  ui.mobileMenuButton.onclick = () => toggleSheet(ui.menuSheet);

  document.body.onclick = (e) => {
    if(!e.target.closest('.bottom-sheet') &&
       !e.target.closest('.mobile-dock') &&
       !e.target.closest('.mobile-search-fab') &&
       !e.target.closest('.gm-search-box') &&
       !e.target.closest('.gm-tool-stack')) closeAllPanels();

    if(!e.target.closest('.gm-search-box') &&
       !e.target.closest('.m-input-container')) {
      ui.desktopSuggestions.style.display = 'none';
    }
  };

  const params = new URLSearchParams(location.search);

  if(params.has('lat')) {
    mapState.lat = parseFloat(params.get('lat'));
    mapState.lon = parseFloat(params.get('lon'));
  }

  if(params.has('l')) mapState.layer = params.get('l');

  setTheme('dark');
  renderPinList();
  refreshMap();
  updateMarkerStyle();
})();
</script>
</body>
</html>