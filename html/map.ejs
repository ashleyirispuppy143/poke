<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>PokeMaps</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no" />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#202124" />
    <link rel="preconnect" href="https://fonts.bunny.net">
  <link href="https://fonts.bunny.net/css?family=roboto:400,500,700&display=swap" rel="stylesheet">
  <style>
    :root {
      --accent: #8ab4f8;
      --accent-hover: #aecbfa;
      --bg: #202124;
      --panel-bg: #202124;
      --panel-hover: #303134;
      --border: #3c4043;
      --text-main: #e8eaed;
      --text-sub: #9aa0a6;
      --danger: #f28b82;
      --radius: 8px;
      --shadow: 0 1px 2px rgba(0,0,0,0.3), 0 2px 6px 2px rgba(0,0,0,0.15);
      --font: 'Roboto', system-ui, sans-serif;
      --marker-size: 20px;
      --marker-color: #ef4444;
    } 
    body.light-mode {
      --bg: #f8f9fa;
      --panel-bg: #ffffff;
      --panel-hover: #f1f3f4;
      --border: #dadce0;
      --text-main: #202124;
      --text-sub: #5f6368;
      --accent: #1a73e8;
      --accent-hover: #174ea6;
      --danger: #d93025;
      --shadow: 0 1px 2px rgba(60,64,67,0.3), 0 2px 6px 2px rgba(60,64,67,0.15);
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { height: 100%; margin: 0; padding: 0; overflow: hidden; }
    body { font-family: var(--font); background: var(--bg); color: var(--text-main); }
    button { font-family: inherit; }
    svg.icon { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .app-shell { position: relative; width: 100%; height: 100%; }
    #map-container { position: absolute; inset: 0; z-index: 0; background: var(--bg); }
    iframe#map { width: 100%; height: 100%; border: 0; display: block; }
    .brand {
      position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
      padding: 6px 12px; font-size: 13px; font-weight: 500; opacity: 0.9;
      background: var(--panel-bg); color: var(--text-main);
      border-radius: 16px; box-shadow: var(--shadow);
      pointer-events: none; z-index: 5;
    } 
    .marker-overlay { position: absolute; inset: 0; pointer-events: none; z-index: 10; display: flex; align-items: center; justify-content: center; }
    .center-marker {
      width: var(--marker-size); height: var(--marker-size); border-radius: 50%;
      background: var(--marker-color);
      box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.4), 0 4px 8px rgba(0,0,0,0.4);
      transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .center-marker::after {
      content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 4px; height: 4px; background: rgba(0,0,0,0.6); border-radius: 50%;
    }
    .ui-layer { position: absolute; inset: 0; z-index: 20; pointer-events: none; }
    .ui-layer > * { pointer-events: auto; } 
    .btn {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      border: none; background: transparent; color: var(--text-main);
      border-radius: var(--radius); padding: 8px 16px; font-size: 14px; font-weight: 500;
      cursor: pointer; transition: background 0.2s;
    }
    .btn:hover { background: var(--panel-hover); }
    .btn-filled {
      background: var(--accent); color: var(--bg); border: none; border-radius: var(--radius);
      padding: 8px 16px; font-weight: 500; font-size: 14px; cursor: pointer; transition: background 0.2s;
    }
    .btn-filled:hover { background: var(--accent-hover); }
    .suggestions {
      background: var(--panel-bg);
      border-radius: var(--radius);
      margin: 8px 0 0 0; padding: 8px 0; list-style: none;
      box-shadow: var(--shadow); max-height: 400px; overflow-y: auto; display: none;
      animation: slideDown 0.2s ease-out; z-index: 1000;
    }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    .suggestions li {
      padding: 12px 16px; cursor: pointer;
      display: flex; align-items: center; gap: 16px;
    }
    .suggestions li:hover { background: var(--panel-hover); }
    .sug-icon { color: var(--text-sub); display: flex; align-items: center; }
    .sug-text { display: flex; flex-direction: column; overflow: hidden; }
    .sug-title { font-weight: 500; font-size: 14px; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sug-sub { font-size: 13px; color: var(--text-sub); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
    .gm-tool-stack { display: flex; flex-direction: column; gap: 0; background: var(--panel-bg); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
    .gm-fab {
      width: 40px; height: 40px; border: none; background: transparent; color: var(--text-sub);
      display: flex; align-items: center; justify-content: center; cursor: pointer;
      border-bottom: 1px solid var(--border); transition: color 0.2s, background 0.2s;
    }
    .gm-fab:last-child { border-bottom: none; }
    .gm-fab:hover { background: var(--panel-hover); color: var(--text-main); }
    .gm-fab.active { color: var(--accent); }
    .popover {
      position: absolute; right: 56px; 
      width: 320px; background: var(--panel-bg);
      border-radius: var(--radius); box-shadow: var(--shadow); padding: 16px;
      display: none; flex-direction: column; gap: 12px;
    }
    .popover.open { display: flex; }
    .popover-header { font-weight: 500; font-size: 16px; border-bottom: 1px solid var(--border); padding-bottom: 12px; margin-bottom: 4px; display: flex; justify-content: space-between; align-items: center; }
    .row { display: flex; justify-content: space-between; align-items: center; }
    .disclaimer { font-size: 11px; color: var(--text-sub); line-height: 1.4; margin-top: 8px; font-style: italic; }

    @media (min-width: 769px) {
      .mobile-only { display: none !important; } 
      .absolute-top-left {
        position: absolute; top: 16px; left: 16px; width: 380px; z-index: 50;
      }
      .gm-search-box {
        background: var(--panel-bg); border-radius: 24px; box-shadow: var(--shadow);
        display: flex; align-items: center; height: 48px; padding: 0 16px;
      }
      .brand-text { font-weight: 700; font-size: 15px; color: var(--accent); white-space: nowrap; margin-right: 12px; }
      .search-divider { width: 1px; height: 28px; background: var(--border); margin-right: 12px; }
      .search-input {
        flex: 1; border: none; background: transparent; color: var(--text-main);
        font-size: 15px; outline: none; width: 100%;
      }
      .search-input::placeholder { color: var(--text-sub); }
      .search-icon-btn { background: transparent; border: none; color: var(--text-sub); cursor: pointer; display: flex; padding: 0; }
      .absolute-bottom-right {
        position: absolute; bottom: 24px; right: 16px; z-index: 50;
        display: flex; flex-direction: column; align-items: flex-end; gap: 16px;
      }
      #pop-settings { bottom: 0; }
      #pop-pins { bottom: 82px; }
    }

    @media (max-width: 768px) {
      .desktop-only { display: none !important; }
      .brand { display: none !important; }
      .mobile-search-fab {
        position: absolute; top: 16px; right: 16px; z-index: 30;
        width: 48px; height: 48px; border-radius: 50%; border: none;
        background: var(--panel-bg); box-shadow: var(--shadow);
        display: flex; align-items: center; justify-content: center;
        color: var(--text-main); cursor: pointer;
      }
      .mobile-dock {
        position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
        display: flex; align-items: center; gap: 8px;
        background: var(--panel-bg); padding: 8px 16px; border-radius: 32px;
        box-shadow: var(--shadow); z-index: 30;
      }
      .dock-btn { background: none; border: none; color: var(--text-sub); padding: 12px 20px; border-radius: 24px; cursor: pointer; }
      .dock-btn:active { background: var(--panel-hover); }
      .dock-btn.main { background: var(--accent); color: var(--bg); padding: 12px 24px; }
      .bottom-sheet {
        position: fixed; left: 0; right: 0; bottom: 0;
        background: var(--panel-bg); border-radius: 16px 16px 0 0;
        box-shadow: 0 -4px 16px rgba(0,0,0,0.2);
        z-index: 40; transform: translateY(110%);
        transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1);
        max-height: 85vh; display: flex; flex-direction: column;
      }
      .bottom-sheet.open { transform: translateY(0); }
      .sheet-handle { width: 32px; height: 4px; background: var(--border); border-radius: 4px; margin: 12px auto; }
      .sheet-content { padding: 16px 24px 40px; overflow-y: auto; }
      .m-input-container {
        display: flex; align-items: center; background: var(--bg);
        border: 1px solid var(--border); border-radius: var(--radius);
        padding: 0 16px; height: 48px; margin-bottom: 12px;
      }
      .m-input-container input { flex: 1; background: transparent; border: none; outline: none; color: var(--text-main); font-size: 15px; margin-left: 12px; }
      #m-suggestions { position: static; box-shadow: none; border: 1px solid var(--border); }
    }
    .pin-item { padding: 12px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
    .pin-info strong { display: block; font-size: 14px; margin-bottom: 4px; color: var(--text-main); }
    .pin-info span { font-size: 12px; color: var(--text-sub); }
    .pin-actions { display: flex; gap: 8px; }
    .pin-btn { background: var(--panel-hover); border: none; border-radius: 4px; padding: 6px 10px; color: var(--text-main); cursor: pointer; font-size: 12px; }
    .pin-btn.del { color: var(--danger); }
    select.std-select { width: 100%; padding: 10px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--bg); color: var(--text-main); outline: none; }
    input[type="range"] { accent-color: var(--accent); width: 120px; }
    input[type="color"] { background: none; border: 1px solid var(--border); border-radius: 4px; width: 32px; height: 32px; cursor: pointer; }
    label { font-size: 14px; color: var(--text-main); font-weight: 500; }
    .link-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 12px; }
    .link-pill { font-size: 12px; color: var(--accent); text-decoration: none; font-weight: 500; }
  </style>
</head>
<body>
<div style="display:none">
  <svg id="icons">
    <symbol id="icon-search" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></symbol>
    <symbol id="icon-nav" viewBox="0 0 24 24"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></symbol>
    <symbol id="icon-menu" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></symbol>
    <symbol id="icon-pin" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></symbol>
    <symbol id="icon-settings" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></symbol>
    <symbol id="icon-share" viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></symbol>
    <symbol id="icon-loc" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"></path><circle cx="12" cy="9" r="2.5"></circle></symbol>
  </svg>
</div>

<div class="app-shell">
  <div id="map-container">
    <iframe id="map" title="Map"></iframe>
    <div class="marker-overlay">
      <div id="center-marker" class="center-marker"></div>
    </div>
    <div class="brand">PokeMaps!</div>
  </div>

  <div class="ui-layer">
    <div class="desktop-only absolute-top-left">
      <div class="gm-search-box">
         <input type="text" id="d-search" class="search-input" placeholder="Search Poke Maps..." autocomplete="off">
        <button class="search-icon-btn" id="d-search-btn"><svg class="icon"><use href="#icon-search"/></svg></button>
      </div>
      <ul id="d-suggestions" class="suggestions"></ul>
    </div>

    <div class="desktop-only absolute-bottom-right">
      <div class="popover" id="pop-pins">
        <div class="popover-header">
          <span>Saved Locations</span>
          <button class="btn-filled" style="padding: 6px 12px; font-size: 13px;" id="d-save-pin">+ Save</button>
        </div>
        <div id="d-pin-list" style="max-height: 300px; overflow-y: auto; margin-top: 8px;"></div>
      </div>

      <div class="popover" id="pop-settings">
        <div class="popover-header">Map Settings</div>
        <div style="display:flex; flex-direction:column; gap:16px; margin-top: 8px;">
          <div>
            <label style="display:block; margin-bottom:6px;">Map Layer</label>
            <select id="d-layer" class="std-select">
              <option value="mapnik">Standard</option>
              <option value="cyclemap">Cyclist</option>
              <option value="transportmap">Transport</option>
              <option value="hot">Humanitarian</option>
            </select>
          </div>
          <div class="row"><label>Follow Location</label><input type="checkbox" id="d-follow" style="width:18px; height:18px; accent-color:var(--accent);"></div>
          <div class="row">
            <label>Theme</label>
            <select id="d-theme" class="std-select" style="width:120px;">
              <option value="dark">Dark</option>
              <option value="light">Light</option>
            </select>
          </div>
          <hr style="border:0; border-top:1px solid var(--border); margin:0;">
          <div class="row"><label>Marker Size</label><input type="range" id="d-m-size" min="10" max="50" value="20"></div>
          <div class="row"><label>Marker Color</label><input type="color" id="d-m-color" value="#ef4444"></div>
          
          <div class="disclaimer">
            Content is not proxied and 3rd party domains may be used. By using this service, you agree to the OpenStreetMap Terms of Service.
          </div>

          <div class="link-row" style="padding-top:8px; border-top:1px solid var(--border);">
            <a href="/privacy" class="link-pill">Privacy</a>
            <a href="https://wiki.osmfoundation.org/wiki/Terms_of_Use" target="_blank" class="link-pill">Terms</a>
            <a href="https://www.openstreetmap.org/copyright" target="_blank" class="link-pill">Data © OSM</a>
          </div>
        </div>
      </div>

      <div class="gm-tool-stack">
        <button class="gm-fab" id="d-locate" title="Locate Me"><svg class="icon"><use href="#icon-loc"/></svg></button>
      </div>
      <div class="gm-tool-stack">
        <button class="gm-fab" id="d-btn-pins" title="Saved Pins"><svg class="icon"><use href="#icon-pin"/></svg></button>
        <button class="gm-fab" id="d-btn-settings" title="Settings"><svg class="icon"><use href="#icon-settings"/></svg></button>
        <button class="gm-fab" id="d-share" title="Share Link"><svg class="icon"><use href="#icon-share"/></svg></button>
      </div>
    </div>

    <button class="mobile-only mobile-search-fab" id="m-btn-search"><svg class="icon"><use href="#icon-search"/></svg></button>
    <div class="mobile-only mobile-dock">
      <button class="dock-btn" id="m-btn-pins"><svg class="icon"><use href="#icon-pin"/></svg></button>
      <button class="dock-btn main" id="m-btn-locate"><svg class="icon"><use href="#icon-nav"/></svg></button>
      <button class="dock-btn" id="m-btn-menu"><svg class="icon"><use href="#icon-menu"/></svg></button>
    </div>

    <div class="mobile-only bottom-sheet" id="sheet-search">
      <div class="sheet-handle"></div>
      <div class="sheet-content">
        <div class="m-input-container">
          <svg class="icon" style="color:var(--text-sub)"><use href="#icon-search"/></svg>
          <input type="text" id="m-search" placeholder="Search places..." autocomplete="off">
        </div>
        <ul id="m-suggestions" class="suggestions"></ul>
      </div>
    </div>

    <div class="mobile-only bottom-sheet" id="sheet-pins">
      <div class="sheet-handle"></div>
      <div class="sheet-content">
        <div class="row" style="margin-bottom:16px;">
          <span style="font-size:18px; font-weight:500;">Saved Pins</span>
          <button class="btn-filled" id="m-save-curr" style="padding:8px 16px;">+ Save</button>
        </div>
        <div id="m-pin-list" style="display:flex; flex-direction:column;"></div>
      </div>
    </div>

    <div class="mobile-only bottom-sheet" id="sheet-menu">
      <div class="sheet-handle"></div>
      <div class="sheet-content">
        <span style="font-size:18px; font-weight:500; display:block; margin-bottom:20px;">Map Settings</span>
        <div style="margin-bottom:24px">
          <label style="display:block; margin-bottom:8px">Map Layer</label>
          <select id="m-layer" class="std-select">
            <option value="mapnik">Standard</option>
            <option value="cyclemap">Cyclist</option>
            <option value="transportmap">Transport</option>
            <option value="hot">Humanitarian</option>
          </select>
        </div>
        <div class="row" style="padding:14px 0; border-top:1px solid var(--border)">
          <label>Follow Location</label>
          <input type="checkbox" id="m-follow" style="width:20px; height:20px; accent-color:var(--accent)">
        </div>
        <div class="row" style="padding:14px 0; border-top:1px solid var(--border)">
          <label>Theme</label>
          <select id="m-theme" class="std-select" style="width:auto">
            <option value="dark">Dark</option>
            <option value="light">Light</option>
          </select>
        </div>

        <div class="disclaimer" style="padding:14px 0; border-top:1px solid var(--border)">
          Content is not proxied and 3rd party domains may be used. By using this service, you agree to the OpenStreetMap Terms of Service.
        </div>

        <div style="margin-top:20px; padding-top:20px; border-top:1px solid var(--border)">
          <div class="link-row">
            <a class="link-pill" href="https://wiki.osmfoundation.org/wiki/Terms_of_Use">OSM Terms</a>
            <a class="link-pill" href="/privacy">Privacy Policy</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
 <script type="text/javascript">
