<%
  function calculateSlopScore(title) {
    if (!title) return 100;
    var score = 0;
    var lowerTitle = title.toLowerCase();

    var nuclearBrainrot =[
      "skibidi", "rizz", "sigma", "gyatt", "fanum tax", "mewing", 
      "looksmaxxing", "grimace shake", "baby gronk", "livvy dunne", 
      "smurf cat", "pibby", "only in ohio", "brainrot", "lankybox",
      "isquared"
    ];
    for (var i = 0; i < nuclearBrainrot.length; i++) {
      if (lowerTitle.indexOf(nuclearBrainrot[i]) !== -1) return 100; 
    }

    var mascotSlop =[
      "garten of banban", "huggy wuggy", "poppy playtime", 
      "rainbow friends", "pomni", "digital circus", "monster school",
      "friday night funkin", "fnf"
    ];
    for (var j = 0; j < mascotSlop.length; j++) {
      if (lowerTitle.indexOf(mascotSlop[j]) !== -1) score += 60;
    }

     if (lowerTitle.indexOf("roblox") !== -1) {
      var robloxTriggers =[
        "free robux", "slender", "brookhaven secret", "online dater", "mic up", "admin abuse", "sad story"
      ];
      for (var k = 0; k < robloxTriggers.length; k++) {
        if (lowerTitle.indexOf(robloxTriggers[k]) !== -1) score += 80;
      }
    }

    var clickbaitPhrases =[
      "gone wrong", "you won't believe", "literally died",
      "don't watch at 3am", "100% real", "not clickbait", "caught on camera"
    ];
    for (var l = 0; l < clickbaitPhrases.length; l++) {
      if (lowerTitle.indexOf(clickbaitPhrases[l]) !== -1) score += 40;
    }

    var letters = title.replace(/[^a-zA-Z]/g, '');
    if (letters.length > 5) {
      var caps = title.replace(/[^A-Z]/g, '');
      var capsRatio = caps.length / letters.length;
      if (capsRatio > 0.6) score += 40; 
    }

    if (/[!?]{3,}/.test(title)) score += 30;

    var emojiRegex = /[\p{Emoji_Presentation}\p{Extended_Pictographic}]/gu;
    var emojis = title.match(emojiRegex);
    if (emojis && emojis.length >= 3) score += 30;

    return score;
  }

  // Improved strict game detection rules with aliases and strict boundaries
  var GAME_RULES = [
    { id: "Minecraft", triggers: ["minecraft", "mcpe", "bedrock"] },
    { id: "Roblox", triggers: ["roblox", "bloxfruits", "brookhaven", "adopt me"] },
    { id: "Fortnite", triggers: ["fortnite", "fncs"] },
    { id: "GTA", triggers: ["gta v", "gta 5", "gta online", "grand theft auto", "gta"] },
    { id: "Valorant", triggers: ["valorant", "vct"] },
    { id: "Call of Duty", triggers: ["call of duty", "warzone", "modern warfare", "black ops"] },
    { id: "CS2", triggers: ["cs:go", "csgo", "cs2", "counter-strike"] },
    { id: "League of Legends", triggers: ["league of legends", "lol esports"] },
    { id: "Clash of Clans", triggers: ["clash of clans", "coc"] },
    { id: "Genshin Impact", triggers: ["genshin impact", "genshin"] },
    { id: "Elden Ring", triggers: ["elden ring", "shadow of the erdtree"] },
    { id: "Helldivers", triggers: ["helldivers"] },
    { id: "FNAF", triggers: ["fnaf", "five nights at freddy", "five nights at freddy's"] },
    { id: "Zelda", triggers: ["zelda", "tears of the kingdom", "breath of the wild"] },
    { id: "Pokemon", triggers: ["pokemon", "pokémon"] },
    { id: "Super Mario", triggers: ["super mario", "mario kart", "mario bros"] },
    { id: "Apex Legends", triggers: ["apex legends"] },
    { id: "Overwatch", triggers: ["overwatch"] },
    { id: "Terraria", triggers: ["terraria"] },
    { id: "Geometry Dash", triggers: ["geometry dash"] },
    { id: "Brawl Stars", triggers: ["brawl stars"] },
    { id: "Clash Royale", triggers: ["clash royale"] },
    { id: "The Sims", triggers: ["the sims", "sims 4", "sims 3"] },
    { id: "Cyberpunk 2077", triggers: ["cyberpunk 2077", "cyberpunk"] },
    { id: "World of Warcraft", triggers: ["world of warcraft", "wow classic"] }
  ];

  function escapeRegExp(string) {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function detectGame(title, author) {
    var combinedText = " " + (title || "").toLowerCase() + " | " + (author || "").toLowerCase() + " ";
    if (combinedText.trim().length <= 3) return null;
    
    for (var i = 0; i < GAME_RULES.length; i++) {
      var rule = GAME_RULES[i];
      for (var j = 0; j < rule.triggers.length; j++) {
        var trigger = rule.triggers[j];
        var regex = new RegExp("\\b" + escapeRegExp(trigger) + "\\b", "i");
        if (regex.test(combinedText)) {
          return rule.id;
        }
      }
    }
    return null;
  }

  function formatViews(num) {
    if (num === null || num === undefined) return "0";
    if (num >= 1000000) return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
    if (num >= 1000) return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
    return num.toString();
  }

  var blockedAuthors = [
      "TheBurntPeanut", "KreekCraft", "Asmongold TV  ", "Tyler & Snowi"
  ];

  var SLOP_THRESHOLD = 70; 

  var gameCounts = {};
  var isMobileVar = (typeof isMobile !== 'undefined' ? isMobile : false);

  var allSafeVideos = inv.filter(function(item) {
    if (blockedAuthors.indexOf(item.author) !== -1) return false;
    if (!item.title || item.title.trim().length < 3) return false;
    return true;
  });

  allSafeVideos.forEach(function(item) {
    item.isSlop = calculateSlopScore(item.title) >= SLOP_THRESHOLD;
    item.detectedGame = detectGame(item.title, item.author) || "Other";
    if (item.detectedGame !== "Other") {
      gameCounts[item.detectedGame] = (gameCounts[item.detectedGame] || 0) + 1;
    }
  });

  var sortedGames = Object.keys(gameCounts).sort(function(a, b) {
    return gameCounts[b] - gameCounts[a];
  });

  // Strict check: only include detected games with more than 0 videos
  var validGames = sortedGames.filter(function(g) { return gameCounts[g] > 0; });
  
  var gameFilters = validGames.slice(0, 3);
  
  // Guarantee exactly 3 tags even if no specific games are detected
  var fallbackCategories = ["Action Games", "Strategy Games", "Indie Games", "RPG", "Simulation"];
  var fallbackIndex = 0;
  while (gameFilters.length < 3) {
    if (!gameFilters.includes(fallbackCategories[fallbackIndex])) {
      gameFilters.push(fallbackCategories[fallbackIndex]);
    }
    fallbackIndex++;
  }

  var finalVideos;

  if (isMobileVar) {
    finalVideos = allSafeVideos.slice();
    for (let i = finalVideos.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [finalVideos[i], finalVideos[j]] = [finalVideos[j], finalVideos[i]];
    }
  } else {
    finalVideos = allSafeVideos.filter(function(item) {
      return !item.isSlop;
    }).slice(0, 32);
  }
%>

<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<meta charset="UTF-8">
<title>Poke | Search</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">
<meta name="twitter:title" content="Poke - The privacy app of your dreams!">
<meta name="twitter:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta name="twitter:image" content="/static/poke-embed.webp">
