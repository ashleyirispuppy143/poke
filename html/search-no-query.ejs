<script>
 (function () {
  var searchInput = document.getElementById("fname");
  var bangIndicator = document.getElementById("bang-indicator");

  if (searchInput && bangIndicator) {
    searchInput.addEventListener("input", function (e) {
      if (e.target.value.includes("!")) {
        bangIndicator.classList.remove("hidden");
        searchInput.setAttribute("autocomplete", "off"); 
      } else {
        bangIndicator.classList.add("hidden");
        searchInput.setAttribute("autocomplete", "on"); 
      }
    });
  }
})();

function toggleMobileSearch() {
  var form = document.getElementById('mobile-search-form');
  form.classList.toggle('active');
  if(form.classList.contains('active')) {
    document.getElementById('mobile-search-input').focus();
  }
}
</script>

