<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Poke</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">

<style>
@font-face{
  font-family:"PokeTube Flex";
  src:url("/static/robotoflex.ttf");
  font-style:normal;
  font-stretch:1% 800%;
  font-display:swap;
}

:root{
  --bg:#0b0c10;
  --panel:#151821;
  --panel2:#1a1d26;
  --text:#f4f6ff;
  --muted:#a7adbf;
  --border:#242836;
  --accent:#df03a8;
  --shadow:0 14px 32px rgba(0,0,0,.45);
  --radius:18px;
}

*{box-sizing:border-box}

body{
  margin:0;
  min-height:100vh;
  background:
    radial-gradient(1200px 600px at 50% -10%, rgba(223,3,168,.20), transparent 55%),
    radial-gradient(900px 500px at 12% 18%, rgba(124,77,255,.14), transparent 60%),
    radial-gradient(900px 500px at 90% 22%, rgba(0,212,255,.08), transparent 62%),
    var(--bg);
  font-family:"PokeTube Flex", Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  color:var(--text);
}

.page{
  width:min(1200px,92vw);
  margin:0 auto;
  padding:42px 0 54px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:22px;
}

.hero{
  width:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:18px;
}

.logo{
  width:240px;
  max-width:70vw;
  filter: drop-shadow(0 10px 24px rgba(0,0,0,.45));
}

.search-wrap{
  width:min(680px,92vw);
}

.search-bar{
  width:100%;
  padding:14px 18px;
  font-size:16px;
  border-radius:999px;
  border:1px solid var(--border);
  background:var(--panel);
  color:var(--text);
  outline:none;
  transition:border-color .18s ease, box-shadow .18s ease;
}

.search-bar::placeholder{
  color:#8c92a6;
}

.search-bar:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 2px rgba(223,3,168,.25);
}

.section{
  width:100%;
  margin-top:12px;
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
}

.section-header{
  display:flex;
  align-items:baseline;
  justify-content:space-between;
  gap:12px;
  padding:14px 16px;
  border-bottom:1px solid var(--border);
}

.section-left{
  display:flex;
  flex-direction:column;
  gap:3px;
  min-width:0;
}

.section-title{
  font-size:16px;
  font-weight:760;
  letter-spacing:.2px;
}

.section-sub{
  font-size:13px;
  color:var(--muted);
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.section-actions{
  display:flex;
  align-items:center;
  gap:10px;
}

.toggle{
  display:inline-flex;
  align-items:center;
  gap:8px;
  cursor:pointer;
  user-select:none;
  font-size:13px;
  color:var(--muted);
}

.toggle input{
  width:16px;
  height:16px;
  margin:0;
  accent-color:var(--accent);
}

.toggle-hint{
  font-size:12px;
  color:rgba(167,173,191,.8);
}

.video-grid{
  padding:16px;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
}

@media (max-width:1100px){
  .video-grid{grid-template-columns:repeat(3,1fr);}
}

@media (max-width:820px){
  .video-grid{grid-template-columns:repeat(2,1fr);}
}

@media (max-width:520px){
  .video-grid{grid-template-columns:1fr;}
}

.video{
  display:block;
  text-decoration:none;
  color:inherit;
  border:1px solid var(--border);
  border-radius:14px;
  background:var(--panel2);
  overflow:hidden;
  transition:transform .15s ease,border-color .15s ease, box-shadow .15s ease;
  box-shadow:0 10px 24px rgba(0,0,0,.25);
}

.video:hover{
  transform:translateY(-2px);
  border-color:var(--accent);
  box-shadow:0 16px 36px rgba(0,0,0,.35);
}

.thumbnail{
  position:relative;
  width:100%;
  aspect-ratio:16/9;
  background-position:center;
  background-size:cover;
  background-repeat:no-repeat;
}

.video-length{
  position:absolute;
  right:8px;
  bottom:8px;
  font-size:12px;
  padding:4px 7px;
  border-radius:6px;
  background:rgba(0,0,0,.75);
  border:1px solid rgba(255,255,255,.08);
}

.info{
  padding:10px 12px 12px;
  display:flex;
  flex-direction:column;
  gap:5px;
}

.title{
  font-size:14px;
  font-weight:680;
  line-height:1.25;
}

.byline{
  font-size:12px;
  color:var(--muted);
}

.max-lines-2{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}

/* NO-JS toggle: checkbox controls the section via CSS only */
#toggle-discover:not(:checked) ~ .discover-body{
  display:none;
}

/* If JS is available, we can show a nicer "collapsed" state (optional) */
html.js #toggle-discover:not(:checked) ~ .discover-body{
  display:none;
}
html.js .toggle-hint{
  display:inline;
}
html.no-js .toggle-hint{
  display:none;
}

/* tiny separation between hero and section on small screens */
@media (max-width:520px){
  .page{padding:34px 0 44px;}
  .section-header{flex-direction:column; align-items:flex-start;}
  .section-actions{width:100%; justify-content:space-between;}
}
</style>

<script>
(function(){
  document.documentElement.classList.remove("no-js");
  document.documentElement.classList.add("js");

  function safeGet(key){
    try{ return localStorage.getItem(key); }catch(e){ return null; }
  }
  function safeSet(key,val){
    try{ localStorage.setItem(key,val); }catch(e){}
  }

  document.addEventListener("DOMContentLoaded", function(){
    var cb = document.getElementById("toggle-discover");
    if(!cb) return;

    var saved = safeGet("poke_discover_open");
    if(saved === "0") cb.checked = false;
    if(saved === "1") cb.checked = true;

    cb.addEventListener("change", function(){
      safeSet("poke_discover_open", cb.checked ? "1" : "0");
    });
  });
})();
</script>
</head>

<body>
<div class="page">

  <div class="hero">
    <img src="/static/logo-poke.svg" class="logo" alt="Poke Logo">

    <div class="search-wrap">
      <form action="/search" method="get">
        <input class="search-bar" autocomplete="on" id="fname" name="query" type="text" placeholder="Search...">
      </form>
    </div>
  </div>

  <section class="section" aria-label="Discover gaming videos">
    <div class="section-header">
      <div class="section-left">
        <div class="section-title">Discover gaming videos</div>
        <div class="section-sub">These are trending gaming videos</div>
      </div>

      <div class="section-actions">
        <label class="toggle" for="toggle-discover" title="Show or hide this section">
          <input id="toggle-discover" type="checkbox" checked>
          <span>Show</span>
        </label>
        <span class="toggle-hint">(remembers your choice)</span>
      </div>
    </div>

    <div class="discover-body">
      <div class="video-grid">
        <% inv.slice(0,16).forEach(x => { %>

          <a href="/watch?v=<%- x.videoId %>" class="video canloadhd" data-author="<%- x.author %>">
            <div class="thumbnail" style="background-image:url('/vi/<%= x.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
              <span class="video-length"><%- turntomins(x.lengthSeconds) %></span>
            </div>
            <div class="info">
              <span class="title max-lines-2" title="<%- x.title %>"><%- x.title %></span>
              <span class="byline max-lines-2">By <%- x.author %></span>
            </div>
          </a>

        <% }) %>
      </div>
    </div>

    <noscript>
      <style>
        html{class: no-js}
      </style>
    </noscript>
  </section>

</div>

<script>
document.documentElement.classList.add("no-js");
</script>
</body>
</html>