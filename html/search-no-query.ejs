<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Poke</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">

<style>
@font-face{
  font-family:"PokeTube Flex";
  src:url("/static/robotoflex.ttf");
  font-style:normal;
  font-stretch:1% 800%;
  font-display:swap;
}

:root{
  --bg:#0b0c10;
  --panel:#151821;
  --panel2:#1a1d26;
  --panel3:#121521;
  --text:#f4f6ff;
  --muted:#a7adbf;
  --muted2:#8c92a6;
  --border:#242836;
  --border2:#2b3041;
  --accent:#df03a8;
  --shadow:0 14px 32px rgba(0,0,0,.45);
  --shadow2:0 10px 22px rgba(0,0,0,.35);
  --radius:18px;
  --radius2:14px;
}

*{box-sizing:border-box}

html,body{height:100%}

body{
  margin:0;
  min-height:100vh;
  background:
    radial-gradient(900px 420px at 50% -10%, rgba(223,3,168,.10), transparent 60%),
    radial-gradient(800px 420px at 15% 15%, rgba(124,77,255,.08), transparent 65%),
    radial-gradient(800px 420px at 85% 15%, rgba(0,212,255,.05), transparent 65%),
    var(--bg);
  font-family:"PokeTube Flex", Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  color:var(--text);
}

a{color:inherit}

.page{
  width:min(1240px, 92vw);
  margin:0 auto;
  padding:44px 0 60px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:22px;
}

.hero{
  width:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:14px;
  padding-top:4px;
}

.logo{
  width:248px;
  max-width:72vw;
  filter: drop-shadow(0 12px 26px rgba(0,0,0,.48));
}

.tagline{
  margin-top:-4px;
  font-size:14px;
  color:rgba(244,246,255,.72);
  letter-spacing:.15px;
  text-align:center;
}

.search-wrap{
  width:min(720px, 92vw);
  margin-top:4px;
}

.search-form{
  display:flex;
  gap:10px;
  align-items:center;
}

.search-bar{
  flex:1;
  width:100%;
  padding:14px 18px;
  font-size:16px;
  border-radius:999px;
  border:1px solid var(--border);
  background:var(--panel);
  color:var(--text);
  outline:none;
  box-shadow:var(--shadow2);
  transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;
}

.search-bar::placeholder{
  color:var(--muted2);
}

.search-bar:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 2px rgba(223,3,168,.25), var(--shadow2);
  transform:translateY(-1px);
}

.quick-pill{
  display:none;
}

.section{
  width:100%;
  margin-top:10px;
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
}

.section-header{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:12px;
  padding:16px 18px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(90deg, rgba(223,3,168,.10), transparent 55%);
}

.section-head-left{
  display:flex;
  flex-direction:column;
  gap:4px;
  min-width:0;
}

.section-title{
  font-size:16px;
  font-weight:720;
  letter-spacing:.2px;
}

.section-sub{
  font-size:13px;
  color:var(--muted);
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.toggle{
  display:inline-flex;
  gap:8px;
  align-items:center;
  user-select:none;
  font-size:13px;
  color:rgba(244,246,255,.78);
  padding:8px 10px;
  border-radius:999px;
  background:var(--panel3);
  border:1px solid var(--border2);
  cursor:pointer;
  transition:border-color .16s ease, transform .16s ease;
}

.toggle:hover{
  border-color:rgba(223,3,168,.55);
  transform:translateY(-1px);
}

.toggle:active{
  transform:translateY(0);
}

.chev{
  width:10px;
  height:10px;
  display:inline-block;
  border-right:2px solid rgba(244,246,255,.7);
  border-bottom:2px solid rgba(244,246,255,.7);
  transform:rotate(45deg);
  margin-top:-2px;
}

.video-grid{
  padding:16px;
  display:grid;
  grid-template-columns:repeat(4, minmax(0, 1fr));
  gap:14px;
}

@media (max-width: 1100px){
  .video-grid{grid-template-columns:repeat(3, minmax(0, 1fr));}
}

@media (max-width: 820px){
  .video-grid{grid-template-columns:repeat(2, minmax(0, 1fr));}
}

@media (max-width: 520px){
  .video-grid{grid-template-columns:1fr;}
  .toggle{padding:7px 9px}
}

.video{
  display:block;
  text-decoration:none;
  color:inherit;
  border:1px solid var(--border);
  border-radius:var(--radius2);
  background:var(--panel2);
  overflow:hidden;
  transition:transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  box-shadow:0 6px 18px rgba(0,0,0,.25);
}

.video:hover{
  transform:translateY(-2px);
  border-color:rgba(223,3,168,.6);
  box-shadow:0 14px 30px rgba(0,0,0,.35);
}

.thumbnail{
  position:relative;
  width:100%;
  aspect-ratio:16/9;
  background-position:center;
  background-size:cover;
  background-repeat:no-repeat;
}

.thumbnail::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(180deg, transparent 62%, rgba(0,0,0,.60) 100%);
}

.video-length{
  position:absolute;
  right:8px;
  bottom:8px;
  z-index:1;
  font-size:12px;
  padding:4px 7px;
  border-radius:6px;
  background:rgba(0,0,0,.78);
  border:1px solid rgba(255,255,255,.10);
}

.info{
  padding:10px 12px 12px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.title{
  font-size:14px;
  font-weight:660;
  line-height:1.25;
  letter-spacing:.1px;
}

.byline{
  font-size:12px;
  color:var(--muted);
}

.max-lines-2{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}

 #discover-toggle{display:none}

 html.js .discover-controls{display:inline-flex}
html.js .discover-body{display:block}
html.js .discover-hidden .discover-body{display:none}
html.js .discover-hidden .toggle .chev{transform:rotate(-135deg); margin-top:2px}

 .details-fallback{
  display:none;
}

noscript .details-fallback{
  display:block;
  width:100%;
}

noscript .section{
  display:none;
}

details.details-fallback{
  width:100%;
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
}

details.details-fallback > summary{
  list-style:none;
  cursor:pointer;
  padding:16px 18px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(90deg, rgba(223,3,168,.10), transparent 55%);
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:12px;
}

details.details-fallback > summary::-webkit-details-marker{display:none}

.summary-left{
  display:flex;
  flex-direction:column;
  gap:4px;
  min-width:0;
}

.summary-title{
  font-size:16px;
  font-weight:720;
  letter-spacing:.2px;
}

.summary-sub{
  font-size:13px;
  color:var(--muted);
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.summary-right{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:8px 10px;
  border-radius:999px;
  background:var(--panel3);
  border:1px solid var(--border2);
  font-size:13px;
  color:rgba(244,246,255,.78);
}

details.details-fallback[open] .summary-right .chev{
  transform:rotate(-135deg);
  margin-top:2px;
}
</style>
</head>

<body>

<div class="page">

  <div class="hero">
    <img src="/static/logo-poke.svg" class="logo" alt="Poke Logo">
 
    <div class="search-wrap">
      <form class="search-form" action="/search" method="get">
        <input class="search-bar" autocomplete="on" id="fname" name="query" type="text" placeholder="Search...">
      </form>
    </div>
  </div>

  <!-- JS / no-JS version (shown when JS is enabled) -->
  <section class="section" id="discover" aria-label="Discover gaming videos">
    <div class="section-header">
      <div class="section-head-left">
        <div class="section-title">Discover gaming videos</div>
        <div class="section-sub">These are trending gaming videos</div>
      </div>

      <button class="toggle discover-controls" id="discoverToggle" type="button" aria-controls="discoverBody" aria-expanded="true">
        <span id="discoverToggleText">Hide</span>
        <span class="chev" aria-hidden="true"></span>
      </button>
    </div>

    <div class="discover-body" id="discoverBody">
      <div class="video-grid">
        <% inv.slice(0,16).forEach(x => { %>

          <a href="/watch?v=<%- x.videoId %>" class="video canloadhd" data-author="<%- x.author %>">
            <div class="thumbnail" style="background-image:url('/vi/<%= x.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
              <span class="video-length"><%- turntomins(x.lengthSeconds) %></span>
            </div>
            <div class="info">
              <span class="title max-lines-2" title="<%- x.title %>"><%- x.title %></span>
              <span class="byline max-lines-2" title="Video By <%- x.author %>">By <%- x.author %></span>
            </div>
          </a>

        <% }) %>
      </div>
    </div>
  </section>

  <!-- NO-JS option: collapsible discover section (only appears when JS is disabled) -->
  <noscript>
    <details class="details-fallback" open>
      <summary>
        <div class="summary-left">
          <div class="summary-title">Discover gaming videos</div>
          <div class="summary-sub">These are trending gaming videos</div>
        </div>
        <div class="summary-right">
          <span>Toggle</span>
          <span class="chev" aria-hidden="true"></span>
        </div>
      </summary>

      <div class="video-grid">
        <% inv.slice(0,16).forEach(x => { %>

          <a href="/watch?v=<%- x.videoId %>" class="video canloadhd" data-author="<%- x.author %>">
            <div class="thumbnail" style="background-image:url('/vi/<%= x.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
              <span class="video-length"><%- turntomins(x.lengthSeconds) %></span>
            </div>
            <div class="info">
              <span class="title max-lines-2" title="<%- x.title %>"><%- x.title %></span>
              <span class="byline max-lines-2" title="Video By <%- x.author %>">By <%- x.author %></span>
            </div>
          </a>

        <% }) %>
      </div>
    </details>
  </noscript>

</div>

<script>
(function(){
  document.documentElement.classList.add("js");

  var btn = document.getElementById("discoverToggle");
  var body = document.getElementById("discoverBody");
  var txt = document.getElementById("discoverToggleText");

  if (!btn || !body || !txt) return;

  var key = "poke_discover_hidden";
  var hidden = false;

  try{
    hidden = localStorage.getItem(key) === "1";
  }catch(e){
    hidden = false;
  }

  function setHidden(v){
    hidden = !!v;
    if (hidden){
      document.documentElement.classList.add("discover-hidden");
      btn.setAttribute("aria-expanded","false");
      txt.textContent = "Show";
    }else{
      document.documentElement.classList.remove("discover-hidden");
      btn.setAttribute("aria-expanded","true");
      txt.textContent = "Hide";
    }
    try{
      localStorage.setItem(key, hidden ? "1" : "0");
    }catch(e){}
  }

  btn.addEventListener("click", function(){
    setHidden(!hidden);
  });

  setHidden(hidden);
})();
</script>

</body>
</html>