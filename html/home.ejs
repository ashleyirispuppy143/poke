<script>
(function () {
  var searchInput = document.getElementById("fname");
  var stickySearchInput = document.getElementById("sticky-fname");
  var bangIndicator = document.getElementById("bang-indicator");

  function updateBangIndicator(value, target) {
    if (bangIndicator) {
      if (value.indexOf("!") !== -1) {
        bangIndicator.classList.remove("hidden");
        if (target) target.setAttribute("autocomplete", "off");
      } else {
        bangIndicator.classList.add("hidden");
        if (target) target.setAttribute("autocomplete", "on");
      }
    }
  }

  function syncSearchInputs(source, target) {
    if (!source || !target) return;

    source.addEventListener("input", function () {
      target.value = source.value;
      updateBangIndicator(source.value, source);
      updateBangIndicator(source.value, target);
    });
  }

  syncSearchInputs(searchInput, stickySearchInput);
  syncSearchInputs(stickySearchInput, searchInput);

  var searchToggle = document.getElementById("mobile-search-toggle");

  if (searchToggle) {
    searchToggle.addEventListener("change", function () {
      if (this.checked) {
        var mobileInput = document.getElementById("mobile-search-input");
        if (mobileInput) mobileInput.focus();
      }
    });
  }

  window.addEventListener("scroll", function() {
    var stickyNav = document.getElementById("desktop-sticky-nav");
    var hero = document.querySelector(".hero");
    if (!stickyNav) return;

    if (document.documentElement.classList.contains("layout-classic")) return;

    if (!hero) return;

    var heroBottom = hero.offsetTop + hero.offsetHeight;
    if (window.scrollY > heroBottom - 50) {
      stickyNav.classList.add("visible");
    } else {
      stickyNav.classList.remove("visible");
    }
  });

  var hamburgers = document.querySelectorAll(".hamburger");
  var sidebar = document.getElementById("desktop-sidebar");
  var sidebarOverlay = document.getElementById("desktop-sidebar-overlay");

  function toggleSidebar() {
    if (sidebar && sidebarOverlay) {
      sidebar.classList.toggle("visible");
      sidebarOverlay.classList.toggle("visible");
    }
  }

  hamburgers.forEach(function(hb) {
    hb.addEventListener("click", toggleSidebar);
  });

  if (sidebarOverlay) {
    sidebarOverlay.addEventListener("click", toggleSidebar);
  }

  var desktopCreateBtns = document.querySelectorAll(".desktop-create-trigger");
  var desktopCreateDropdowns = document.querySelectorAll(".desktop-dropdown-menu");

  function closeDesktopCreateDropdowns(exceptDropdown) {
    desktopCreateDropdowns.forEach(function(dropdown) {
      if (dropdown !== exceptDropdown) {
        dropdown.classList.remove("show");
      }
    });
  }

  desktopCreateBtns.forEach(function(button) {
    button.addEventListener("click", function(e) {
      e.stopPropagation();

      var menuId = this.getAttribute("data-create-menu");
      var dropdown = document.getElementById(menuId);
      if (!dropdown) return;

      closeDesktopCreateDropdowns(dropdown);
      dropdown.classList.toggle("show");
    });
  });

  var openSettingsBtn = document.getElementById("open-settings-btn");
  var heroSettingsBtn = document.getElementById("hero-settings-btn");
  var saveSettingsBtn = document.getElementById("save-settings-btn");
  var settingsModalToggle = document.getElementById("settings-modal-toggle");
  var feedSettingControl = document.getElementById("setting-feed");
  var gameFeedsSettingControl = document.getElementById("setting-gamefeeds");
  var feedSettingHelper = document.getElementById("setting-feed-helper");
  var gameFeedsSettingHelper = document.getElementById("setting-gamefeeds-helper");

  function syncSettingsAvailability() {
    if (!feedSettingControl || !gameFeedsSettingControl) return;

    if (gameFeedsSettingControl.value === "true") {
      feedSettingControl.value = "gaming";
      feedSettingControl.disabled = true;
      gameFeedsSettingControl.disabled = false;

      if (feedSettingHelper) feedSettingHelper.classList.add("is-visible");
      if (gameFeedsSettingHelper) gameFeedsSettingHelper.classList.remove("is-visible");
      return;
    }

    feedSettingControl.disabled = false;
    if (feedSettingHelper) feedSettingHelper.classList.remove("is-visible");

    if (feedSettingControl.value !== "gaming") {
      gameFeedsSettingControl.value = "false";
      gameFeedsSettingControl.disabled = true;
      if (gameFeedsSettingHelper) gameFeedsSettingHelper.classList.add("is-visible");
    } else {
      gameFeedsSettingControl.disabled = false;
      if (gameFeedsSettingHelper) gameFeedsSettingHelper.classList.remove("is-visible");
    }
  }

  if (feedSettingControl) {
    feedSettingControl.addEventListener("change", syncSettingsAvailability);
  }

  if (gameFeedsSettingControl) {
    gameFeedsSettingControl.addEventListener("change", syncSettingsAvailability);
  }

  function openSettingsHandler(e) {
    e.preventDefault();

    var layoutSetting = document.getElementById("setting-layout");
    var feedSetting = document.getElementById("setting-feed");
    var gameFeedsSetting = document.getElementById("setting-gamefeeds");
    var accentInput = document.getElementById("setting-accent");

    if (layoutSetting) layoutSetting.value = localStorage.getItem("poke_layout") || "hero";
    if (feedSetting) feedSetting.value = localStorage.getItem("poke_feed") || "gaming";
    if (gameFeedsSetting) gameFeedsSetting.value = localStorage.getItem("poke_gamefeeds") || "false";
    if (gameFeedsSetting && gameFeedsSetting.value === "true" && feedSetting) feedSetting.value = "gaming";
    if (accentInput) accentInput.value = localStorage.getItem("poke_accent") || "#ffabcc";

    syncSettingsAvailability();

    settingsModalToggle.checked = true;

    if (this.id === "open-settings-btn" && sidebar && sidebar.classList.contains("visible")) {
      toggleSidebar();
    }
  }

  if (openSettingsBtn) {
    openSettingsBtn.addEventListener("click", openSettingsHandler);
  }

  if (heroSettingsBtn) {
    heroSettingsBtn.addEventListener("click", openSettingsHandler);
  }

  var currentFeed = localStorage.getItem("poke_feed") || "gaming";

  if (localStorage.getItem("poke_gamefeeds") === "true") {
    currentFeed = "gaming";
    localStorage.setItem("poke_feed", "gaming");
  }

  var currentChip = "all";
  var desktopFeedBtns = document.querySelectorAll(".feed-btn");
  var filterChips = document.querySelectorAll("[data-filter]");
  var videos = document.querySelectorAll(".video-grid .video");

  function applyFilters() {
    var visibleCount = 0;

    videos.forEach(function(vid) {
      var isSlop = vid.getAttribute("data-isslop") === "true";
      var game = vid.getAttribute("data-game");
      var genre = vid.getAttribute("data-genre");
      var category = vid.getAttribute("data-category");

      var matchesChip = false;

      if (currentChip === "all") {
        matchesChip = true;
      } else if (game === currentChip || genre === currentChip || category === currentChip) {
        matchesChip = true;
      }

      var matchesFeed = true;

      if (currentFeed === "gaming") {
        if (isSlop) matchesFeed = false;
      }

      if (matchesChip && matchesFeed) {
        if (currentFeed === "gaming" && visibleCount >= 32) {
          vid.style.display = "none";
        } else {
          vid.style.display = "flex";
          visibleCount++;
        }
      } else {
        vid.style.display = "none";
      }
    });
  }

  if (currentFeed !== "gaming") {
    var initFeedOpt = document.querySelector(".feed-btn[data-feed=\"" + currentFeed + "\"]");

    if (initFeedOpt) {
      desktopFeedBtns.forEach(function(b) {
        b.classList.remove("active");
      });

      initFeedOpt.classList.add("active");
    }
  }

  applyFilters();

  if (saveSettingsBtn) {
    saveSettingsBtn.addEventListener("click", function(e) {
      e.preventDefault();

      var newLayout = document.getElementById("setting-layout").value;
      var newFeed = document.getElementById("setting-feed").value;
      var newGameFeeds = document.getElementById("setting-gamefeeds").value;
      var newAccent = document.getElementById("setting-accent").value;

      if (newGameFeeds === "true") {
        newFeed = "gaming";
      }

      if (newFeed !== "gaming") {
        newGameFeeds = "false";
      }

      localStorage.setItem("poke_layout", newLayout);
      localStorage.setItem("poke_feed", newFeed);
      localStorage.setItem("poke_gamefeeds", newGameFeeds);
      localStorage.setItem("poke_accent", newAccent);

      document.documentElement.classList.remove("layout-classic", "layout-mix", "layout-nodiscover");

      if (newLayout === "classic") {
        document.documentElement.classList.add("layout-classic");
      } else if (newLayout === "mix") {
        document.documentElement.classList.add("layout-mix");
      } else if (newLayout === "mix-nodiscover") {
        document.documentElement.classList.add("layout-mix", "layout-nodiscover");
      } else if (newLayout === "hero-nodiscover") {
        document.documentElement.classList.add("layout-nodiscover");
      }

      var stickyNav = document.getElementById("desktop-sticky-nav");
      if (stickyNav && window.scrollY < 100) stickyNav.classList.remove("visible");

      if (newGameFeeds === "true") {
        document.documentElement.classList.add("show-game-feeds");
      } else {
        document.documentElement.classList.remove("show-game-feeds");
      }

      document.documentElement.style.setProperty("--ptc-accent", newAccent);

      currentFeed = newFeed;

      desktopFeedBtns.forEach(function(b) {
        if (b.getAttribute("data-feed") === newFeed) {
          b.classList.add("active");
        } else {
          b.classList.remove("active");
        }
      });

      applyFilters();
      settingsModalToggle.checked = false;
    });
  }

  if (desktopFeedBtns) {
    desktopFeedBtns.forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.preventDefault();

        var feedType = this.getAttribute("data-feed");
        currentFeed = feedType;

        desktopFeedBtns.forEach(function(b) {
          b.classList.remove("active");
        });

        this.classList.add("active");
        applyFilters();
      });
    });
  }

  document.addEventListener("click", function(e) {
    if (!e.target.closest(".nav-right")) {
      closeDesktopCreateDropdowns();
    }
  });

  filterChips.forEach(function(chip) {
    chip.addEventListener("click", function(e) {
      e.preventDefault();

      var targetFilter = this.getAttribute("data-filter");

      filterChips.forEach(function(c) {
        if (c.getAttribute("data-filter") === targetFilter) {
          c.classList.add("active");
        } else {
          c.classList.remove("active");
        }
      });

      currentChip = targetFilter;
      applyFilters();
    });
  });

  var libraryModal = document.getElementById("library-modal");
  var libraryOpenButtons = document.querySelectorAll("[data-library-open]");
  var libraryCloseButtons = document.querySelectorAll("[data-library-close]");

  function openLibraryModal() {
    if (!libraryModal) return;

    libraryModal.classList.add("is-open");
    libraryModal.setAttribute("aria-hidden", "false");

    var firstCloseButton = libraryModal.querySelector("[data-library-close]");
    if (firstCloseButton) firstCloseButton.focus();
  }

  function closeLibraryModal() {
    if (!libraryModal) return;

    libraryModal.classList.remove("is-open");
    libraryModal.setAttribute("aria-hidden", "true");
  }

  libraryOpenButtons.forEach(function(button) {
    button.addEventListener("click", function(e) {
      e.preventDefault();
      openLibraryModal();
    });
  });

  libraryCloseButtons.forEach(function(button) {
    button.addEventListener("click", function(e) {
      e.preventDefault();
      closeLibraryModal();
    });
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") {
      closeLibraryModal();
      closeDesktopCreateDropdowns();
    }
  });
})();
</script>

</body>
</html>