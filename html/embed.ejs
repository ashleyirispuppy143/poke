    </style></head><body class="<%= isShowHow ? 'mode-showhow' : 'mode-video' %>" data-forcequality="<%= typeof forcequality !== 'undefined' ? forcequality : '' %>">
    
    <% if (!isShowHow && (typeof VideoError === 'undefined' || !VideoError)) { %>
    <script>
        let _failsBotCheck = false;
        try {
            if (navigator.webdriver) _failsBotCheck = true;
            if (window.navigator.webdriver) _failsBotCheck = true;
            if (window.document.documentElement.getAttribute("webdriver") !== null) _failsBotCheck = true;
            if (/bot|crawler|spider|crawling|wget|curl|headless|puppeteer|playwright/i.test(navigator.userAgent || '')) _failsBotCheck = true;
            if (window.callPhantom || window._phantom || window.__nightmare) _failsBotCheck = true;
            if (window.outerWidth === 0 && window.outerHeight === 0 && window.innerWidth === 0) _failsBotCheck = true;
            if (typeof document.createElement !== 'function') _failsBotCheck = true;
            if (typeof window.requestAnimationFrame !== 'function') _failsBotCheck = true;
            if (navigator.languages === "") _failsBotCheck = true;
            
            // Basic framing abuse check
            if (window.self !== window.top && (window.innerWidth < 100 || window.innerHeight < 100)) {
                _failsBotCheck = true;
            }
        } catch(e) { 
            _failsBotCheck = true; 
        }

        const _isDir = window.self === window.top;
        
        if (_isDir || _failsBotCheck) {
            document.write('<style>body { background-color: #212121; } .video-wrapper-<%- v %> { display: none !important; }</style>');
        }
    </script>
    <% } %>

    <% if (typeof VideoError !== 'undefined' && VideoError) { %>
        <div class="video-error-container-<%- v %>">
            <svg class="error-icon-<%- v %>" viewBox="0 0 24 24">
                <path fill="currentColor" d="M13,13h-2V7h2V13z M13,17h-2v-2h2V17z M12,2C6.48,2,2,6.48,2,12c0,5.52,4.48,10,10,10s10-4.48,10-10C22,6.48,17.52,2,12,2z M12,21c-4.96,0-9-4.04-9-9c0-4.96,4.04-9,9-9c4.96,0,9,4.04,9,9C21,16.96,16.96,21,12,21z"/>
