<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- v %></title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #000;
            overflow: hidden;
            font-family: Arial, sans-serif;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
            padding: 2px; 
        }

        .thumbnail-link {
            position: relative;
            display: block;
            width: 100%;
            height: 100%;
            text-decoration: none;
            overflow: hidden;
        }

        .thumbnail-img {
            width: 100%;
            height: 100%;
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            display: block;
        }

        .play-button {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: clamp(64px, 12vw, 120px);
            height: clamp(64px, 12vw, 120px);
            background: rgba(20, 20, 20, 0.65);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            cursor: pointer;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.15);
        }

        .thumbnail-link:hover .play-button {
            background: rgba(35, 35, 35, 0.85);
            transform: translate(-50%, -50%) scale(1.15);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.7), inset 0 0 0 1.5px rgba(255, 255, 255, 0.4);
        }

        .play-triangle {
            width: 38%;
            height: 38%;
            margin-left: 8%;
            fill: #ffffff;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
            transition: transform 0.3s ease;
        }

        .thumbnail-link:hover .play-triangle {
            transform: scale(1.05);
        }

        .logo-link {
            position: absolute;
            bottom: 15px;
            right: 15px;
            z-index: 10;
            display: block;
            transition: transform 0.2s ease-in-out;
        }

        .logo-link:hover {
            transform: scale(1.05);
        }

        .logo-img {
            height: clamp(25px, 5vw, 40px);
            width: auto;
            display: block;
            filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.5));
        }
    </style>
</head>
<body>

    <div class="video-wrapper">
        <a href="/watch?v=<%- v %>" target="_blank" rel="noopener noreferrer" class="thumbnail-link">
            <img src="https://i.ytimg.com/vi/<%- v %>/maxresdefault.jpg" alt="Play Video" class="thumbnail-img" onerror="this.src='https://i.ytimg.com/vi/<%- v %>/hqdefault.jpg';">
            <div class="play-button">
                <svg class="play-triangle" viewBox="0 0 24 24">
                    <polygon points="8,5 8,19 19,12" />
                </svg>
            </div>
        </a>

        <a href="/home" target="_blank" rel="noopener noreferrer" class="logo-link">
            <img src="/css/logo-poke.svg" alt="Poke Logo" class="logo-img">
        </a>
    </div>

</body>
</html>