                    function getVideoUrl(itag, retryNonce) {
                        const _enc = '<%= encodedVidUrl %>';
                        const _vidBase = _enc.split('-').filter(Boolean).map(c => String.fromCharCode(parseInt(c, 16))).join('');

                        const _pArr = <%- obfPath %>;
                        let _vPath = "";
                        for(let i = 0; i < _pArr.length; i++) {
                            _vPath += String.fromCharCode(_pArr[i] ^ 0x5A);
                        }
                        
                        _vPath = _vPath.replace('&itag=18', '&itag=' + (itag || 18));

                        const _token = '<%- rToken %>';
                        const _decipher = function(s) {
                            let a = s.split("");
                            a = a.reverse();
                            a.splice(1, 1);
                            let t = a[0];
                            if(a.length > 3) {
                                a[0] = a[3];
                                a[3] = t;
                            }
                            return a.join("");
                        };

                        const baseUrl = _vidBase + _vPath + '&sig=' + _decipher(_token);
                        return retryNonce ? baseUrl + '&retry=' + encodeURIComponent(retryNonce) : baseUrl;
                    }

