<% 
    const isShowHow = typeof showHow !== 'undefined' && (showHow === true || showHow === 'true');

    function formatCount(num) {
        if (num === null || num === undefined) return '0';
        return new Intl.NumberFormat('en-US', { notation: 'compact', compactDisplay: 'short' }).format(num);
    }
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- v %><%= isShowHow ? ' - Embed Guide' : '' %></title>
    <style>
        @font-face {
            font-family: "PokeTube Flex";
            src: url("/static/robotoflex.ttf");
            font-style: normal;
            font-stretch: 1% 800%;
            font-display: swap;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: "PokeTube Flex", Arial, sans-serif;
            background-color: #000;
        }

        /* Prevent border-radius artifacts in fullscreen */
        :fullscreen, :fullscreen * { border-radius: 0 !important; }

        body.mode-showhow {
            background-color: #0f0f0f;
            overflow-y: auto;
            color: #f1f1f1;
        }

        .video-wrapper-<%- v %> {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #000;
            will-change: transform;
        }

        .video-error-container-<%- v %> {
            width: 100vw;
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background-color: #212121;
            gap: 20px;
            color: #f1f1f1;
            text-align: center;
        }

        .error-icon-<%- v %> {
            width: 48px;
            height: 48px;
            color: #aaaaaa;
        }

        .player-link-<%- v %> {
            position: relative;
            display: block;
            width: 100%;
            height: 100%;
            z-index: 10;
        }

        .player-image-<%- v %> {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .play-button-<%- v %> {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: clamp(48px, 12vmin, 90px);
            height: clamp(48px, 12vmin, 90px);
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(8px);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .play-button-<%- v %>:hover { transform: translate(-50%, -50%) scale(1.1); }

        .logo-link-<%- v %> {
            position: absolute;
            bottom: 24px;
            right: 24px;
            z-index: 30;
        }

        .logo-link-<%- v %>.in-player-<%- v %> {
            position: static;
            margin-left: 12px;
        }

        /* Player UI */
        .custom-video-player-<%- v %> {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            z-index: 5;
        }

        .custom-controls-<%- v %> {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 16px;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            z-index: 20;
            transition: opacity 0.3s;
        }

        .custom-context-menu-<%- v %> {
            position: absolute;
            background: rgba(28, 28, 28, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 8px;
            padding: 8px 0;
            z-index: 1000;
            display: none;
            flex-direction: column;
            box-shadow: 0 4px 16px rgba(0,0,0,0.5);
        }

        .context-item-<%- v %> {
            padding: 10px 16px;
            color: #f1f1f1;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
        }

        .context-item-<%- v %>:hover { background: rgba(255, 255, 255, 0.1); }
    </style>
</head>

<body class="<%= isShowHow ? 'mode-showhow' : 'mode-video' %>">

    <% if (typeof VideoError !== 'undefined' && VideoError) { %>
        <div class="video-error-container-<%- v %>">
            <svg class="error-icon-<%- v %>" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            <div class="error-text-<%- v %>"><%= VideoError.message %></div>
            <a href="/watch?v=<%- v %>" class="embed-btn-<%- v %>" style="text-decoration:none;">Open video on actual Poke</a>
        </div>
    <% } else if (isShowHow) { %>
        <% } else { %>
        <div class="video-wrapper-<%- v %>" id="player-wrapper-<%- v %>">
            <a href="/watch?v=<%- v %>" class="player-link-<%- v %>">
                <img src="https://i.ytimg.com/vi/<%- v %>/maxresdefault.jpg" class="player-image-<%- v %>" onerror="this.src='https://i.ytimg.com/vi/<%- v %>/hqdefault.jpg';">
                <div class="play-button-<%- v %>"><svg width="40" height="40" viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg></div>
            </a>
            <a href="/" class="logo-link-<%- v %>"><img src="/css/logo-poke.svg" alt="Poke" class="logo-img-<%- v %>"></a>
        </div>

        <script>
            const v = '<%- v %>';
            const wrapper = document.getElementById('player-wrapper-' + v);
            
            wrapper.addEventListener('click', (e) => {
                if (e.target.closest('.player-link-<%- v %>')) {
                    e.preventDefault();
                    wrapper.querySelector('.player-link-<%- v %>').style.display = 'none';
                    
                    const video = document.createElement('video');
                    video.className = 'custom-video-player-' + v;
                    video.src = 'https://companion-proxy.poketube.fun/companion/latest_version?id=' + v + '&itag=18&local=true';
                    video.autoplay = true;
                    video.onerror = () => {
                        wrapper.innerHTML = `<div class="video-error-container-${v}"><div class="error-title-${v}">Error loading video</div><a href="/watch?v=${v}" class="embed-btn-${v}">Open video on actual Poke</a></div>`;
                    };
                    wrapper.appendChild(video);
                    
                    // Add controls, context menu, etc here...
                }
            });
        </script>
    <% } %>
</body>
</html>