<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- v %></title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #000;
            overflow: hidden;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
            padding: 2px; 
        }

        .player-link {
            position: relative;
            display: block;
            width: 100%;
            height: 100%;
            text-decoration: none;
            overflow: hidden;
        }

        .player-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            background-color: #111;
        }

        .play-button {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: clamp(48px, 10vmin, 84px);
            height: clamp(48px, 10vmin, 84px);
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.25s ease;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        }

        .player-link:hover .play-button {
            background-color: rgba(0, 0, 0, 0.75);
            transform: translate(-50%, -50%) scale(1.1);
        }

        .play-triangle {
            width: 40%;
            height: 40%;
            margin-left: 8%;
            fill: #ffffff;
            transition: transform 0.2s ease;
        }

        .player-link:hover .play-triangle {
            transform: scale(1.05);
        }

        .beta-chip {
            position: absolute;
            bottom: 58px;
            right: 15px;
            background-color: rgba(0, 0, 0, 0.7);
            color: #eeeeee;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            pointer-events: none;
            user-select: none;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            z-index: 10;
        }

        .logo-link {
            position: absolute;
            bottom: 15px;
            right: 15px;
            z-index: 10;
            display: block;
            transition: transform 0.2s ease-in-out;
        }

        .logo-link:hover {
            transform: scale(1.05);
        }

        .logo-img {
            height: clamp(20px, 4vmin, 35px);
            width: auto;
            display: block;
            filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.6));
        }
    </style>
</head>
<body>

    <div class="video-wrapper">
        <a href="/watch?v=<%- v %>" target="_blank" rel="noopener noreferrer" class="player-link">
            <img src="https://i.ytimg.com/vi/<%- v %>/maxresdefault.jpg" alt="<%- v %>" class="player-image" onerror="this.src='https://i.ytimg.com/vi/<%- v %>/hqdefault.jpg';">
            <div class="play-button">
                <svg class="play-triangle" viewBox="0 0 24 24">
                    <polygon points="8,5 8,19 19,12" />
                </svg>
            </div>
        </a>

        <div class="beta-chip">Embeds are beta</div>

        <a href="/home" target="_blank" rel="noopener noreferrer" class="logo-link">
            <img src="/css/logo-poke.svg" alt="Poke Logo" class="logo-img">
        </a>
    </div>

</body>
</html>