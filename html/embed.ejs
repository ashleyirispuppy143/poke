                            const settingsBtn = controls.querySelector('.settings-btn-<%- v %>');
                            const settingsPanel = controls.querySelector('.settings-panel-<%- v %>');
                            const speedRow = controls.querySelector('.speed-row-<%- v %>');
                            const speedValue = controls.querySelector('.speed-value-<%- v %>');
                            const loopRow = controls.querySelector('.loop-row-<%- v %>');
                            const loopValue = controls.querySelector('.loop-value-<%- v %>');

                            if (!playPauseBtn || !playPausePathEl || !muteBtn || !mutePathEl || !volGroup || !volumeSlider || !fsBtn || !progressContainer || !progressFill || !progressThumb || !timeDisplay || !settingsBtn || !settingsPanel || !speedRow || !speedValue || !loopRow || !loopValue) {
                                return;
                            }

                            let showRemainingTime = false;
                            let lastVolume = 1;
                            let retryCount = 0;
                            let retryTimer = null;
                            const maxRetries = 3;
                            const speeds = [0.25, 0.5, 1, 1.25, 1.5, 2];
                            let speedIdx = 2;
                            let lastWidth = '';
                            let lastText = '';
                            let isRafPending = false;
                            let hideTimeout = null;
                            let isScrubbing = false;

                            function formatTime(s) {
                                if (!Number.isFinite(s)) return '0:00';
                                s = Math.max(0, s);
                                const h = Math.floor(s / 3600);
                                const m = Math.floor((s % 3600) / 60);
                                const sec = Math.floor(s % 60);
                                if (h > 0) {
                                    return h + ':' + String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
                                }
                                return m + ':' + String(sec).padStart(2, '0');
                            }

                            function setSliderBackground(value) {
                                const pct = Math.max(0, Math.min(1, value)) * 100;
                                volumeSlider.style.background = `linear-gradient(to right, #fff ${pct}%, rgba(255, 255, 255, 0.3) ${pct}%)`;
                            }

                            function updateVolumeUI() {
                                const effectiveVolume = video.muted ? 0 : video.volume;
                                volumeSlider.value = String(effectiveVolume);
                                setSliderBackground(effectiveVolume);
                                mutePathEl.setAttribute('d', effectiveVolume <= 0 ? muteIcon : volIcon);
                                if (!video.muted && video.volume > 0) {
                                    lastVolume = video.volume;
                                }
                            }

                            function setVolumeOpen(open) {
                                volGroup.classList.toggle('is-volume-open-<%- v %>', open);
                            }

                            function setSettingsOpen(open) {
                                if (open) {
                                    setVolumeOpen(false);
                                }
                                settingsPanel.classList.toggle('is-open-<%- v %>', open);
                                settingsPanel.setAttribute('aria-hidden', open ? 'false' : 'true');
                                settingsBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
                            }

                            function closeSettings() {
                                setSettingsOpen(false);
                            }

                            function showRetryOverlay() {
                                retryOverlay.classList.add('is-visible-<%- v %>');
                                controls.style.opacity = '0';
                                closeSettings();
                            }

                            function hideRetryOverlay() {
                                retryOverlay.classList.remove('is-visible-<%- v %>');
                                controls.style.opacity = '1';
                            }

                            function showRuntimeError() {
                                clearTimeout(retryTimer);
                                hideRetryOverlay();
                                closeSettings();
                                video.pause();
                                video.removeAttribute('poster');
                                video.style.display = 'none';
                                controls.style.display = 'none';
                                playerLink.style.display = 'none';
                                wrapper.style.backgroundColor = '#212121';

                                let errContainer = wrapper.querySelector('.video-runtime-error-<%- v %>');
                                if (!errContainer) {
                                    errContainer = document.createElement('div');
                                    errContainer.className = 'video-error-container-<%- v %> video-runtime-error-<%- v %>';
                                    errContainer.style.position = 'absolute';
                                    errContainer.style.top = '0';
                                    errContainer.style.left = '0';
                                    errContainer.style.width = '100%';
                                    errContainer.style.height = '100%';
                                    errContainer.style.zIndex = '100';
                                    errContainer.style.backgroundColor = '#212121';
                                    errContainer.innerHTML = `
                                        <svg class="error-icon-<%- v %>" viewBox="0 0 24 24" style="color: #aaaaaa;">
                                            <path fill="currentColor" d="M12,2C6.48,2,2,6.48,2,12c0,5.52,4.48,10,10,10s10-4.48,10-10C22,6.48,17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z"/>
                                        </svg>
                                        <div class="error-text-<%- v %>">
                                            <div class="error-title-<%- v %>" style="margin-bottom: 12px;">Video playback failed</div>
                                            <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
                                                <button class="embed-btn-<%- v %> retry-btn-<%- v %>" type="button" style="cursor: pointer;">Retry</button>
                                                <a href="/watch?v=<%- v %>" target="_blank" rel="noopener noreferrer" style="color: #ffabcc; text-decoration: none; font-size: 16px; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; font-family: 'PokeTube Flex', Arial, sans-serif;">
                                                    Watch on Poke
                                                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                                                </a>
                                            </div>
                                        </div>
                                    `;
                                    wrapper.appendChild(errContainer);

                                    const retryButton = errContainer.querySelector('.retry-btn-<%- v %>');
                                    retryButton.addEventListener('click', (event) => {
                                        event.stopPropagation();
                                        retryCount = 0;
                                        errContainer.style.display = 'none';
                                        wrapper.style.backgroundColor = '#000';
                                        video.style.display = 'block';
                                        controls.style.display = '';
                                        playerLink.style.display = 'none';
                                        if (posterSrc) {
                                            video.poster = posterSrc;
                                        }
                                        showRetryOverlay();
                                        video.src = getVideoUrl(Date.now());
                                        video.load();
                                        video.play().catch(() => {});
                                    });
                                } else {
                                    errContainer.style.display = 'flex';
                                }
                            }

                            function queueRetry() {
                                if (retryCount >= maxRetries) {
                                    showRuntimeError();
                                    return;
                                }
                                retryCount++;
                                showRetryOverlay();
                                retryTimer = setTimeout(() => {
                                    video.src = getVideoUrl(Date.now() + '-' + retryCount);
                                    video.load();
                                    video.play().catch(() => {});
                                }, 900);
                            }

                            function updateTime() {
                                if (isRafPending) return;
                                isRafPending = true;
                                requestAnimationFrame(() => {
                                    const duration = Number.isFinite(video.duration) ? video.duration : 0;
                                    const current = Number.isFinite(video.currentTime) ? video.currentTime : 0;
                                    const p = duration ? Math.max(0, Math.min(100, (current / duration) * 100)) : 0;
                                    const newWidth = p + '%';

                                    if (lastWidth !== newWidth) {
                                        progressFill.style.width = newWidth;
                                        progressThumb.style.left = newWidth;
                                        progressContainer.setAttribute('aria-valuenow', String(Math.round(p)));
                                        lastWidth = newWidth;
                                    }

                                    const newText = showRemainingTime
                                        ? `-${formatTime(duration - current)} / ${formatTime(duration)}`
                                        : `${formatTime(current)} / ${formatTime(duration)}`;

                                    if (lastText !== newText) {
                                        timeDisplay.innerText = newText;
                                        lastText = newText;
                                    }
                                    isRafPending = false;
                                });
                            }

                            function seekFromEvent(event) {
                                const duration = Number.isFinite(video.duration) ? video.duration : 0;
                                if (!duration) return;
                                const r = progressContainer.getBoundingClientRect();
                                const x = Math.max(0, Math.min(r.width, event.clientX - r.left));
                                video.currentTime = (x / r.width) * duration;
                                updateTime();
                            }

                            function togglePlay() {
                                if (video.paused) {
                                    video.play().catch(() => {});
                                } else {
                                    video.pause();
                                }
                            }

                            function showControls() {
                                if (retryOverlay.classList.contains('is-visible-<%- v %>')) return;
                                controls.style.opacity = '1';
                                wrapper.style.cursor = 'default';
                                clearTimeout(hideTimeout);
                                hideTimeout = setTimeout(() => {
                                    if (!video.paused && !settingsPanel.classList.contains('is-open-<%- v %>') && !volGroup.classList.contains('is-volume-open-<%- v %>')) {
                                        controls.style.opacity = '0';
                                        wrapper.style.cursor = 'none';
                                    }
                                }, 2500);
                            }

                            volGroup.addEventListener('click', (event) => event.stopPropagation());
                            volGroup.addEventListener('pointerenter', () => setVolumeOpen(true));
                            volGroup.addEventListener('pointerleave', () => setVolumeOpen(false));
                            settingsBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                setVolumeOpen(false);
                                setSettingsOpen(!settingsPanel.classList.contains('is-open-<%- v %>'));
                            });
                            settingsPanel.addEventListener('click', (event) => event.stopPropagation());
                            controls.querySelector('.bottom-area-<%- v %>').addEventListener('click', (event) => event.stopPropagation());

                            playPauseBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                closeSettings();
                                setVolumeOpen(false);
                                togglePlay();
                            });
                            playPauseBtn.addEventListener('keydown', (event) => {
                                if (event.key === 'Enter' || event.key === ' ') {
                                    event.preventDefault();
                                    closeSettings();
                                    togglePlay();
                                }
                            });

                            volumeSlider.addEventListener('input', (event) => {
                                event.stopPropagation();
                                setVolumeOpen(true);
                                const val = Math.max(0, Math.min(1, parseFloat(event.target.value) || 0));
                                video.volume = val;
                                video.muted = val === 0;
                                if (val > 0) lastVolume = val;
                                updateVolumeUI();
                            });
                            volumeSlider.addEventListener('click', (event) => event.stopPropagation());
                            volumeSlider.addEventListener('pointerdown', (event) => {
                                event.stopPropagation();
                                setVolumeOpen(true);
                            });

                            muteBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                closeSettings();
                                setVolumeOpen(true);
                                if (video.muted || video.volume === 0) {
                                    const restoreVolume = lastVolume > 0 ? lastVolume : 1;
                                    video.volume = restoreVolume;
                                    video.muted = false;
                                } else {
                                    lastVolume = video.volume;
                                    video.muted = true;
                                }
                                updateVolumeUI();
                            });

                            timeDisplay.addEventListener('click', (event) => {
                                event.stopPropagation();
                                showRemainingTime = !showRemainingTime;
                                updateTime();
                            });

                            progressContainer.addEventListener('pointerdown', (event) => {
                                event.preventDefault();
                                event.stopPropagation();
                                closeSettings();
                                isScrubbing = true;
                                progressContainer.classList.add('is-scrubbing-<%- v %>');
                                progressContainer.setPointerCapture(event.pointerId);
                                seekFromEvent(event);
                            });
                            progressContainer.addEventListener('pointermove', (event) => {
                                if (!isScrubbing) return;
                                event.preventDefault();
                                seekFromEvent(event);
                            });
                            progressContainer.addEventListener('pointerup', (event) => {
                                if (!isScrubbing) return;
                                event.preventDefault();
                                isScrubbing = false;
                                progressContainer.classList.remove('is-scrubbing-<%- v %>');
                                try {
                                    progressContainer.releasePointerCapture(event.pointerId);
                                } catch(e) {}
                            });
                            progressContainer.addEventListener('keydown', (event) => {
                                const duration = Number.isFinite(video.duration) ? video.duration : 0;
                                if (!duration) return;
                                if (event.key === 'ArrowLeft') {
                                    event.preventDefault();
                                    video.currentTime = Math.max(0, video.currentTime - 5);
                                } else if (event.key === 'ArrowRight') {
                                    event.preventDefault();
                                    video.currentTime = Math.min(duration, video.currentTime + 5);
                                }
                            });

                            fsBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                closeSettings();
                                setVolumeOpen(false);
                                if (!document.fullscreenElement) {
                                    wrapper.requestFullscreen().catch(() => {});
                                } else {
                                    document.exitFullscreen().catch(() => {});
                                }
                            });

                            speedRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                speedIdx = (speedIdx + 1) % speeds.length;
                                video.playbackRate = speeds[speedIdx];
                                speedValue.innerText = speeds[speedIdx] === 1 ? 'Normal' : speeds[speedIdx] + 'x';
                                showControls();
                            });

                            loopRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                video.loop = !video.loop;
                                loopValue.innerText = video.loop ? 'On' : 'Off';
                                showControls();
                            });

                            video.addEventListener('click', () => {
                                closeSettings();
                                setVolumeOpen(false);
                                togglePlay();
                            });
                            video.addEventListener('contextmenu', (event) => event.preventDefault());
                            wrapper.addEventListener('contextmenu', (event) => event.preventDefault());

                            document.addEventListener('click', (event) => {
                                if (!controls.contains(event.target)) {
                                    closeSettings();
                                    setVolumeOpen(false);
                                }
                            });

                            video.addEventListener('timeupdate', updateTime);
                            video.addEventListener('loadedmetadata', updateTime);
                            video.addEventListener('durationchange', updateTime);
                            video.addEventListener('volumechange', updateVolumeUI);
                            video.addEventListener('canplay', () => {
                                hideRetryOverlay();
                            });
                            video.addEventListener('playing', () => {
                                hideRetryOverlay();
                            });
                            video.addEventListener('error', () => {
                                queueRetry();
                            });

                            video.addEventListener('play', () => {
                                retryCount = 0;
                                clearTimeout(retryTimer);
                                playPausePathEl.setAttribute('d', pauseIcon);
                                hideRetryOverlay();
                                showControls();
                            });
                            video.addEventListener('pause', () => {
                                playPausePathEl.setAttribute('d', playIcon);
                                controls.style.opacity = '1';
                                wrapper.style.cursor = 'default';
                                clearTimeout(hideTimeout);
                            });

                            let lastMouseMove = 0;
                            wrapper.addEventListener('mousemove', () => {
                                const now = Date.now();
                                if (now - lastMouseMove > 50) {
                                    lastMouseMove = now;
                                    showControls();
                                }
                            });
                            wrapper.addEventListener('mouseleave', () => {
                                if (!video.paused && !settingsPanel.classList.contains('is-open-<%- v %>') && !volGroup.classList.contains('is-volume-open-<%- v %>')) {
                                    controls.style.opacity = '0';
                                }
                            });

                            updateVolumeUI();
                            video.play().catch(() => {});
                        });
                    }
                });
            </script>
        <% } %>

    <% } %></body></html>
