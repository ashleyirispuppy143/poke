                                    <div class="progress-container-<%- v %>" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0">
                                        <div class="progress-fill-<%- v %>"></div>
                                        <div class="progress-thumb-<%- v %>"></div>
                                    </div>

                                    <div class="controls-row-bottom-<%- v %>">
                                        <div class="bottom-left-controls-<%- v %>">
                                            <button class="link-circle-btn-<%- v %> link-btn-<%- v %>" type="button" title="Copy Link">
                                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
                                            </button>
                                        </div>
                                        <div class="bottom-right-controls-<%- v %>">
                                            <button class="more-videos-pill-<%- v %>" type="button" title="More videos">
                                                <span>More videos</span>
                                                <div class="more-videos-icon-wrapper-<%- v %>">
                                                    ${posterSrc ? `<img src="${posterSrc.replace(/"/g, '&quot;')}" style="width: 100%; height: 100%; object-fit: cover;" alt="">` : `<svg viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8 12.5v-9l6 4.5-6 4.5z"/></svg>`}
                                                </div>
                                            </button>
                                            <a href="/" target="_blank" rel="noopener noreferrer" class="logo-link-<%- v %>">
                                                <img src="/css/logo-poke.svg" alt="Poke Logo" class="logo-img-<%- v %>">
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            `;

                            if (logoLink) {
                                logoLink.style.display = 'none';
                            }

                            wrapper.insertBefore(audio, wrapper.firstChild);
                            wrapper.insertBefore(video, audio.nextSibling);
                            wrapper.appendChild(statsOverlayWrapper);
                            wrapper.appendChild(controls);

                            // --- Core Audio/Video Sync Controller ---
                            let activeQuality = '360p'; 
                            let isAutoQuality = true;
                            let is720pAvailable = true;
                            let isDualPlaying = false;
                            let isIntendedToPlay = true; 
                            let lastVolume = 1;
                            let isSwitchingQuality = false;

                            let pendingSeekTime = 0;
                            let isSeekingPending = false;

                            let lastPlayToggle = 0;
                            let qualityChangeTimestamps = [];

                            function getPrimaryMedia() {
                                return isDualPlaying ? audio : video;
                            }
                            function getDuration() {
                                return getPrimaryMedia().duration || 0;
                            }
                            function getCurrentTime() {
                                return getPrimaryMedia().currentTime || 0;
                            }
                            function setCurrentTime(t) {
                                video.currentTime = t;
                                if (isDualPlaying) audio.currentTime = t;
                            }
                            
                            function updatePlayPauseUI() {
                                if (isIntendedToPlay) {
                                    playPausePathEl.setAttribute('d', pauseIcon);
                                } else {
                                    playPausePathEl.setAttribute('d', playIcon);
                                    controls.style.opacity = '1';
                                    wrapper.style.cursor = 'default';
                                    clearTimeout(hideTimeout);
                                }
                                if ('mediaSession' in navigator) {
                                    navigator.mediaSession.playbackState = isIntendedToPlay ? 'playing' : 'paused';
                                }
                            }

                            function playMedia() {
                                isIntendedToPlay = true;
                                updatePlayPauseUI();
                                if (isDualPlaying) {
                                    audio.play().catch(()=>{});
                                    video.play().catch(()=>{});
                                } else {
                                    video.play().catch(()=>{});
                                }
                            }
                            
                            function pauseMedia() {
                                isIntendedToPlay = false;
                                updatePlayPauseUI();
                                video.pause();
                                if (isDualPlaying) audio.pause();
                            }

                            function togglePlay() {
                                const now = Date.now();
                                if (now - lastPlayToggle < 300) return;
                                lastPlayToggle = now;

                                if (getPrimaryMedia().paused || !isIntendedToPlay) {
                                    playMedia();
                                } else {
                                    pauseMedia();
                                }
                            }

                            if ('mediaSession' in navigator) {
                                navigator.mediaSession.setActionHandler('play', playMedia);
                                navigator.mediaSession.setActionHandler('pause', pauseMedia);
                                navigator.mediaSession.setActionHandler('seekbackward', (details) => {
                                    setCurrentTime(Math.max(getCurrentTime() - (details.seekOffset || 10), 0));
                                    updateTime();
                                });
                                navigator.mediaSession.setActionHandler('seekforward', (details) => {
                                    const dur = getDuration();
                                    setCurrentTime(Math.min(getCurrentTime() + (details.seekOffset || 10), dur ? dur : 0));
                                    updateTime();
                                });
                                navigator.mediaSession.setActionHandler('seekto', (details) => {
                                    setCurrentTime(details.seekTime);
                                    updateTime();
                                });
                            }

                            function setMediaVolume(v) {
                                lastVolume = v;
                                if (isDualPlaying) {
                                    audio.volume = v;
                                    audio.muted = (v === 0);
                                    video.muted = true; // Video ALWAYS muted in dual mode
                                } else {
                                    video.volume = v;
                                    video.muted = (v === 0);
                                }
                                updateVolumeUI();
                            }
                            
                            function setPlaybackRate(r) {
                                video.playbackRate = r;
                                audio.playbackRate = r;
                            }

                            const toastEl = controls.querySelector('.toast-indicator-<%- v %>');
                            let toastTimeout = null;
                            function showToast(msg, duration = 3000) {
                                if (!toastEl) return;
                                toastEl.innerText = msg;
                                toastEl.classList.add('is-visible');
                                clearTimeout(toastTimeout);
                                if (duration > 0) {
                                    toastTimeout = setTimeout(() => {
                                        toastEl.classList.remove('is-visible');
                                    }, duration);
                                }
                            }

                            function updateQualityUI() {
                                const qualityListItems = controls.querySelectorAll('.quality-list-item-<%- v %>');
                                qualityListItems.forEach(item => {
                                    item.classList.remove('is-active');
                                    const qual = item.getAttribute('data-quality');
                                    
                                    if (isAutoQuality && qual === 'Auto') {
                                        item.classList.add('is-active');
                                        const lbl = item.querySelector('.auto-quality-label-<%- v %>');
                                        if(lbl) lbl.innerText = activeQuality;
                                    } else if (!isAutoQuality && qual === activeQuality) {
                                        item.classList.add('is-active');
                                    }
                                });
                                
                                const qv = controls.querySelector('.quality-value-<%- v %>');
                                if (qv) {
                                    qv.innerText = isAutoQuality ? `Auto (${activeQuality})` : activeQuality;
                                }
                            }

                            function requestQualityChange(requestedQuality, silent = false) {
                                if (requestedQuality === activeQuality) return;
                                
                                const now = Date.now();
                                qualityChangeTimestamps = qualityChangeTimestamps.filter(t => now - t < 10000);
                                
                                if (qualityChangeTimestamps.length >= 3 && !silent) {
                                    showToast("Quality changes rate-limited. Wait a few seconds.", 3000);
                                    return;
                                }
                                
                                qualityChangeTimestamps.push(now);
                                loadQuality(requestedQuality, getCurrentTime(), null, silent);
                            }

                            function loadQuality(quality, timeToSeek = 0, nonce = null, silent = false) {
                                activeQuality = quality;
                                isDualPlaying = (quality === '720p');
                                
                                pendingSeekTime = timeToSeek;
                                isSeekingPending = true;

                                if (!silent) {
                                    isSwitchingQuality = true;
                                    showToast(`Switching to ${quality}...`, 0); 
                                    setBuffering(true);
                                    video.style.opacity = '0.01'; // Hide to prevent showing frame 0
                                }
                                
                                updateQualityUI();

                                if (isDualPlaying) {
                                    video.src = getVideoUrl(247, nonce);
                                    audio.src = getVideoUrl(140, nonce);
                                    video.muted = true;
                                    video.currentTime = timeToSeek;
                                    audio.currentTime = timeToSeek;
                                    audio.playbackRate = video.playbackRate;
                                    if(isIntendedToPlay) {
                                        audio.play().catch(()=>{});
                                        video.play().catch(()=>{});
                                    }
                                } else {
                                    audio.pause();
                                    audio.removeAttribute('src'); 
                                    audio.load();

                                    video.src = getVideoUrl(18, nonce);
                                    video.muted = (lastVolume === 0);
                                    video.currentTime = timeToSeek;
                                    if(isIntendedToPlay) {
                                        video.play().catch(()=>{});
                                    }
                                }
                                setMediaVolume(lastVolume);
                            }

                            function testAndUpgradeTo720p() {
                                const dummy = document.createElement('video');
                                dummy.src = getVideoUrl(247);
                                dummy.onloadedmetadata = () => {
                                    is720pAvailable = true;
                                    if (isAutoQuality && activeQuality !== '720p' && forcedQuality !== '360p') {
                                        loadQuality('720p', getCurrentTime(), null, true);
                                    }
                                    dummy.removeAttribute('src');
                                    dummy.load();
                                };
                                dummy.onerror = () => {
                                    is720pAvailable = false;
                                    const qBtn = controls.querySelector('.quality-list-item-<%- v %>[data-quality="720p"]');
                                    if(qBtn) {
                                        qBtn.style.display = 'none';
                                    }
                                    
                                    if (activeQuality === '720p' || (isAutoQuality && activeQuality !== '360p')) {
                                        loadQuality('360p', getCurrentTime(), null, true);
                                    } else {
                                        updateQualityUI();
                                    }
                                };
                            }

                            // --- UI References ---
                            const playPauseBtn = controls.querySelector('.play-pause-btn-<%- v %>');
                            const playPausePathEl = controls.querySelector('.play-pause-path');
                            const muteBtn = controls.querySelector('.mute-btn-<%- v %>');
                            const mutePathEl = controls.querySelector('.mute-path');
                            const volGroup = controls.querySelector('.vol-group-<%- v %>');
                            const volSliderBg = controls.querySelector('.volume-slider-bg-<%- v %>');
                            const volFill = controls.querySelector('.volume-slider-fill-<%- v %>');
                            const volThumb = controls.querySelector('.volume-slider-thumb-<%- v %>');
                            const fsBtn = controls.querySelector('.fs-btn-<%- v %>');
                            const progressContainer = controls.querySelector('.progress-container-<%- v %>');
                            const progressFill = controls.querySelector('.progress-fill-<%- v %>');
                            const progressThumb = controls.querySelector('.progress-thumb-<%- v %>');
                            const timeDisplay = controls.querySelector('.time-display-<%- v %>');
                            const bufferingWrapper = controls.querySelector('.buffering-wrapper-<%- v %>');
                            
                            const settingsBtn = controls.querySelector('.settings-btn-<%- v %>');
                            const settingsPanel = controls.querySelector('.settings-panel-<%- v %>');
                            const settingsGrabberArea = controls.querySelector('.settings-grabber-area-<%- v %>');
                            
                            const qualityRow = controls.querySelector('.quality-row-<%- v %>');
                            const qualityPanel = controls.querySelector('.quality-panel-<%- v %>');
                            const qualityListItems = controls.querySelectorAll('.quality-list-item-<%- v %>');

                            const speedRow = controls.querySelector('.speed-row-<%- v %>');
                            const speedValue = controls.querySelector('.speed-value-<%- v %>');
                            const speedPanel = controls.querySelector('.speed-panel-<%- v %>');
                            const speedHeader = controls.querySelector('.speed-panel-header-<%- v %>');
                            const speedSlider = controls.querySelector('.speed-slider-input-<%- v %>');
                            const speedMinus = controls.querySelector('.speed-minus-<%- v %>');
                            const speedPlus = controls.querySelector('.speed-plus-<%- v %>');
                            const speedPresets = controls.querySelectorAll('.speed-preset-btn-<%- v %>');
                            
                            const loopRow = controls.querySelector('.loop-row-<%- v %>');
                            const loopValue = controls.querySelector('.loop-value-<%- v %>');

                            const embedPanel = controls.querySelector('.embed-popup-container-<%- v %>');
                            const embedRow = controls.querySelector('.embed-row-<%- v %>');
                            const embedWidth = controls.querySelector('.embed-width-<%- v %>');
                            const embedHeight = controls.querySelector('.embed-height-<%- v %>');
                            const embedText = controls.querySelector('.embed-textarea-popup-<%- v %>');
                            const embedClose = controls.querySelector('.embed-popup-close-<%- v %>');
                            
                            const statsRow = controls.querySelector('.stats-row-<%- v %>');
                            const statsOverlay = wrapper.querySelector('.stats-overlay-<%- v %>');
                            const statsContent = wrapper.querySelector('.stats-content-<%- v %>');
                            const statsClose = wrapper.querySelector('.stats-close-<%- v %>');
                            
                            const restartBtn = endOverlay.querySelector('.restart-btn-<%- v %>');
                            
                            const linkBtn = controls.querySelector('.link-btn-<%- v %>');

                            let showRemainingTime = false;
                            let retryCount = 0;
                            let retryTimer = null;
                            const maxRetries = 3;
                            let lastWidth = '';
                            let lastText = '';
                            let isRafPending = false;
                            let hideTimeout = null;
                            let isScrubbing = false;
                            let statsUpdateInterval = null;
                            let isNaturalEnd = true;
                            let hasSeekedNearEnd = false;
                            const sCPN = Math.random().toString(36).substring(2, 14).toUpperCase();

                            let isDraggingSettings = false;
                            let settingsStartY = 0;
                            let settingsCurrentY = 0;

                            function formatTime(s) {
                                if (!Number.isFinite(s)) return '0:00';
                                s = Math.max(0, s);
                                const h = Math.floor(s / 3600);
                                const m = Math.floor((s % 3600) / 60);
                                const sec = Math.floor(s % 60);
                                if (h > 0) {
                                    return h + ':' + String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
                                }
                                return m + ':' + String(sec).padStart(2, '0');
                            }

                            function updateVolumeUI() {
                                const effectiveVolume = isDualPlaying ? (audio.muted ? 0 : audio.volume) : (video.muted ? 0 : video.volume);
                                const pct = effectiveVolume * 100;
                                if(volFill) volFill.style.height = pct + '%';
                                if(volThumb) volThumb.style.bottom = pct + '%';
                                if(mutePathEl) mutePathEl.setAttribute('d', effectiveVolume <= 0 ? muteIcon : volIcon);
                            }

                            let isVolScrubbing = false;
                            function handleVolumeEvent(e) {
                                if(!volSliderBg) return;
                                const rect = volSliderBg.getBoundingClientRect();
                                let y = e.clientY - rect.top;
                                let p = 1 - (y / rect.height);
                                p = Math.max(0, Math.min(1, p));
                                setMediaVolume(p);
                            }

                            function setVolumeOpen(open) {
                                volGroup.classList.toggle('is-volume-open-<%- v %>', open);
                            }

                            function setSettingsOpen(open) {
                                if (open) {
                                    setVolumeOpen(false);
                                    if (speedPanel) speedPanel.classList.remove('is-open-<%- v %>');
                                    if (qualityPanel) qualityPanel.classList.remove('is-open-<%- v %>');
                                    if (embedPanel) embedPanel.classList.remove('is-open-<%- v %>');
                                }
                                settingsPanel.style.transform = '';
                                settingsPanel.classList.toggle('is-open-<%- v %>', open);
                                settingsPanel.setAttribute('aria-hidden', open ? 'false' : 'true');
                                settingsBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
                            }

                            function closeAllPanels() {
                                setSettingsOpen(false);
                                setVolumeOpen(false);
                                [speedPanel, qualityPanel, embedPanel].forEach(p => {
                                    if(p) {
                                        p.classList.remove('is-open-<%- v %>');
                                        p.setAttribute('aria-hidden', 'true');
                                    }
                                });
                            }

                            function setBuffering(isBuffering) {
                                if (isBuffering) {
                                    bufferingWrapper.classList.add('is-buffering-<%- v %>');
                                    playPauseBtn.style.display = 'none';
                                } else {
                                    bufferingWrapper.classList.remove('is-buffering-<%- v %>');
                                    playPauseBtn.style.display = 'flex';
                                }
                            }

                            function showRuntimeError() {
                                clearTimeout(retryTimer);
                                closeAllPanels();
                                setBuffering(false);
                                pauseMedia();
                                video.removeAttribute('poster');
                                video.style.display = 'none';
                                audio.style.display = 'none';
                                controls.style.display = 'none';
                                playerLink.style.display = 'none';
                                wrapper.style.backgroundColor = '#212121';

                                let errContainer = wrapper.querySelector('.video-runtime-error-<%- v %>');
                                if (!errContainer) {
                                    errContainer = document.createElement('div');
                                    errContainer.className = 'video-error-container-<%- v %> video-runtime-error-<%- v %>';
                                    errContainer.style.position = 'absolute';
                                    errContainer.style.top = '0';
                                    errContainer.style.left = '0';
                                    errContainer.style.width = '100%';
                                    errContainer.style.height = '100%';
                                    errContainer.style.zIndex = '100';
                                    errContainer.style.backgroundColor = '#212121';
                                    errContainer.innerHTML = `
                                        <svg class="error-icon-<%- v %>" viewBox="0 0 24 24" style="color: #aaaaaa;">
                                            <path fill="currentColor" d="M12,2C6.48,2,2,6.48,2,12c0,5.52,4.48,10,10,10s10-4.48,10-10C22,6.48,17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z"/>
                                        </svg>
                                        <div class="error-text-<%- v %>">
                                            <div class="error-title-<%- v %>" style="margin-bottom: 12px;">Video playback failed</div>
                                            <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
                                                <button class="embed-btn-<%- v %> retry-btn-<%- v %>" type="button" style="cursor: pointer;">Retry</button>
                                                <a href="/watch?v=<%- v %>" target="_blank" rel="noopener noreferrer" style="color: #ffabcc; text-decoration: none; font-size: 16px; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; font-family: 'PokeTube Flex', Arial, sans-serif;">
                                                    Watch on Poke
                                                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                                                </a>
                                            </div>
                                        </div>
                                    `;
                                    wrapper.appendChild(errContainer);

                                    const retryButton = errContainer.querySelector('.retry-btn-<%- v %>');
                                    retryButton.addEventListener('click', (event) => {
                                        event.stopPropagation();
                                        retryCount = 0;
                                        errContainer.style.display = 'none';
                                        wrapper.style.backgroundColor = '#000';
                                        video.style.display = 'block';
                                        controls.style.display = '';
                                        playerLink.style.display = 'none';
                                        if (posterSrc) video.poster = posterSrc;
                                        
                                        loadQuality(activeQuality, getCurrentTime(), Date.now());
                                    });
                                } else {
                                    errContainer.style.display = 'flex';
                                }
                            }

                            function queueRetry() {
                                if (retryCount >= maxRetries) {
                                    if (activeQuality === '720p') {
                                        showToast("720p stream failed, falling back to 360p", 3000);
                                        retryCount = 0;
                                        is720pAvailable = false;
                                        const qBtn = controls.querySelector('.quality-list-item-<%- v %>[data-quality="720p"]');
                                        if(qBtn) qBtn.style.display = 'none';
                                        loadQuality('360p', getCurrentTime(), null, true);
                                        return;
                                    }
                                    showRuntimeError();
                                    return;
                                }
                                retryCount++;
                                retryTimer = setTimeout(() => {
                                    loadQuality(activeQuality, getCurrentTime(), Date.now() + '-' + retryCount);
                                }, 900);
                            }

                            function updateTime() {
                                if (isRafPending) return;
                                isRafPending = true;
                                requestAnimationFrame(() => {
                                    const pm = getPrimaryMedia();
                                    const duration = Number.isFinite(pm.duration) ? pm.duration : 0;
                                    const current = Number.isFinite(pm.currentTime) ? pm.currentTime : 0;
                                    const p = duration ? Math.max(0, Math.min(100, (current / duration) * 100)) : 0;
                                    const newWidth = p + '%';

                                    if (lastWidth !== newWidth) {
                                        progressFill.style.width = newWidth;
                                        progressThumb.style.left = newWidth;
                                        progressContainer.setAttribute('aria-valuenow', String(Math.round(p)));
                                        lastWidth = newWidth;
                                    }

                                    const newText = showRemainingTime
                                        ? `-${formatTime(duration - current)} / ${formatTime(duration)}`
                                        : `${formatTime(current)} / ${formatTime(duration)}`;

                                    if (lastText !== newText) {
                                        timeDisplay.innerText = newText;
                                        lastText = newText;
                                    }
                                    isRafPending = false;
                                });
                            }

                            function seekFromEvent(event) {
                                const duration = getDuration();
                                if (!duration) return;
                                const r = progressContainer.getBoundingClientRect();
                                const x = Math.max(0, Math.min(r.width, event.clientX - r.left));
                                setCurrentTime((x / r.width) * duration);
                                updateTime();
                            }

                            function showControls() {
                                controls.style.opacity = '1';
                                wrapper.style.cursor = 'default';
                                clearTimeout(hideTimeout);
                                hideTimeout = setTimeout(() => {
                                    if (!getPrimaryMedia().paused && !settingsPanel.classList.contains('is-open-<%- v %>') && !speedPanel.classList.contains('is-open-<%- v %>') && !qualityPanel.classList.contains('is-open-<%- v %>') && !embedPanel.classList.contains('is-open-<%- v %>') && !volGroup.classList.contains('is-volume-open-<%- v %>')) {
                                        controls.style.opacity = '0';
                                        wrapper.style.cursor = 'none';
                                    }
                                }, 2500);
                            }

                            function updateSpeedState(newSpeed) {
                                newSpeed = Math.max(0.25, Math.min(2, newSpeed));
                                setPlaybackRate(newSpeed);
                                speedSlider.value = newSpeed;
                                speedHeader.innerText = newSpeed.toFixed(2) + 'x';
                                speedValue.innerText = newSpeed === 1 ? 'Normal' : newSpeed + 'x';

                                const pct = ((newSpeed - 0.25) / (2 - 0.25)) * 100;
                                speedSlider.style.background = `linear-gradient(to right, #fff ${pct}%, rgba(255, 255, 255, 0.3) ${pct}%)`;

                                speedPresets.forEach(btn => {
                                    const spd = parseFloat(btn.getAttribute('data-speed'));
                                    btn.classList.toggle('is-active', Math.abs(spd - newSpeed) < 0.01);
                                });
                            }

                            function updateEmbedCode() {
                                const w = embedWidth.value || '560';
                                const h = embedHeight.value || '315';
                                const fqEl = controls.querySelector('.embed-forcequality-<%- v %>');
                                const fq = fqEl ? fqEl.value : '';
                                const srcUrl = `https://<%= typeof hostname !== 'undefined' ? hostname : '' %>/embed/<%- v %>${fq ? '?forcequality=' + fq : ''}`;
                                const fqAttr = fq ? ` forcequality="${fq}"` : ' forcequality=""';
                                embedText.value = `<iframe src="${srcUrl}" width="${w}" height="${h}" frameborder="0" style="border-radius: 16px;"${fqAttr} referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>`;
                            }

                            function updateStats() {
                                if(!statsOverlay.classList.contains('is-visible-<%- v %>')) return;
                                const vW = video.videoWidth || 0;
                                const vH = video.videoHeight || 0;
                                const cW = wrapper.clientWidth || 0;
                                const cH = wrapper.clientHeight || 0;
                                const vd = '<%- v %>';
                                const vol = Math.round(lastVolume * 100);
                                const pbRate = video.playbackRate;
                                const pm = getPrimaryMedia();
                                const ct = pm.currentTime.toFixed(3);
                                const dur = (pm.duration || 0).toFixed(3);
                                
                                let dropped = 0;
                                let total = 0;
                                if (typeof video.getVideoPlaybackQuality === 'function') {
                                    const pq = video.getVideoPlaybackQuality();
                                    dropped = pq.droppedVideoFrames;
                                    total = pq.totalVideoFrames;
                                }

                                let bufferHealth = 0;
                                try {
                                    for (let i = 0; i < pm.buffered.length; i++) {
                                        if (pm.buffered.start(i) <= pm.currentTime && pm.buffered.end(i) >= pm.currentTime) {
                                            bufferHealth = pm.buffered.end(i) - pm.currentTime;
                                            break;
                                        }
                                    }
                                } catch(e) {}
                                
                                const resStr = vW && vH ? `${vW}x${vH}` : '0x0';
                                const optimalRes = isDualPlaying ? '1280x720@30' : '640x360@30';
                                const codecStr = isDualPlaying ? 'avc1.4d401e (247) / mp4a.40.2 (140)' : 'avc1.42001E, mp4a.40.2 (18)';

                                statsContent.innerHTML = `
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Video ID / sCPN</span><span class="stats-value-<%- v %>">${vd} / ${sCPN}</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Viewport / Frames</span><span class="stats-value-<%- v %>">${cW}x${cH} / ${dropped} dropped of ${total}</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Current / Optimal Res</span><span class="stats-value-<%- v %>">${resStr} / ${optimalRes}</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Volume / Normalized</span><span class="stats-value-<%- v %>">${vol}% / ${vol}% (content loudness 0.0dB)</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Codecs</span><span class="stats-value-<%- v %>">${codecStr}</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Color</span><span class="stats-value-<%- v %>">bt709 / bt709</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Buffer Health</span><span class="stats-value-<%- v %>">${bufferHealth.toFixed(2)} s</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Network Activity</span><span class="stats-value-<%- v %>">${pm.networkState === 2 ? 'Downloading' : 'Idle'}</span></div>
                                    <div class="stats-line-<%- v %>"><span class="stats-label-<%- v %>">Mystery Text</span><span class="stats-value-<%- v %>">vd:y, q:${activeQuality}, r:${retryCount}</span></div>
                                `;
                            }

                            // --- Event Listeners Mapping ---
                            const bindMediaEvent = (evt, handler) => {
                                video.addEventListener(evt, (e) => { if(!isDualPlaying || e.target === video) handler(e, video); });
                                audio.addEventListener(evt, (e) => { if(isDualPlaying && e.target === audio) handler(e, audio); });
                            };

                            bindMediaEvent('loadedmetadata', () => {
                                if (isSeekingPending) {
                                    video.currentTime = pendingSeekTime;
                                    if (isDualPlaying) audio.currentTime = pendingSeekTime;
                                    isSeekingPending = false;
                                }
                                updateTime();
                            });
                            
                            bindMediaEvent('timeupdate', updateTime);
                            bindMediaEvent('durationchange', updateTime);

                            video.addEventListener('seeked', () => {
                                video.style.opacity = '1';
                                setBuffering(false);
                            });

                            video.addEventListener('error', () => { setBuffering(false); queueRetry(); });
                            audio.addEventListener('error', () => { if(isDualPlaying){ setBuffering(false); queueRetry(); } });

                            function onEndedHandler() {
                                if (isNaturalEnd && !hasSeekedNearEnd && (getDuration() >= 120) && !video.loop) {
                                    endOverlay.classList.add('is-visible-<%- v %>');
                                    controls.style.display = 'none';
                                } else if (video.loop) {
                                    setCurrentTime(0);
                                    playMedia();
                                }
                            }
                            video.addEventListener('ended', onEndedHandler);
                            audio.addEventListener('ended', onEndedHandler);

                            // The Central Synchronization Loop
                            setInterval(() => {
                                if (!isIntendedToPlay) return; 

                                const pm = getPrimaryMedia();
                                if (!pm.src) return; 

                                if (isDualPlaying) {
                                    if (pm.ended && !video.loop) return;

                                    const vReady = video.readyState >= 3;
                                    const aReady = audio.readyState >= 3;
                                    
                                    let isBuffering = false;
                                    if (document.hidden) {
                                        // In background, only pause if audio stalls to prevent chromium dropping playstate
                                        isBuffering = !aReady;
                                    } else {
                                        isBuffering = !vReady || !aReady;
                                    }

                                    if (isBuffering) {
                                        setBuffering(true);
                                        if (!audio.paused) audio.pause();
                                        if (!video.paused) video.pause();
                                    } else {
                                        setBuffering(false);
                                        if (isSwitchingQuality) {
                                            isSwitchingQuality = false;
                                            showToast(`Switched to ${activeQuality}`, 2000);
                                            video.style.opacity = '1';
                                        }
                                        
                                        // Drift correction. Audio leads.
                                        if (Math.abs(audio.currentTime - video.currentTime) > 0.3) {
                                            video.currentTime = audio.currentTime;
                                        }
                                        
                                        if (audio.paused) audio.play().catch(()=>{});
                                        if (video.paused && !document.hidden) video.play().catch(()=>{});
                                    }
                                } else {
                                    if (video.ended && !video.loop) return;

                                    if (video.readyState < 3) {
                                        setBuffering(true);
                                        if (!video.paused) video.pause();
                                    } else {
                                        setBuffering(false);
                                        if (isSwitchingQuality) {
                                            isSwitchingQuality = false;
                                            showToast(`Switched to ${activeQuality}`, 2000);
                                            video.style.opacity = '1';
                                        }
                                        if (video.paused) video.play().catch(()=>{});
                                    }
                                }
                            }, 250);

                            document.addEventListener('visibilitychange', () => {
                                if (!document.hidden && isDualPlaying && isIntendedToPlay) {
                                    if (Math.abs(video.currentTime - audio.currentTime) > 0.1) {
                                        video.currentTime = audio.currentTime;
                                    }
                                    video.play().catch(()=>{});
                                }
                            });

                            // Seeking logic (to detect manual seeks near the end to prevent early end screens)
                            video.addEventListener('seeking', () => {
                                if (getDuration() && (getDuration() - getCurrentTime() <= 20)) {
                                    hasSeekedNearEnd = true;
                                    isNaturalEnd = false;
                                }
                            });
                            audio.addEventListener('seeking', () => {
                                if (isDualPlaying && getDuration() && (getDuration() - getCurrentTime() <= 20)) {
                                    hasSeekedNearEnd = true;
                                    isNaturalEnd = false;
                                }
                            });

                            // Interaction setup
                            volGroup.addEventListener('click', (event) => event.stopPropagation());
                            volGroup.addEventListener('pointerenter', () => setVolumeOpen(true));
                            volGroup.addEventListener('pointerleave', () => setVolumeOpen(false));
                            
                            settingsBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                setSettingsOpen(!settingsPanel.classList.contains('is-open-<%- v %>'));
                            });
                            settingsPanel.addEventListener('click', (event) => event.stopPropagation());
                            
                            settingsGrabberArea.addEventListener('pointerdown', (e) => {
                                e.stopPropagation();
                                isDraggingSettings = true;
                                settingsStartY = e.clientY;
                                settingsPanel.style.transition = 'none';
                                try { settingsGrabberArea.setPointerCapture(e.pointerId); } catch(err) {}
                            });
                            settingsGrabberArea.addEventListener('pointermove', (e) => {
                                if (!isDraggingSettings) return;
                                e.stopPropagation();
                                settingsCurrentY = Math.max(0, e.clientY - settingsStartY);
                                settingsPanel.style.transform = `translate(-50%, ${settingsCurrentY}px)`;
                            });
                            settingsGrabberArea.addEventListener('pointerup', (e) => {
                                if (!isDraggingSettings) return;
                                e.stopPropagation();
                                isDraggingSettings = false;
                                settingsPanel.style.transition = 'opacity 0.16s ease, transform 0.16s ease';
                                try { settingsGrabberArea.releasePointerCapture(e.pointerId); } catch(err) {}
                                
                                if (settingsCurrentY > 40) {
                                    setSettingsOpen(false);
                                } else {
                                    settingsPanel.style.transform = '';
                                }
                                settingsCurrentY = 0;
                            });

                            qualityPanel.addEventListener('click', (e) => e.stopPropagation());
                            speedPanel.addEventListener('click', (e) => e.stopPropagation());
                            embedPanel.addEventListener('click', (e) => e.stopPropagation());
                            statsOverlay.addEventListener('click', (e) => e.stopPropagation());
                            controls.querySelector('.bottom-area-<%- v %>').addEventListener('click', (e) => e.stopPropagation());
                            endOverlay.addEventListener('click', (e) => e.stopPropagation());

                            restartBtn.addEventListener('click', (e) => {
                                e.stopPropagation();
                                endOverlay.classList.remove('is-visible-<%- v %>');
                                controls.style.display = '';
                                isNaturalEnd = true;
                                hasSeekedNearEnd = false;
                                setCurrentTime(0);
                                playMedia();
                            });

                            playPauseBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                closeAllPanels();
                                togglePlay();
                            });
                            playPauseBtn.addEventListener('keydown', (event) => {
                                if (event.key === 'Enter' || event.key === ' ') {
                                    event.preventDefault();
                                    closeAllPanels();
                                    togglePlay();
                                }
                            });

                            if(volSliderBg) {
                                volSliderBg.addEventListener('pointerdown', (e) => {
                                    e.stopPropagation();
                                    setVolumeOpen(true);
                                    isVolScrubbing = true;
                                    volSliderBg.setPointerCapture(e.pointerId);
                                    handleVolumeEvent(e);
                                });
                                volSliderBg.addEventListener('pointermove', (e) => {
                                    if (!isVolScrubbing) return;
                                    e.preventDefault();
                                    handleVolumeEvent(e);
                                });
                                volSliderBg.addEventListener('pointerup', (e) => {
                                    if (!isVolScrubbing) return;
                                    isVolScrubbing = false;
                                    try { volSliderBg.releasePointerCapture(e.pointerId); } catch(err) {}
                                });
                            }

                            muteBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                closeAllPanels();
                                setVolumeOpen(true);
                                if (getPrimaryMedia().muted || lastVolume === 0) {
                                    setMediaVolume(lastVolume > 0 ? lastVolume : 1);
                                } else {
                                    setMediaVolume(0);
                                }
                            });

                            timeDisplay.addEventListener('click', (event) => {
                                event.stopPropagation();
                                showRemainingTime = !showRemainingTime;
                                updateTime();
                            });

                            progressContainer.addEventListener('pointerdown', (event) => {
                                event.preventDefault();
                                event.stopPropagation();
                                closeAllPanels();
                                isScrubbing = true;
                                progressContainer.classList.add('is-scrubbing-<%- v %>');
                                progressContainer.setPointerCapture(event.pointerId);
                                seekFromEvent(event);
                            });
                            progressContainer.addEventListener('pointermove', (event) => {
                                if (!isScrubbing) return;
                                event.preventDefault();
                                seekFromEvent(event);
                            });
                            progressContainer.addEventListener('pointerup', (event) => {
                                if (!isScrubbing) return;
                                event.preventDefault();
                                isScrubbing = false;
                                progressContainer.classList.remove('is-scrubbing-<%- v %>');
                                try { progressContainer.releasePointerCapture(event.pointerId); } catch(e) {}
                            });
                            progressContainer.addEventListener('keydown', (event) => {
                                const duration = getDuration();
                                if (!duration) return;
                                if (event.key === 'ArrowLeft') {
                                    event.preventDefault();
                                    setCurrentTime(Math.max(0, getCurrentTime() - 5));
                                } else if (event.key === 'ArrowRight') {
                                    event.preventDefault();
                                    setCurrentTime(Math.min(duration, getCurrentTime() + 5));
                                }
                            });

                            fsBtn.addEventListener('click', (event) => {
                                event.stopPropagation();
                                closeAllPanels();
                                if (!document.fullscreenElement) {
                                    wrapper.requestFullscreen().catch(() => {});
                                } else {
                                    document.exitFullscreen().catch(() => {});
                                }
                            });

                            qualityRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                setSettingsOpen(false);
                                qualityPanel.classList.add('is-open-<%- v %>');
                                qualityPanel.setAttribute('aria-hidden', 'false');
                            });

                            qualityListItems.forEach(item => {
                                item.addEventListener('click', () => {
                                    if (item.disabled) return;
                                    const requestedQuality = item.getAttribute('data-quality');
                                    
                                    if (requestedQuality === 'Auto') {
                                        isAutoQuality = true;
                                        requestQualityChange(is720pAvailable ? '720p' : '360p');
                                    } else {
                                        isAutoQuality = false;
                                        requestQualityChange(requestedQuality);
                                    }
                                    
                                    closeAllPanels();
                                });
                            });

                            speedRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                setSettingsOpen(false);
                                speedPanel.classList.add('is-open-<%- v %>');
                                speedPanel.setAttribute('aria-hidden', 'false');
                            });

                            speedSlider.addEventListener('input', (e) => {
                                updateSpeedState(parseFloat(e.target.value));
                                showControls();
                            });
                            speedMinus.addEventListener('click', () => {
                                updateSpeedState(parseFloat(speedSlider.value) - 0.05);
                                showControls();
                            });
                            speedPlus.addEventListener('click', () => {
                                updateSpeedState(parseFloat(speedSlider.value) + 0.05);
                                showControls();
                            });
                            speedPresets.forEach(btn => {
                                btn.addEventListener('click', () => {
                                    updateSpeedState(parseFloat(btn.getAttribute('data-speed')));
                                    showControls();
                                });
                            });

                            loopRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                video.loop = !video.loop;
                                loopValue.innerText = video.loop ? 'On' : 'Off';
                                showControls();
                            });

                            embedWidth.addEventListener('input', updateEmbedCode);
                            embedHeight.addEventListener('input', updateEmbedCode);
                            const embedForceQuality = controls.querySelector('.embed-forcequality-<%- v %>');
                            if (embedForceQuality) {
                                embedForceQuality.addEventListener('change', updateEmbedCode);
                            }

                            embedRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                setSettingsOpen(false);
                                embedPanel.classList.add('is-open-<%- v %>');
                                embedPanel.setAttribute('aria-hidden', 'false');
                                updateEmbedCode();
                            });
                            embedClose.addEventListener('click', (event) => {
                                event.stopPropagation();
                                embedPanel.classList.remove('is-open-<%- v %>');
                                embedPanel.setAttribute('aria-hidden', 'true');
                            });
                            
                            statsRow.addEventListener('click', (event) => {
                                event.stopPropagation();
                                setSettingsOpen(false);
                                statsOverlay.classList.toggle('is-visible-<%- v %>');
                                if(statsOverlay.classList.contains('is-visible-<%- v %>')) {
                                    updateStats();
                                    statsUpdateInterval = setInterval(updateStats, 500);
                                } else {
                                    clearInterval(statsUpdateInterval);
                                }
                            });
                            statsClose.addEventListener('click', (event) => {
                                event.stopPropagation();
                                statsOverlay.classList.remove('is-visible-<%- v %>');
                                clearInterval(statsUpdateInterval);
                            });

                            if (linkBtn) {
                                linkBtn.addEventListener('click', (event) => {
                                    event.stopPropagation();
                                    const url = window.location.origin + '/watch?v=<%- v %>';
                                    navigator.clipboard.writeText(url).then(() => {
                                        const originalSvg = linkBtn.innerHTML;
                                        linkBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" style="width: 20px; height: 20px;"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg>';
                                        setTimeout(() => {
                                            if (linkBtn) linkBtn.innerHTML = originalSvg;
                                        }, 1500);
                                    }).catch(() => {});
                                });
                            }

                            const moreVideosBtn = controls.querySelector('.more-videos-pill-<%- v %>');
                            if (moreVideosBtn) {
                                moreVideosBtn.addEventListener('click', (event) => {
                                    event.stopPropagation();
                                    window.open('/home', '_blank');
                                });
                            }

                            video.addEventListener('click', () => {
                                const anyPanelOpen = settingsPanel.classList.contains('is-open-<%- v %>') || 
                                                     speedPanel.classList.contains('is-open-<%- v %>') || 
                                                     qualityPanel.classList.contains('is-open-<%- v %>') ||
                                                     embedPanel.classList.contains('is-open-<%- v %>') ||
                                                     volGroup.classList.contains('is-volume-open-<%- v %>');
                                closeAllPanels();
                                if (anyPanelOpen) return;
                                togglePlay();
                            });
                            
                            video.addEventListener('contextmenu', (event) => event.preventDefault());
                            wrapper.addEventListener('contextmenu', (event) => event.preventDefault());

                            document.addEventListener('click', (event) => {
                                if (!controls.contains(event.target) && !endOverlay.contains(event.target)) {
                                    closeAllPanels();
                                }
                            });

                            let lastMouseMove = 0;
                            wrapper.addEventListener('mousemove', () => {
                                const now = Date.now();
                                if (now - lastMouseMove > 50) {
                                    lastMouseMove = now;
                                    showControls();
                                }
                            });
                            wrapper.addEventListener('mouseleave', () => {
                                if (!getPrimaryMedia().paused && !settingsPanel.classList.contains('is-open-<%- v %>') && !speedPanel.classList.contains('is-open-<%- v %>') && !qualityPanel.classList.contains('is-open-<%- v %>') && !embedPanel.classList.contains('is-open-<%- v %>') && !volGroup.classList.contains('is-volume-open-<%- v %>')) {
                                    controls.style.opacity = '0';
                                }
                            });

                            // --- Init Parsing ---
                            const urlParams = new URLSearchParams(window.location.search);
                            let forcedQuality = urlParams.get('forcequality') || document.body.getAttribute('data-forcequality');
                            
                            try {
                                if (window.frameElement && window.frameElement.hasAttribute('forcequality')) {
                                    forcedQuality = window.frameElement.getAttribute('forcequality') || forcedQuality;
                                }
                            } catch(e) {}

                            // --- Init Flow ---
                            setBuffering(true); 
                            
                            if (forcedQuality === '720p') {
                                isAutoQuality = false;
                                loadQuality('720p', 0, null, true);
                                testAndUpgradeTo720p();
                            } else if (forcedQuality === '360p') {
                                isAutoQuality = false;
                                loadQuality('360p', 0, null, true);
                                testAndUpgradeTo720p(); 
                            } else {
                                isAutoQuality = true;
                                loadQuality('360p', 0, null, true); 
                                testAndUpgradeTo720p(); 
                            }
                            
                            playMedia();

                        });
                    }
                })();
            </script>
        <% } %>

    <% } %></body></html>
